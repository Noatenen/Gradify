@page "/Signup"
@layout BlankLayout
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Forms
@inject NavigationManager nav

<PageTitle>Gradify — הרשמה</PageTitle>

<div class="lp-page">
    <div class="lp-card">

        <div class="lp-brand">
            <span class="lp-brand-dot"></span>
            Gradify
        </div>
        <h1 class="lp-title">הרשמה למערכת</h1>
        <p class="lp-subtitle">צרו חשבון חדש והתחילו לנהל פרויקטים</p>

        <EditForm Model="@newUser" OnValidSubmit="@signup">
            <DataAnnotationsValidator />

            <div class="sp-name-row">
                <div class="lp-field">
                    <label class="lp-label" for="sp-fname">שם פרטי</label>
                    <InputText id="sp-fname" class="lp-input" @bind-Value="newUser.FirstName" placeholder="ישראל" />
                    <ValidationMessage For="@(() => newUser.FirstName)" />
                </div>
                <div class="lp-field">
                    <label class="lp-label" for="sp-lname">שם משפחה</label>
                    <InputText id="sp-lname" class="lp-input" @bind-Value="newUser.LastName" placeholder="ישראלי" />
                    <ValidationMessage For="@(() => newUser.LastName)" />
                </div>
            </div>

            <div class="lp-field">
                <label class="lp-label" for="sp-email">כתובת מייל</label>
                <InputText id="sp-email" class="lp-input" @bind-Value="newUser.Email" placeholder="your@email.com" />
                <ValidationMessage For="@(() => newUser.Email)" />
            </div>

            <div class="lp-field">
                <label class="lp-label" for="sp-password">סיסמה</label>
                <input id="sp-password" class="lp-input" type="password"
                       value="@newUser.Password"
                       @oninput="e => newUser.Password = e.Value?.ToString() ?? string.Empty"
                       placeholder="••••••••" />
                <ValidationMessage For="@(() => newUser.Password)" />
                @if (!string.IsNullOrEmpty(newUser.Password))
                {
                    <div class="sp-strength">
                        <div class="sp-strength-bar">
                            <div class="sp-strength-fill sp-strength-@StrengthClass"
                                 style="width: @(PasswordStrength * 20)%"></div>
                        </div>
                        <span class="sp-strength-label sp-strength-label-@StrengthClass">@StrengthLabel</span>
                    </div>
                }
            </div>

            <div class="lp-field">
                <label class="lp-label" for="sp-confirm">אימות סיסמה</label>
                <input id="sp-confirm" class="lp-input" type="password"
                       value="@newUser.ConfirmPassword"
                       @oninput="e => newUser.ConfirmPassword = e.Value?.ToString() ?? string.Empty"
                       placeholder="••••••••" />
                @if (!string.IsNullOrEmpty(newUser.ConfirmPassword))
                {
                    <div class="sp-match @(PasswordsMatch ? "sp-match--ok" : "sp-match--err")">
                        <span class="oi @(PasswordsMatch ? "oi-check" : "oi-x")" aria-hidden="true"></span>
                        @(PasswordsMatch ? "הסיסמאות תואמות" : "הסיסמאות אינן תואמות")
                    </div>
                }
            </div>

            @if (!string.IsNullOrEmpty(message))
            {
                <div class="lp-error">@message</div>
            }

            <button class="lp-btn" type="submit" disabled="@loading">
                @(loading ? "נרשם..." : "הרשמה")
            </button>

            <div class="lp-divider"><span>או</span></div>

            <a href="api/Users/google/@PageRoutes.Signup" class="lp-google-btn">
                <svg class="lp-google-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                    <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                    <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
                    <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                </svg>
                הרשמה עם Google
            </a>

            <div class="lp-footer">
                <a href="@PageRoutes.Login" class="lp-link">כבר יש לך חשבון? התחברות</a>
            </div>

        </EditForm>
    </div>
</div>

@code {
    SignupForm newUser = new SignupForm();
    public string message = "";
    bool loading = false;

    [Inject]
    public IAuthenticationService _Auth { get; set; }

    [CascadingParameter]
    private User user { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (user != null)
            nav.NavigateTo(PageRoutes.Dashboard, forceLoad: true, replace: true);
    }

    async Task signup()
    {
        message = "";
        loading = true;
        bool ok = await _Auth.Signup(newUser);
        if (ok)
            nav.NavigateTo(PageRoutes.Dashboard, forceLoad: true, replace: true);
        else
            message = "קרתה תקלה בהרשמה. אנא נסו שוב.";
        loading = false;
    }

    private bool PasswordsMatch =>
        !string.IsNullOrEmpty(newUser.ConfirmPassword) &&
        newUser.Password == newUser.ConfirmPassword;

    private int PasswordStrength
    {
        get
        {
            var p = newUser.Password ?? "";
            if (p.Length == 0) return 0;
            int score = 0;
            if (p.Length >= 8) score++;
            if (p.Any(char.IsUpper)) score++;
            if (p.Any(char.IsLower)) score++;
            if (p.Any(char.IsDigit)) score++;
            if (p.Any(c => !char.IsLetterOrDigit(c))) score++;
            return score;
        }
    }

    private string StrengthClass => PasswordStrength switch
    {
        <= 1 => "weak",
        <= 3 => "medium",
        _    => "strong"
    };

    private string StrengthLabel => PasswordStrength switch
    {
        1 => "חלשה מאוד",
        2 => "חלשה",
        3 => "בינונית",
        4 => "חזקה",
        _ => "חזקה מאוד"
    };
}
