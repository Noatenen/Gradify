@page "/Redirect"
@inject NavigationManager nav
@using System.Web
@using AuthWithAdmin.Client.Services

<PageTitle>Redirecting...</PageTitle>

<!--דף שלא רואים אין צורך לעצב-->

@code {


    [Inject]
    public IAuthenticationService _Auth { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var uri = new Uri(nav.Uri);

        // מציאת הטוקן שהגיע
        var queryParams = HttpUtility.ParseQueryString(uri.Query);
        string? token = queryParams["token"];
        Console.WriteLine(token);

        //אם אין טוקך
        if (string.IsNullOrEmpty(token))
        {
            //חזרה לדף הראשי
            nav.NavigateTo(PageRoutes.LandingPage);
        }
        else
        {
            //אימות המשתמש
            await _Auth.TokenLogin(token);
            await Task.Delay(1); // דיליי קטן - לעדכון הממשק

            // Role-aware default landing — staff → /dashboard/lecturer,
            // mentor → /dashboard/mentor, student → legacy /dashboard.
            var loggedInUser = await _Auth.GetUserFromClaimAsync();
            nav.NavigateTo(RoleService.GetDefaultLandingRoute(loggedInUser), forceLoad: true, replace: true);
        }
    }
}
