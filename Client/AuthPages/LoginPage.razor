@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Forms
@using AuthWithAdmin.Shared.AuthSharedModels
@using AuthWithAdmin.Client.Services
@layout BlankLayout
@inject NavigationManager nav
@inject HttpClient Http

<PageTitle>Gradify — התחברות</PageTitle>

@page "/Login"

<div class="lp-page">
    <div class="lp-card">

        <div class="lp-brand">
            <span class="lp-brand-dot"></span>
            Gradify
        </div>
        <h1 class="lp-title">התחברות למערכת</h1>
        <p class="lp-subtitle">מערכת ניהול פרויקטים אקדמיים</p>

        <EditForm Model="@loginUser" OnValidSubmit="@login">
            <DataAnnotationsValidator />

            <div class="lp-field">
                <label class="lp-label" for="lp-email">כתובת מייל</label>
                <InputText id="lp-email" class="lp-input" @bind-Value="loginUser.Email" placeholder="your@email.com" />
                <ValidationMessage For="@(() => loginUser.Email)" />
            </div>

            <div class="lp-field">
                <label class="lp-label" for="lp-password">סיסמה</label>
                <InputText id="lp-password" class="lp-input" type="password" @bind-Value="loginUser.Password" placeholder="••••••••" />
                <ValidationMessage For="@(() => loginUser.Password)" />
            </div>

            @if (!string.IsNullOrEmpty(message))
            {
                <div class="lp-error">@message</div>
            }

            <button class="lp-btn" type="submit" disabled="@loading">
                @(loading ? "מתחבר..." : "התחברות")
            </button>

            <div class="lp-divider"><span>או</span></div>

            <a href="api/Users/google/@PageRoutes.Login" class="lp-google-btn">
                <svg class="lp-google-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                    <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                    <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
                    <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                </svg>
                התחברות עם Google
            </a>

            <div class="lp-footer">
                <a href="@PageRoutes.ForgetPassword" class="lp-link">שכחת סיסמה?</a>
                <a href="@PageRoutes.Signup" class="lp-link">אין לך חשבון? הרשמה</a>
            </div>

        </EditForm>
    </div>
</div>


@code {

    private LoginForm loginUser = new LoginForm();

    public string message = "";
    bool loading = false;

    [Inject]
    public IAuthenticationService _Auth { get; set; }


    [CascadingParameter]
    private User user { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (user != null)
            nav.NavigateTo(await GetRedirectTarget(user), forceLoad: true, replace: true);
    }

    async Task login()
    {
        loading = true;
        message = "";

        bool LoginOK = await _Auth.Login(loginUser);

        if (LoginOK)
        {
            var loggedInUser = await _Auth.GetUserFromClaimAsync();
            nav.NavigateTo(await GetRedirectTarget(loggedInUser), forceLoad: true, replace: true);
        }
        else
        {
            message = "שם המשתמש או הסיסמה אינם נכונים";
        }
        loading = false;
    }

    private async Task<string> GetRedirectTarget(User? u)
    {
        // Non-students go to their role-specific dashboard
        // (Admin/Staff → /dashboard/lecturer, Mentor → /dashboard/mentor).
        if (!RoleService.IsStudent(u))
            return RoleService.GetDefaultLandingRoute(u);

        // Students: check whether they have a team but no project yet
        try
        {
            var dashboard = await Http.GetFromJsonAsync<DashboardDto>("api/projects/my-dashboard");
            if (dashboard is not null && dashboard.HasTeam && dashboard.Project is null)
                return PageRoutes.StudentCatalog;
        }
        catch { /* fall through to dashboard on any error */ }

        return PageRoutes.Dashboard;
    }


}
