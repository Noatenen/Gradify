@using AuthWithAdmin.Shared.AuthSharedModels

<div class="psc-card">

    <!-- ── Header: icon badge + title + description ── -->
    <div class="psc-header">
        <div class="psc-team-badge">
            <span class="oi oi-layers" aria-hidden="true"></span>
        </div>
        <div class="psc-header-text">
            <h1 class="psc-title">צוות @Project.ProjectNumber – @Project.Title</h1>
            @if (!string.IsNullOrWhiteSpace(Project.Description))
            {
                <p class="psc-description">@Project.Description</p>
            }
        </div>
        @if (!string.IsNullOrWhiteSpace(Project.HealthStatus))
        {
            <span class="psc-health-badge psc-health-@Project.HealthStatus.ToLower()">
                @HealthLabel(Project.HealthStatus)
            </span>
        }
    </div>

    <div class="psc-divider"></div>

    <!-- ── Meta row: team members | mentors ── -->
    <div class="psc-meta-row">

        <!-- Team members -->
        <div class="psc-meta-group">
            <div class="psc-meta-label">
                <span class="oi oi-people" aria-hidden="true"></span>
                חברי צוות
            </div>
            <div class="psc-chips">
                @if (TeamMembers.Count == 0)
                {
                    <span class="psc-chip-empty">לא נמצאו חברי צוות</span>
                }
                @foreach (var member in TeamMembers)
                {
                    <span class="psc-chip" title="@member.MemberRole">@member.FullName</span>
                }
            </div>
        </div>

        <div class="psc-meta-sep"></div>

        <!-- Mentors (with contact tooltip) -->
        <div class="psc-meta-group">
            <div class="psc-meta-label">
                <span class="oi oi-person" aria-hidden="true"></span>
                מנחים
            </div>
            @if (Mentors.Count == 0)
            {
                <span class="psc-chip-empty">לא שויך מנחה</span>
            }
            else
            {
                <div class="psc-contact-list">
                    @foreach (var mentor in Mentors)
                    {
                        <div class="psc-contact-entry">
                            <button class="psc-contact-btn"
                                    @onclick="() => ToggleTooltip(mentor.UserId)"
                                    title="לחץ לפרטי קשר">
                                @mentor.FullName
                                <span class="oi oi-info psc-info-icon" aria-hidden="true"></span>
                            </button>
                            @if (_activeTooltip == mentor.UserId)
                            {
                                <div class="psc-tooltip">
                                    <div class="psc-tooltip-row">
                                        <span class="oi oi-envelope-closed" aria-hidden="true"></span>
                                        <span dir="ltr">@mentor.Email</span>
                                    </div>
                                    <div class="psc-tooltip-row">
                                        <span class="oi oi-phone" aria-hidden="true"></span>
                                        <span dir="ltr">@mentor.Phone</span>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>

    </div>
</div>

@code {
    [Parameter, EditorRequired] public ProjectInfoDto    Project     { get; set; } = default!;
    [Parameter, EditorRequired] public List<TeamMemberDto> TeamMembers { get; set; } = default!;
    [Parameter, EditorRequired] public List<ContactDto>  Mentors     { get; set; } = default!;

    private int? _activeTooltip;

    private void ToggleTooltip(int userId)
        => _activeTooltip = _activeTooltip == userId ? null : userId;

    private static string HealthLabel(string h) => h switch
    {
        "OnTrack"        => "במסלול",
        "NeedsAttention" => "דורש תשומת לב",
        "AtRisk"         => "בסיכון",
        _                => h,
    };
}
