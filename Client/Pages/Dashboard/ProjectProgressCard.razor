@using AuthWithAdmin.Shared.AuthSharedModels

<div class="ppc-card">

    <!-- ── Card header ── -->
    <div class="ppc-header">
        <div class="ppc-header-left">
            <span class="oi oi-bar-chart ppc-icon" aria-hidden="true"></span>
            <h2 class="ppc-title">התקדמות הפרויקט</h2>
        </div>
        <div class="ppc-stats">
            <span class="ppc-stat">
                <span class="ppc-stat-num">@_completedTasks</span>/<span class="ppc-stat-total">@_totalTasks</span>
                משימות
            </span>
            <div class="ppc-stat-sep"></div>
            <span class="ppc-stat">
                <span class="ppc-stat-num">@_completedMilestones</span>/<span class="ppc-stat-total">@Milestones.Count</span>
                אבני דרך
            </span>
        </div>
        <span class="ppc-percent-badge">@_overallPercent%</span>
    </div>

    <!-- ── Overall progress bar ── -->
    <div class="ppc-bar-track" role="progressbar"
         aria-valuenow="@_overallPercent" aria-valuemin="0" aria-valuemax="100"
         aria-label="התקדמות כללית">
        <div class="ppc-bar-fill" style="width: @_overallPercent%"></div>
    </div>

    <!-- ── Milestone timeline (LTR — time flows left→right) ── -->
    @if (Milestones.Count > 0)
    {
        <div class="ppc-timeline">
            @for (int i = 0; i < Milestones.Count; i++)
            {
                var ms      = Milestones[i];
                bool isLast = i == Milestones.Count - 1;

                bool msHasIssue = MilestoneHasProblematicTask(ms);
                string dotClass = msHasIssue ? "attention" : StatusClass(ms.Status);
                <div class="ppc-ms-step">
                    <div class="ppc-ms-dot ppc-ms-@dotClass"
                         title="@ms.Title – @(msHasIssue ? "דורש תשומת לב" : StatusLabel(ms.Status))">
                        <span class="oi @(msHasIssue ? "oi-warning" : StatusIcon(ms.Status))" aria-hidden="true"></span>
                    </div>
                    <div class="ppc-ms-label">
                        <span class="ppc-ms-title">@ms.Title</span>
                        @if (ms.DueDate.HasValue)
                        {
                            <span class="ppc-ms-date">@ms.DueDate.Value.ToString("dd/MM/yy")</span>
                        }
                        <span class="ppc-ms-status-label ppc-sl-@dotClass">
                            @(msHasIssue ? "דורש תשומת לב" : StatusLabel(ms.Status))
                        </span>
                    </div>
                </div>

                @if (!isLast)
                {
                    <div class="ppc-ms-connector @(ms.Status == "Completed" ? "ppc-conn-done" : "")"></div>
                }
            }
        </div>
    }
    else
    {
        <p class="ppc-empty">אבני הדרך טרם הוגדרו לפרויקט זה.</p>
    }

</div>

@code {
    [Parameter, EditorRequired] public List<MilestoneSummaryDto> Milestones { get; set; } = default!;

    private int _totalTasks          => Milestones.Sum(m => m.Tasks.Count);
    private int _completedTasks      => Milestones.Sum(m => m.Tasks.Count(t => t.Status == "Done"));
    private int _completedMilestones => Milestones.Count(m => m.Status == "Completed");

    // Task completion ratio drives the overall bar.
    // When no tasks exist, fall back to milestone completion ratio.
    // TODO: swap for a weighted formula from the backend when available.
    private int _overallPercent =>
        _totalTasks > 0
            ? (int)Math.Round((double)_completedTasks / _totalTasks * 100)
            : Milestones.Count > 0
                ? (int)Math.Round((double)_completedMilestones / Milestones.Count * 100)
                : 0;

    // ── Milestone attention check ─────────────────────────────────────────────
    // Returns true when any task inside the milestone has a returned submission
    // or is overdue — overriding the stored milestone status for display purposes.
    private static bool MilestoneHasProblematicTask(MilestoneSummaryDto ms)
    {
        foreach (var t in ms.Tasks)
        {
            if (t.LatestMentorStatus == "Returned") return true;
            if (t.LatestSubmissionStatus == "NeedsRevision") return true;
            if (t.DueDate.HasValue && t.DueDate.Value.Date < DateTime.Today
                && t.Status is "Open" or "InProgress" or "ReturnedForRevision") return true;
        }
        return false;
    }

    // ── Status helpers — DB strings → UI classes/icons/labels ────────────────

    private static string StatusClass(string s) => s switch
    {
        "Completed"  => "completed",
        "InProgress" => "inprogress",
        "Delayed"    => "delayed",
        _            => "notstarted",
    };

    private static string StatusIcon(string s) => s switch
    {
        "Completed"  => "oi-check",
        "InProgress" => "oi-clock",
        "Delayed"    => "oi-warning",
        _            => "oi-media-record",
    };

    private static string StatusLabel(string s) => s switch
    {
        "Completed"  => "הושלם",
        "InProgress" => "בתהליך",
        "Delayed"    => "באיחור",
        _            => "טרם החל",
    };
}
