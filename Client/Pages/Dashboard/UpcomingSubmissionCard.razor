@inject NavigationManager Nav

<div class="usc-card">

    <div class="usc-header">
        <div class="usc-title-row">
            <span class="oi oi-document usc-icon" aria-hidden="true"></span>
            <h2 class="usc-card-title">הגשה קרובה</h2>
        </div>
        @if (Deadline is not null)
        {
            <span class="usc-days-badge @DaysClass()">@DaysLabel()</span>
        }
    </div>

    @if (Deadline is not null)
    {
        <div class="usc-body">
            <h3 class="usc-submission-title">@Deadline.Title</h3>
            <div class="usc-due-row">
                <span class="oi oi-calendar usc-cal-icon" aria-hidden="true"></span>
                <span class="usc-due-text">
                    תאריך הגשה:
                    <strong>@Deadline.DueDate.ToString("dd/MM/yyyy")</strong>
                </span>
            </div>
        </div>

        @if (OpenRequests.Count > 0)
        {
            <div class="usc-requests-row">
                <span class="oi oi-bell" aria-hidden="true"></span>
                <span>@OpenRequests.Count @(OpenRequests.Count == 1 ? "בקשה פתוחה" : "בקשות פתוחות")</span>
            </div>
        }

        <div class="usc-actions">
            <button class="usc-primary-btn" @onclick="OnUpload">
                <span class="oi oi-data-transfer-upload" aria-hidden="true"></span>
                העלאת קבצים
            </button>
            <button class="usc-secondary-btn" @onclick="GoToSubmissions">
                לכל ההגשות
                <span class="oi oi-chevron-left" aria-hidden="true"></span>
            </button>
            <button class="usc-request-btn" @onclick="OpenNewRequest">
                <span class="oi oi-envelope-closed" aria-hidden="true"></span>
                פתח בקשה
            </button>
        </div>
    }
    else
    {
        <div class="usc-empty">
            <span class="oi oi-circle-check usc-empty-icon" aria-hidden="true"></span>
            <p class="usc-empty-text">אין אבני דרך פתוחות עם מועד הגשה</p>
        </div>
    }

</div>

@code {
    [Parameter] public UpcomingDeadlineDto?  Deadline         { get; set; }
    [Parameter] public List<OpenRequestDto>  OpenRequests     { get; set; } = new();
    [Parameter] public EventCallback         OnOpenNewRequest { get; set; }

    private int DaysLeft() =>
        Deadline is null ? 0 : (int)(Deadline.DueDate.Date - DateTime.Today).TotalDays;

    private string DaysLabel()
    {
        int d = DaysLeft();
        if (d < 0) return "פג המועד";
        if (d == 0) return "היום!";
        if (d == 1) return "מחר";
        return $"נותרו {d} ימים";
    }

    private string DaysClass()
    {
        int d = DaysLeft();
        if (d < 0) return "usc-badge-overdue";
        if (d <= 3) return "usc-badge-urgent";
        if (d <= 7) return "usc-badge-soon";
        return "usc-badge-normal";
    }

    private void OnUpload()
    {
        if (Deadline?.TaskId is int tid)
            Nav.NavigateTo($"/submissions?taskId={tid}");
        else
            Nav.NavigateTo("/submissions");
    }

    private void GoToSubmissions() => Nav.NavigateTo("/submissions");

    private async Task OpenNewRequest() => await OnOpenNewRequest.InvokeAsync();
}
