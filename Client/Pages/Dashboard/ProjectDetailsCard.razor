@using AuthWithAdmin.Shared.AuthSharedModels
@using AuthWithAdmin.Client.Services
@inject IDashboardService DashboardService

<!-- ══════════════════════════════════════════════════════════════
     ProjectDetailsCard
     Compact dashboard card that replaces the old ProjectSummaryCard.
     Removes risk/health status and lecturer-internal metadata.
     Shows the project identity + a CTA to open the full-details modal.
     Team members and mentor contacts are shown inside the modal only.
     ══════════════════════════════════════════════════════════════ -->

<div class="pdc-card">

    <!-- ── Project header ── -->
    <div class="pdc-header">
        <div class="pdc-icon">
            <span class="oi oi-briefcase" aria-hidden="true"></span>
        </div>
        <div class="pdc-header-text">
            <div class="pdc-number-row">
                <span class="pdc-number">פרויקט @Project.ProjectNumber</span>
                <span class="pdc-type-badge">@Project.ProjectType</span>
            </div>
            <h1 class="pdc-title">@Project.Title</h1>
        </div>
    </div>

    <div class="pdc-divider"></div>

    <!-- ── Call-to-action section ── -->
    <div class="pdc-cta-section">
        <div class="pdc-cta-text-block">
            <span class="pdc-section-label">פרטי הפרויקט</span>
            <p class="pdc-cta-subtitle">כאן ניתן לצפות בפרטים המלאים של הפרויקט</p>
        </div>
        <button class="pdc-btn-primary" @onclick="OpenModal">
            לצפייה בפרטי הפרויקט
            <span class="oi oi-chevron-left pdc-btn-arrow" aria-hidden="true"></span>
        </button>
    </div>

</div>

<!-- ══════════════════════════════════════════════════════════════
     PROJECT DETAILS MODAL
     Rendered outside the card so it overlays the full viewport.
     ══════════════════════════════════════════════════════════════ -->
@if (_modalOpen)
{
    <div class="pdc-overlay" @onclick="CloseModal">
        <div class="pdc-modal" @onclick:stopPropagation="true">

            <!-- Modal header -->
            <div class="pdc-modal-header">
                <div class="pdc-modal-header-start">
                    <div class="pdc-modal-icon">
                        <span class="oi oi-briefcase" aria-hidden="true"></span>
                    </div>
                    <div>
                        <h2 class="pdc-modal-title">פרטי הפרויקט</h2>
                        <p class="pdc-modal-subtitle">פרויקט @Project.ProjectNumber – @Project.Title</p>
                    </div>
                </div>
                <button class="pdc-modal-close" @onclick="CloseModal" title="סגירה">
                    <span class="oi oi-x" aria-hidden="true"></span>
                </button>
            </div>

            <!-- Modal body -->
            <div class="pdc-modal-body">

                @if (_detailsLoading)
                {
                    <div class="pdc-loading">
                        <div class="pdc-spinner"></div>
                        <span>טוענת פרטי פרויקט…</span>
                    </div>
                }
                else if (_detailsError)
                {
                    <div class="pdc-error">
                        <span class="oi oi-warning" aria-hidden="true"></span>
                        <p>לא ניתן לטעון את פרטי הפרויקט. נסי לרענן את הדף.</p>
                    </div>
                }
                else if (_details is not null)
                {
                    <!-- ── 1. Project identity strip ── -->
                    <div class="pdc-identity-strip">
                        <span class="pdc-identity-type">@_details.ProjectType</span>
                        @if (!string.IsNullOrWhiteSpace(_details.AcademicYear))
                        {
                            <span class="pdc-identity-sep">·</span>
                            <span class="pdc-identity-year">@_details.AcademicYear</span>
                        }
                    </div>

                    <!-- ── 2. Description / need statement ── -->
                    @if (!string.IsNullOrWhiteSpace(_details.Description))
                    {
                        <div class="pdc-section">
                            <h3 class="pdc-section-title">
                                <span class="oi oi-document" aria-hidden="true"></span>
                                תיאור הפרויקט
                            </h3>
                            <p class="pdc-section-text">@_details.Description</p>
                        </div>
                    }

                    <!-- ── 3. Goals ── -->
                    @if (!string.IsNullOrWhiteSpace(_details.Goals))
                    {
                        <div class="pdc-section">
                            <h3 class="pdc-section-title">
                                <span class="oi oi-target" aria-hidden="true"></span>
                                מטרות הפרויקט
                            </h3>
                            <p class="pdc-section-text">@_details.Goals</p>
                        </div>
                    }

                    <!-- ── 4. Target audience ── -->
                    @if (!string.IsNullOrWhiteSpace(_details.TargetAudience))
                    {
                        <div class="pdc-section">
                            <h3 class="pdc-section-title">
                                <span class="oi oi-people" aria-hidden="true"></span>
                                קהל יעד
                            </h3>
                            <p class="pdc-section-text">@_details.TargetAudience</p>
                        </div>
                    }

                    <!-- ── 5. Project topic / contents (Airtable-sourced) ── -->
                    @if (!string.IsNullOrWhiteSpace(_details.ProjectTopic) ||
                         !string.IsNullOrWhiteSpace(_details.Contents))
                    {
                        <div class="pdc-section">
                            <h3 class="pdc-section-title">
                                <span class="oi oi-layers" aria-hidden="true"></span>
                                נושא ותכנים
                            </h3>
                            @if (!string.IsNullOrWhiteSpace(_details.ProjectTopic))
                            {
                                <p class="pdc-section-text">@_details.ProjectTopic</p>
                            }
                            @if (!string.IsNullOrWhiteSpace(_details.Contents))
                            {
                                <p class="pdc-section-text">@_details.Contents</p>
                            }
                        </div>
                    }

                    <!-- ── 6. Organization / client ── -->
                    @if (!string.IsNullOrWhiteSpace(_details.OrganizationName) ||
                         !string.IsNullOrWhiteSpace(_details.ContactPerson))
                    {
                        <div class="pdc-section">
                            <h3 class="pdc-section-title">
                                <span class="oi oi-home" aria-hidden="true"></span>
                                ארגון לקוח
                            </h3>
                            <div class="pdc-detail-grid">
                                @if (!string.IsNullOrWhiteSpace(_details.OrganizationName))
                                {
                                    <div class="pdc-detail-row">
                                        <span class="pdc-detail-label">שם הארגון</span>
                                        <span class="pdc-detail-value">@_details.OrganizationName</span>
                                    </div>
                                }
                                @if (!string.IsNullOrWhiteSpace(_details.OrganizationType))
                                {
                                    <div class="pdc-detail-row">
                                        <span class="pdc-detail-label">סוג ארגון</span>
                                        <span class="pdc-detail-value">@_details.OrganizationType</span>
                                    </div>
                                }
                                @if (!string.IsNullOrWhiteSpace(_details.ContactPerson))
                                {
                                    <div class="pdc-detail-row">
                                        <span class="pdc-detail-label">איש קשר</span>
                                        <span class="pdc-detail-value">
                                            @_details.ContactPerson
                                            @if (!string.IsNullOrWhiteSpace(_details.ContactRole))
                                            {
                                                <span class="pdc-contact-role"> — @_details.ContactRole</span>
                                            }
                                        </span>
                                    </div>
                                }
                                @if (!string.IsNullOrWhiteSpace(_details.ContactEmail))
                                {
                                    <div class="pdc-detail-row">
                                        <span class="pdc-detail-label">אימייל</span>
                                        <span class="pdc-detail-value" dir="ltr">@_details.ContactEmail</span>
                                    </div>
                                }
                                @if (!string.IsNullOrWhiteSpace(_details.ContactPhone))
                                {
                                    <div class="pdc-detail-row">
                                        <span class="pdc-detail-label">טלפון</span>
                                        <span class="pdc-detail-value" dir="ltr">@_details.ContactPhone</span>
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    <!-- ── 7. Team members ── -->
                    @if (TeamMembers.Count > 0)
                    {
                        <div class="pdc-section">
                            <h3 class="pdc-section-title">
                                <span class="oi oi-people" aria-hidden="true"></span>
                                חברי הצוות
                            </h3>
                            <div class="pdc-chips">
                                @foreach (var member in TeamMembers)
                                {
                                    <span class="pdc-chip" title="@member.MemberRole">@member.FullName</span>
                                }
                            </div>
                        </div>
                    }

                    <!-- ── 8. Mentors ── -->
                    @if (Mentors.Count > 0)
                    {
                        <div class="pdc-section">
                            <h3 class="pdc-section-title">
                                <span class="oi oi-person" aria-hidden="true"></span>
                                מנחים
                            </h3>
                            <div class="pdc-mentor-list">
                                @foreach (var mentor in Mentors)
                                {
                                    <div class="pdc-mentor-card">
                                        <div class="pdc-mentor-name">@mentor.FullName</div>
                                        <div class="pdc-mentor-contacts">
                                            @if (!string.IsNullOrWhiteSpace(mentor.Email))
                                            {
                                                <span class="pdc-mentor-contact">
                                                    <span class="oi oi-envelope-closed" aria-hidden="true"></span>
                                                    <span dir="ltr">@mentor.Email</span>
                                                </span>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(mentor.Phone))
                                            {
                                                <span class="pdc-mentor-contact">
                                                    <span class="oi oi-phone" aria-hidden="true"></span>
                                                    <span dir="ltr">@mentor.Phone</span>
                                                </span>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }
            </div>

            <!-- Modal footer -->
            <div class="pdc-modal-footer">
                <button class="pdc-btn-ghost" @onclick="CloseModal">סגירה</button>
            </div>

        </div>
    </div>
}

@code {
    [Parameter, EditorRequired] public ProjectInfoDto       Project     { get; set; } = default!;
    [Parameter, EditorRequired] public List<TeamMemberDto>  TeamMembers { get; set; } = default!;
    [Parameter, EditorRequired] public List<ContactDto>     Mentors     { get; set; } = default!;

    // ── Modal state ──────────────────────────────────────────────────────────
    private bool _modalOpen     = false;
    private bool _detailsLoading = false;
    private bool _detailsError  = false;

    // Cached after first fetch — no re-fetch on subsequent modal opens.
    private StudentProjectDetailsDto? _details;

    // ── Handlers ─────────────────────────────────────────────────────────────
    private async Task OpenModal()
    {
        _modalOpen = true;

        // Lazy-fetch: only call the server on the first open.
        if (_details is null && !_detailsError)
        {
            _detailsLoading = true;
            StateHasChanged();

            _details      = await DashboardService.GetMyProjectDetailsAsync();
            _detailsError = _details is null;
            _detailsLoading = false;
        }
    }

    private void CloseModal() => _modalOpen = false;
}
