@page "/dashboard"
@layout AppLayout
@using Microsoft.AspNetCore.Authorization
@using AuthWithAdmin.Shared.AuthSharedModels
@using AuthWithAdmin.Client.Services
@using AuthWithAdmin.Client.Pages.Requests
@using AuthWithAdmin.Client.Pages.Tasks
@inject IDashboardService DashboardService
@inject NavigationManager Nav
@attribute [Authorize]

<!-- New request modal (hosted at dashboard level) -->
<NewRequestModal IsOpen="@_showNewRequest"
                 OnClose="@(() => _showNewRequest = false)"
                 OnSuccess="ReloadDashboard" />

@if (_isLoading)
{
    <div class="sdash-loading">
        <div class="sdash-spinner"></div>
        <span>טוענת נתונים…</span>
    </div>
}
else if (_loadError)
{
    <div class="sdash-error">
        <span class="oi oi-warning" aria-hidden="true"></span>
        <p>אירעה שגיאה בטעינת הדשבורד. נסי לרענן את הדף.</p>
    </div>
}
else if (_data?.Project is null)
{
    <div class="sdash-empty">
        <span class="oi oi-info" aria-hidden="true"></span>
        <p>לא שויכת לפרויקט עדיין. פני למנחה שלך להשמת הצוות.</p>
    </div>
}
else
{
    <div class="student-dashboard">
        <ProjectDetailsCard Project="@_data.Project"
                            TeamMembers="@_data.TeamMembers"
                            Mentors="@_data.Mentors" />

        <ProjectProgressCard Milestones="@_data.Milestones" />

        <div class="sdash-lower">
            <ActiveTasksCard        Milestones="@_data.Milestones"
                                   OnOpenDetail="OpenDetail" />
            <UpcomingSubmissionCard Deadline="@_data.NextDeadline"
                                   OpenRequests="@_data.OpenRequests"
                                   OnOpenNewRequest="@(() => _showNewRequest = true)" />
        </div>
    </div>
}

<TaskDetailModal TaskId="@_detailTaskId"
                 OnClose="CloseDetail"
                 OnOpenSubmission="OpenSubmissionFromDetail" />

@code {
    [CascadingParameter] private User? _user { get; set; }

    private DashboardDto? _data;
    private bool _isLoading = true;
    private bool _loadError = false;
    private bool _showNewRequest;
    private int  _detailTaskId;

    protected override async Task OnInitializedAsync()
    {
        // Non-students that land on the legacy /dashboard route are bounced
        // to their dedicated dashboard. The student flow continues below.
        if (!RoleService.IsStudent(_user))
        {
            Nav.NavigateTo(RoleService.GetDefaultLandingRoute(_user), replace: true);
            return;
        }

        _data = await DashboardService.GetDashboardAsync();
        _loadError = _data is null;
        _isLoading = false;

        // Any student without an assigned project → catalog experience
        // Covers both: has team but no project, and no team at all.
        if (_data is not null && _data.Project is null)
            Nav.NavigateTo("/" + PageRoutes.StudentCatalog);
    }

    private void OpenDetail(int taskId)
    {
        _detailTaskId = taskId;
        StateHasChanged();
    }

    private void CloseDetail()               => _detailTaskId = 0;

    private void OpenSubmissionFromDetail(int taskId)
    {
        _detailTaskId = 0;
        Nav.NavigateTo("/tasks");
    }

    private async Task ReloadDashboard()
    {
        _data = await DashboardService.GetDashboardAsync();
    }
}
