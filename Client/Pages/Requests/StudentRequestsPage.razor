    /// <summary>One-line preview shown beneath the title in the inbox list.</summary>
    private static string ListItemPreview(StudentOwnRequestDto r)
    {
        // Latest comment first; falls back to resolution notes; otherwise empty.
        var latestComment = r.Events
            .Where(e => e.EventType == RequestEventTypes.Comment && !string.IsNullOrWhiteSpace(e.Content))
            .OrderByDescending(e => e.CreatedAt)
            .FirstOrDefault();

        var raw = latestComment?.Content
                  ?? r.ResolutionNotes
                  ?? "";

        raw = raw.Replace("\r", " ").Replace("\n", " ").Trim();
        if (raw.Length <= 90) return raw;
        return raw[..90] + "…";
    }

    /// <summary>Compact "now" / "X min ago" / date formatter for inbox rows.</summary>
    private static string FormatRelativeOrDate(DateTime t)
    {
        var diff = DateTime.Now - t.ToLocalTime();
        if (diff.TotalMinutes < 1)  return "כעת";
        if (diff.TotalMinutes < 60) return $"לפני {(int)diff.TotalMinutes} דק'";
        if (diff.TotalHours   < 24) return $"לפני {(int)diff.TotalHours} שע'";
        if (diff.TotalDays    < 7)  return $"לפני {(int)diff.TotalDays} ימים";
        return t.ToLocalTime().ToString("dd/MM/yyyy");
    }
