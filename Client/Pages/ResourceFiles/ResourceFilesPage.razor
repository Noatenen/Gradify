@page "/resource-files"
@page "/management/resources"
@layout AppLayout
@using AuthWithAdmin.Client.Services
@attribute [Authorize(Roles = Roles.Admin + "," + Roles.Staff)]
@inject IResourceFilesService ResourceFilesService

@if (_isLoading)
{
    <div class="rfp-loading">
        <div class="rfp-spinner"></div>
        <span>טוענת פריטים…</span>
    </div>
}
else if (_loadError)
{
    <div class="rfp-state-msg rfp-error">
        <span class="oi oi-warning" aria-hidden="true"></span>
        <p>אירעה שגיאה בטעינת הנתונים. נסה לרענן את הדף.</p>
    </div>
}
else
{
    <div class="rfp-page">

        <!-- ── Page header ── -->
        <div class="rfp-header-card">
            <div class="rfp-header-start">
                <div class="rfp-page-icon">
                    <span class="oi oi-folder" aria-hidden="true"></span>
                </div>
                <div>
                    <h1 class="rfp-page-title">קבצים וחומרי עזר</h1>
                    <p class="rfp-page-subtitle">מסמכים, סרטונים וקבצים מקוטלגים לפי אבני דרך</p>
                </div>
            </div>
            <button class="rfp-btn-primary" @onclick="ToggleCreateForm">
                <span class="oi @(IsFormVisible ? "oi-x" : "oi-plus")" aria-hidden="true"></span>
                @(IsFormVisible ? "ביטול" : "הוספת פריט")
            </button>
        </div>

        <!-- ── Unified create / edit form ── -->
        @if (IsFormVisible)
        {
            <div class="rfp-upload-card">
                <h2 class="rfp-upload-title">
                    @if (_editingFile != null)
                    {
                        <span class="oi oi-pencil" aria-hidden="true"></span>
                        <span>עריכת פריט</span>
                    }
                    else
                    {
                        <span class="oi oi-plus" aria-hidden="true"></span>
                        <span>הוספת פריט חדש</span>
                    }
                </h2>

                <!-- ── Item type toggle (only in create mode) ── -->
                @if (_editingFile == null)
                {
                    <div class="rfp-type-toggle">
                        <button class="rfp-type-tab @(_formItemType == "File" ? "rfp-type-tab--active" : "")"
                                @onclick='() => SetFormItemType("File")'>
                            <span class="oi oi-file" aria-hidden="true"></span>
                            קובץ
                        </button>
                        <button class="rfp-type-tab @(_formItemType == "Video" ? "rfp-type-tab--active" : "")"
                                @onclick='() => SetFormItemType("Video")'>
                            <span class="oi oi-media-play" aria-hidden="true"></span>
                            סרטון YouTube
                        </button>
                    </div>
                }

                <div class="rfp-form-grid">

                    @if (_formItemType == "File")
                    {
                        <!-- ── File picker ── -->
                        <div class="rfp-field rfp-field-full">
                            <label class="rfp-label">
                                קובץ
                                @if (_editingFile != null)
                                { <span class="rfp-optional">(לחץ להחלפה)</span> }
                                else
                                { <span class="rfp-required">*</span> }
                            </label>
                            <label class="rfp-file-btn @(!string.IsNullOrEmpty(_formFileOsName) ? "rfp-file-btn--selected" : "")">
                                <InputFile OnChange="HandleFileSelected"
                                           accept=".pdf,.doc,.docx,.ppt,.pptx,.xlsx,.xls,.txt,.zip,.jpg,.jpeg,.png,.gif"
                                           style="position:absolute;width:1px;height:1px;opacity:0;overflow:hidden;pointer-events:none" />
                                <span class="oi oi-data-transfer-upload rfp-file-btn-icon" aria-hidden="true"></span>
                                @if (!string.IsNullOrEmpty(_formFileOsName))
                                {
                                    <div class="rfp-file-btn-info">
                                        <span class="rfp-file-btn-name">@_formFileOsName</span>
                                        <span class="rfp-file-btn-hint">לחץ להחלפה</span>
                                    </div>
                                }
                                else if (_editingFile != null && _editingFile.ItemType == "File")
                                {
                                    <div class="rfp-file-btn-info">
                                        <span class="rfp-file-btn-name">@_editingFile.FileName</span>
                                        <span class="rfp-file-btn-hint">קובץ קיים — לחץ לבחירת חדש</span>
                                    </div>
                                }
                                else
                                {
                                    <span class="rfp-file-btn-placeholder">לחץ לבחירת קובץ להעלאה</span>
                                }
                            </label>
                        </div>
                    }
                    else
                    {
                        <!-- ── YouTube URL ── -->
                        <div class="rfp-field rfp-field-full">
                            <label class="rfp-label">קישור YouTube <span class="rfp-required">*</span></label>
                            <input class="rfp-input" type="url" @bind="_formVideoUrl"
                                   placeholder="https://www.youtube.com/watch?v=..." />
                        </div>
                    }

                    <!-- ── Display name ── -->
                    <div class="rfp-field rfp-field-full">
                        <label class="rfp-label">שם תצוגה <span class="rfp-required">*</span></label>
                        <input class="rfp-input" type="text" @bind="_formFileName"
                               placeholder="שם כפי שיוצג למשתמשים" maxlength="200" />
                    </div>

                    <!-- ── Milestone ── -->
                    <div class="rfp-field">
                        <label class="rfp-label">אבן דרך <span class="rfp-optional">(אופציונלי)</span></label>
                        <select class="rfp-select" @onchange="HandleFormMilestoneChanged">
                            <option value="0" selected="@(_formMilestoneId == 0)">— כללי (ללא אבן דרך) —</option>
                            @foreach (var ms in _milestones)
                            {
                                <option value="@ms.Id" selected="@(_formMilestoneId == ms.Id)">@ms.Title</option>
                            }
                        </select>
                    </div>

                    <!-- ── Task (optional, depends on milestone) ── -->
                    <div class="rfp-field">
                        <label class="rfp-label">משימה <span class="rfp-optional">(אופציונלי)</span></label>
                        <select class="rfp-select" @bind="_formTaskId"
                                disabled="@(_formMilestoneId == 0 || _formTaskOptions.Count == 0)">
                            <option value="0">— ללא משימה ספציפית —</option>
                            @foreach (var t in _formTaskOptions)
                            {
                                <option value="@t.Id">@t.Title</option>
                            }
                        </select>
                    </div>

                    <!-- ── Project type checkboxes ── -->
                    <div class="rfp-field rfp-field-full">
                        <label class="rfp-label">סוג פרויקט <span class="rfp-optional">(אופציונלי — ניתן לבחור שניים)</span></label>
                        <div class="rfp-checkboxes">
                            <label class="rfp-checkbox-item">
                                <input type="checkbox" @bind="_formForTech" />
                                <span>פרויקטים טכנולוגיים</span>
                            </label>
                            <label class="rfp-checkbox-item">
                                <input type="checkbox" @bind="_formForMethod" />
                                <span>פרויקטים מתודולוגיים</span>
                            </label>
                        </div>
                    </div>

                    <!-- ── Description ── -->
                    <div class="rfp-field rfp-field-full">
                        <label class="rfp-label">תיאור <span class="rfp-optional">(אופציונלי)</span></label>
                        <input class="rfp-input" type="text" @bind="_formDescription"
                               placeholder="תיאור קצר…" maxlength="300" />
                    </div>

                </div>

                @if (!string.IsNullOrEmpty(_formError))
                {
                    <div class="rfp-form-error">
                        <span class="oi oi-warning" aria-hidden="true"></span>
                        @_formError
                    </div>
                }

                <div class="rfp-form-actions">
                    <button class="rfp-btn-ghost" @onclick="CloseForm" disabled="@_saving">ביטול</button>
                    <button class="rfp-btn-primary" @onclick="SubmitForm" disabled="@_saving">
                        @if (_saving)
                        {
                            <span class="rfp-spinner-sm"></span>
                            <span>שומר…</span>
                        }
                        else if (_editingFile != null)
                        {
                            <span class="oi oi-check" aria-hidden="true"></span>
                            <span>שמור שינויים</span>
                        }
                        else if (_formItemType == "Video")
                        {
                            <span class="oi oi-media-play" aria-hidden="true"></span>
                            <span>הוספת סרטון</span>
                        }
                        else
                        {
                            <span class="oi oi-cloud-upload" aria-hidden="true"></span>
                            <span>העלאה</span>
                        }
                    </button>
                </div>
            </div>
        }

        <!-- ── Grouped item list ── -->
        @if (_files.Count == 0)
        {
            <div class="rfp-empty">
                <span class="oi oi-folder" aria-hidden="true"></span>
                <p>לא נוספו פריטים עדיין. לחץ על "הוספת פריט" כדי להתחיל.</p>
            </div>
        }
        else
        {
            @foreach (var group in GetGroups())
            {
                bool isOpen = _openGroups.Contains(group.Key);
                <div class="rfp-accordion @(isOpen ? "rfp-accordion--open" : "")">

                    <button class="rfp-accordion-head" @onclick="() => ToggleGroup(group.Key)">
                        <span class="rfp-accordion-chevron oi @(isOpen ? "oi-chevron-bottom" : "oi-chevron-left")" aria-hidden="true"></span>
                        <span class="rfp-accordion-title">@GroupTitle(group.Key)</span>
                        <span class="rfp-accordion-count">@group.Value.Count פריטים</span>
                    </button>

                    @if (isOpen)
                    {
                        <div class="rfp-accordion-body">
                            <table class="rfp-table">
                                <thead>
                                    <tr>
                                        <th>שם</th>
                                        <th>סוג</th>
                                        <th>תיאור</th>
                                        <th>סוג פרויקט</th>
                                        <th>משימה</th>
                                        <th>תאריך</th>
                                        <th>פעולות</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var file in group.Value)
                                    {
                                        bool isDeleting    = _confirmDeleteId == file.Id;
                                        bool isActiveEdit  = _editingFile?.Id == file.Id;
                                        bool isVideo       = file.ItemType == "Video";
                                        <tr class="@(isDeleting ? "rfp-row-deleting" : "") @(isActiveEdit ? "rfp-row-editing" : "")">
                                            <td>
                                                <div class="rfp-file-cell">
                                                    <span class="rfp-file-icon oi @(isVideo ? "oi-media-play" : FileIcon(file.ContentType))" aria-hidden="true"></span>
                                                    <span class="rfp-file-label">@file.FileName</span>
                                                </div>
                                            </td>
                                            <td>
                                                @if (isVideo)
                                                { <span class="rfp-item-type-badge rfp-item-type-badge--video">סרטון</span> }
                                                else
                                                { <span class="rfp-item-type-badge rfp-item-type-badge--file">קובץ</span> }
                                            </td>
                                            <td class="rfp-desc-cell">
                                                @if (!string.IsNullOrWhiteSpace(file.Description))
                                                { <span>@file.Description</span> }
                                                else
                                                { <span class="rfp-no-value">—</span> }
                                            </td>
                                            <td>
                                                <div class="rfp-type-badges">
                                                    @if (file.ForTechnological)
                                                    { <span class="rfp-type-badge rfp-type-badge--tech">טכנולוגי</span> }
                                                    @if (file.ForMethodological)
                                                    { <span class="rfp-type-badge rfp-type-badge--method">מתודולוגי</span> }
                                                    @if (!file.ForTechnological && !file.ForMethodological)
                                                    { <span class="rfp-no-value">—</span> }
                                                </div>
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrWhiteSpace(file.TaskName))
                                                { <span class="rfp-task-badge">@file.TaskName</span> }
                                                else
                                                { <span class="rfp-no-value">—</span> }
                                            </td>
                                            <td class="rfp-date-cell">@file.UploadedAt.ToString("dd/MM/yy")</td>
                                            <td>
                                                <div class="rfp-actions">
                                                    @if (isDeleting)
                                                    {
                                                        <button class="rfp-action-btn rfp-action-confirm"
                                                                @onclick="() => ConfirmDelete(file.Id)"
                                                                title="אישור מחיקה">
                                                            <span class="oi oi-check" aria-hidden="true"></span>
                                                        </button>
                                                        <button class="rfp-action-btn rfp-action-cancel-del"
                                                                @onclick="CancelDelete"
                                                                title="ביטול">
                                                            <span class="oi oi-x" aria-hidden="true"></span>
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        @if (isVideo)
                                                        {
                                                            <a class="rfp-action-btn rfp-action-download"
                                                               href="@file.VideoUrl"
                                                               target="_blank"
                                                               rel="noopener noreferrer"
                                                               title="פתח בYouTube">
                                                                <span class="oi oi-external-link" aria-hidden="true"></span>
                                                            </a>
                                                        }
                                                        else
                                                        {
                                                            <a class="rfp-action-btn rfp-action-download"
                                                               href="/resources/@file.StoredFileName"
                                                               download="@file.FileName"
                                                               title="הורדה">
                                                                <span class="oi oi-cloud-download" aria-hidden="true"></span>
                                                            </a>
                                                        }
                                                        <button class="rfp-action-btn rfp-action-edit"
                                                                @onclick="() => StartEdit(file)"
                                                                title="עריכה">
                                                            <span class="oi oi-pencil" aria-hidden="true"></span>
                                                        </button>
                                                        <button class="rfp-action-btn rfp-action-delete"
                                                                @onclick="() => RequestDelete(file.Id)"
                                                                title="מחיקה">
                                                            <span class="oi oi-trash" aria-hidden="true"></span>
                                                        </button>
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            }
        }

    </div>
}

@code {
    // ── Page state ───────────────────────────────────────────────────────────
    private List<ResourceFileDto>    _files      = new();
    private List<MilestoneOptionDto> _milestones = new();

    private bool _isLoading = true;
    private bool _loadError;

    // ── Form state (shared by create and edit) ───────────────────────────────
    private bool             _showForm    = false;
    private ResourceFileDto? _editingFile = null;
    private bool IsFormVisible => _showForm || _editingFile != null;

    private string              _formItemType    = "File";
    private string              _formFileName    = "";
    private string              _formDescription = "";
    private int                 _formMilestoneId = 0;
    private int                 _formTaskId      = 0;
    private bool                _formForTech     = false;
    private bool                _formForMethod   = false;
    private List<TaskOptionDto> _formTaskOptions = new();

    // File-specific
    private string? _formFileBase64  = null;
    private string  _formFileOsName  = "";
    private string  _formContentType = "";

    // Video-specific
    private string _formVideoUrl = "";

    private string _formError = "";
    private bool   _saving    = false;

    // ── Accordion state ──────────────────────────────────────────────────────
    private HashSet<int> _openGroups = new();

    // ── Delete confirmation ──────────────────────────────────────────────────
    private int _confirmDeleteId;

    // ── Lifecycle ────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        var filesTask = ResourceFilesService.GetAllAsync();
        var msTask    = ResourceFilesService.GetMilestonesAsync();
        await Task.WhenAll(filesTask, msTask);

        var files = await filesTask;
        _loadError  = files is null;
        _files      = files ?? new();
        _milestones = await msTask;

        _openGroups = _files.Select(f => f.MilestoneId).Distinct().ToHashSet();
        _isLoading  = false;
    }

    // ── Form open/close ──────────────────────────────────────────────────────
    private void ToggleCreateForm()
    {
        if (IsFormVisible) CloseForm();
        else
        {
            _showForm    = true;
            _editingFile = null;
            ResetForm();
        }
    }

    private void SetFormItemType(string type)
    {
        _formItemType   = type;
        _formFileBase64 = null;
        _formFileOsName = "";
        _formVideoUrl   = "";
        _formError      = "";
    }

    private async Task StartEdit(ResourceFileDto file)
    {
        _editingFile = file;
        _showForm    = false;
        _confirmDeleteId = 0;

        _formItemType    = file.ItemType;
        _formFileName    = file.FileName;
        _formDescription = file.Description ?? "";
        _formMilestoneId = file.MilestoneId;
        _formTaskId      = file.TaskId ?? 0;
        _formForTech     = file.ForTechnological;
        _formForMethod   = file.ForMethodological;
        _formFileBase64  = null;
        _formFileOsName  = "";
        _formContentType = "";
        _formVideoUrl    = file.VideoUrl ?? "";
        _formError       = "";

        _formTaskOptions = _formMilestoneId > 0
            ? await ResourceFilesService.GetTasksForMilestoneAsync(_formMilestoneId)
            : new();
    }

    private void CloseForm()
    {
        _showForm    = false;
        _editingFile = null;
        ResetForm();
    }

    private void ResetForm()
    {
        _formItemType    = "File";
        _formFileName    = "";
        _formDescription = "";
        _formMilestoneId = 0;
        _formTaskId      = 0;
        _formForTech     = false;
        _formForMethod   = false;
        _formFileBase64  = null;
        _formFileOsName  = "";
        _formContentType = "";
        _formVideoUrl    = "";
        _formTaskOptions = new();
        _formError       = "";
    }

    // ── Form interactions ────────────────────────────────────────────────────
    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        _formError = "";
        var file = e.File;

        if (file.Size > 10 * 1024 * 1024)
        {
            _formError = "גודל הקובץ עולה על 10MB";
            return;
        }

        _formFileOsName  = file.Name;
        _formContentType = string.IsNullOrWhiteSpace(file.ContentType)
            ? "application/octet-stream"
            : file.ContentType;

        if (string.IsNullOrWhiteSpace(_formFileName))
            _formFileName = file.Name;

        using var ms = new MemoryStream();
        await file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024).CopyToAsync(ms);
        _formFileBase64 = Convert.ToBase64String(ms.ToArray());
    }

    private async Task HandleFormMilestoneChanged(ChangeEventArgs e)
    {
        _formMilestoneId = int.TryParse(e.Value?.ToString(), out int id) ? id : 0;
        _formTaskId      = 0;
        _formTaskOptions = _formMilestoneId > 0
            ? await ResourceFilesService.GetTasksForMilestoneAsync(_formMilestoneId)
            : new();
    }

    private async Task SubmitForm()
    {
        _formError = "";

        if (string.IsNullOrWhiteSpace(_formFileName))
        { _formError = "יש להזין שם תצוגה"; return; }

        if (_formItemType == "Video")
        {
            if (string.IsNullOrWhiteSpace(_formVideoUrl))
            { _formError = "יש להזין קישור YouTube"; return; }
        }
        else
        {
            if (_editingFile == null && string.IsNullOrEmpty(_formFileBase64))
            { _formError = "יש לבחור קובץ להעלאה"; return; }
        }

        _saving = true;

        bool   ok;
        string? uploadError = null;

        if (_editingFile != null)
        {
            ok = await ResourceFilesService.UpdateAsync(_editingFile.Id, new UpdateResourceFileRequest
            {
                ItemType          = _formItemType,
                FileName          = _formFileName.Trim(),
                Description       = NullIfBlank(_formDescription),
                MilestoneId       = _formMilestoneId,
                TaskId            = _formTaskId > 0 ? _formTaskId : null,
                ForTechnological  = _formForTech,
                ForMethodological = _formForMethod,
                FileBase64        = _formFileBase64,
                ContentType       = _formContentType,
                VideoUrl          = _formItemType == "Video" ? _formVideoUrl.Trim() : null,
            });
        }
        else
        {
            uploadError = await ResourceFilesService.UploadAsync(new UploadResourceFileRequest
            {
                ItemType          = _formItemType,
                FileName          = _formFileName.Trim(),
                FileBase64        = _formFileBase64 ?? "",
                ContentType       = _formContentType,
                MilestoneId       = _formMilestoneId,
                TaskId            = _formTaskId > 0 ? _formTaskId : null,
                Description       = NullIfBlank(_formDescription),
                ForTechnological  = _formForTech,
                ForMethodological = _formForMethod,
                VideoUrl          = _formItemType == "Video" ? _formVideoUrl.Trim() : null,
            });
            ok = uploadError is null;
        }

        _saving = false;

        if (!ok) { _formError = uploadError ?? "שגיאה בשמירה. נסה שנית."; return; }

        CloseForm();
        var files = await ResourceFilesService.GetAllAsync();
        _files = files ?? _files;
        foreach (var f in _files) _openGroups.Add(f.MilestoneId);
    }

    // ── Delete ───────────────────────────────────────────────────────────────
    private void RequestDelete(int id)   => _confirmDeleteId = id;
    private void CancelDelete()          => _confirmDeleteId = 0;

    private async Task ConfirmDelete(int id)
    {
        _confirmDeleteId = 0;
        await ResourceFilesService.DeleteAsync(id);
        _files.RemoveAll(f => f.Id == id);
        if (_editingFile?.Id == id) CloseForm();
    }

    // ── Grouping ─────────────────────────────────────────────────────────────
    private IEnumerable<KeyValuePair<int, List<ResourceFileDto>>> GetGroups()
    {
        foreach (var ms in _milestones)
        {
            var group = _files.Where(f => f.MilestoneId == ms.Id).ToList();
            if (group.Count > 0) yield return new(ms.Id, group);
        }
        var general = _files.Where(f => f.MilestoneId == 0).ToList();
        if (general.Count > 0) yield return new(0, general);
    }

    private string GroupTitle(int milestoneId)
    {
        if (milestoneId == 0) return "כללי";
        return _milestones.FirstOrDefault(m => m.Id == milestoneId)?.Title ?? "אחר";
    }

    private void ToggleGroup(int milestoneId)
    {
        if (!_openGroups.Add(milestoneId)) _openGroups.Remove(milestoneId);
    }

    // ── Helpers ──────────────────────────────────────────────────────────────
    private static string? NullIfBlank(string s) =>
        string.IsNullOrWhiteSpace(s) ? null : s.Trim();

    private static string FileIcon(string contentType) => contentType switch
    {
        var ct when ct.StartsWith("image/")                             => "oi-image",
        "application/pdf"                                               => "oi-document",
        "application/zip" or "application/x-zip-compressed"            => "oi-data-transfer-download",
        var ct when ct.Contains("spreadsheet") || ct.Contains("excel") => "oi-spreadsheet",
        var ct when ct.Contains("presentation")                        => "oi-monitor",
        _                                                               => "oi-file",
    };
}
