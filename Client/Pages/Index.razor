@page "/"
@layout BlankLayout
@inject NavigationManager Nav
@inject IAuthenticationService _Auth

@code {
    protected override async Task OnInitializedAsync()
    {
        var user = await _Auth.GetUserFromClaimAsync();
        if (user != null)
            Nav.NavigateTo(PageRoutes.Dashboard, forceLoad: true, replace: true);
        else
            Nav.NavigateTo(PageRoutes.Login, forceLoad: true, replace: true);
    }
}
