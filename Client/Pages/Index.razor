@page "/"
@layout BlankLayout
@inject NavigationManager Nav
@inject IAuthenticationService _Auth
@using AuthWithAdmin.Client.Services

@code {
    protected override async Task OnInitializedAsync()
    {
        var user = await _Auth.GetUserFromClaimAsync();
        if (user != null)
            // Role-aware default landing — staff → lecturer dashboard,
            // mentor → mentor dashboard, students → legacy /dashboard.
            Nav.NavigateTo(RoleService.GetDefaultLandingRoute(user), forceLoad: true, replace: true);
        else
            Nav.NavigateTo(PageRoutes.Login, forceLoad: true, replace: true);
    }
}
