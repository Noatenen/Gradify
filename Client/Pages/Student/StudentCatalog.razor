@page "/student/catalog"
@layout AppLayout
@using AuthWithAdmin.Shared.AuthSharedModels
@using Microsoft.AspNetCore.Authorization
@inject HttpClient Http
@inject NavigationManager Nav
@attribute [Authorize(Roles = Roles.Student)]

<!-- ══ Project details modal ═══════════════════════════════════════════════ -->
@if (_modalProject is not null)
{
    <div class="sc-modal-backdrop" @onclick="CloseModal"></div>
    <div class="sc-modal" dir="rtl" role="dialog" aria-modal="true">

        <!-- Modal header -->
        <div class="sc-modal-head">
            <div class="sc-modal-head-meta">
                <span class="sc-modal-num">#@_modalProject.ProjectNumber</span>
                <span class="sc-type-badge">@_modalProject.ProjectType</span>
                @if (!string.IsNullOrWhiteSpace(_modalProject.ProjectTopic))
                {
                    <span class="sc-topic-badge">@_modalProject.ProjectTopic</span>
                }
                @if (_modalProject.Availability == "Taken")
                {
                    <span class="sc-avail-badge sc-avail-badge--taken">תפוס</span>
                }
                else
                {
                    <span class="sc-avail-badge sc-avail-badge--free">פנוי</span>
                }
            </div>
            <div class="sc-modal-head-actions">
                <button class="sc-modal-fav @(_favoriteIds.Contains(_modalProject.Id) ? "sc-modal-fav--active" : "")"
                        @onclick="() => ToggleFavorite(_modalProject)"
                        @onclick:stopPropagation="true"
                        title="@(_favoriteIds.Contains(_modalProject.Id) ? "הסר ממועדפים" : "הוסף למועדפים")">
                    @(_favoriteIds.Contains(_modalProject.Id) ? "★" : "☆")
                </button>
                <button class="sc-modal-close" @onclick="CloseModal" title="סגירה">
                    <span class="oi oi-x" aria-hidden="true"></span>
                </button>
            </div>
        </div>

        <h2 class="sc-modal-title">@_modalProject.Title</h2>

        <!-- Scrollable body -->
        <div class="sc-modal-body">

            <!-- פרטי הפרויקט -->
            @if (!string.IsNullOrWhiteSpace(_modalProject.Description))
            {
                <div class="sc-modal-section">
                    <h3 class="sc-modal-section-title">תיאור הפרויקט</h3>
                    <p class="sc-modal-text">@_modalProject.Description</p>
                </div>
            }

            <!-- תוכן / היקף -->
            @if (!string.IsNullOrWhiteSpace(_modalProject.Contents))
            {
                <div class="sc-modal-section">
                    <h3 class="sc-modal-section-title">תוכן הפרויקט</h3>
                    <p class="sc-modal-text">@_modalProject.Contents</p>
                </div>
            }

            <!-- מטרות -->
            @if (!string.IsNullOrWhiteSpace(_modalProject.Goals))
            {
                <div class="sc-modal-section">
                    <h3 class="sc-modal-section-title">מטרות</h3>
                    <p class="sc-modal-text">@_modalProject.Goals</p>
                </div>
            }

            <!-- קהל יעד -->
            @if (!string.IsNullOrWhiteSpace(_modalProject.TargetAudience))
            {
                <div class="sc-modal-section">
                    <h3 class="sc-modal-section-title">קהל יעד</h3>
                    <p class="sc-modal-text">@_modalProject.TargetAudience</p>
                </div>
            }

            <!-- ארגון ואיש קשר -->
            @{
                bool hasOrg     = !string.IsNullOrWhiteSpace(_modalProject.OrganizationName);
                bool hasContact = !string.IsNullOrWhiteSpace(_modalProject.ContactPerson);
                bool hasMentors = !string.IsNullOrWhiteSpace(_modalProject.Mentors);
            }
            @if (hasOrg || hasContact || hasMentors)
            {
                <div class="sc-modal-section">
                    <h3 class="sc-modal-section-title">ארגון ואיש קשר</h3>
                    <div class="sc-modal-info-grid">
                        @if (hasOrg)
                        {
                            <div class="sc-modal-info-row">
                                <span class="sc-modal-info-label">ארגון</span>
                                <span class="sc-modal-info-val">
                                    @_modalProject.OrganizationName
                                    @if (!string.IsNullOrWhiteSpace(_modalProject.OrganizationType))
                                    {
                                        <span class="sc-modal-info-sub">(@_modalProject.OrganizationType)</span>
                                    }
                                </span>
                            </div>
                        }
                        @if (hasContact)
                        {
                            <div class="sc-modal-info-row">
                                <span class="sc-modal-info-label">איש קשר</span>
                                <span class="sc-modal-info-val">
                                    @_modalProject.ContactPerson
                                    @if (!string.IsNullOrWhiteSpace(_modalProject.ContactRole))
                                    {
                                        <span class="sc-modal-info-sub">— @_modalProject.ContactRole</span>
                                    }
                                </span>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(_modalProject.ContactEmail))
                        {
                            <div class="sc-modal-info-row">
                                <span class="sc-modal-info-label">אימייל</span>
                                <a class="sc-modal-info-val sc-modal-link"
                                   href="mailto:@_modalProject.ContactEmail">
                                    @_modalProject.ContactEmail
                                </a>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(_modalProject.ContactPhone))
                        {
                            <div class="sc-modal-info-row">
                                <span class="sc-modal-info-label">טלפון</span>
                                <span class="sc-modal-info-val">@_modalProject.ContactPhone</span>
                            </div>
                        }
                        @if (hasMentors)
                        {
                            <div class="sc-modal-info-row">
                                <span class="sc-modal-info-label">מנחים</span>
                                <span class="sc-modal-info-val">@_modalProject.Mentors</span>
                            </div>
                        }
                    </div>
                </div>
            }

        </div>

        <!-- Modal footer -->
        <div class="sc-modal-footer">
            <button class="sc-modal-fav-btn @(_favoriteIds.Contains(_modalProject.Id) ? "sc-modal-fav-btn--active" : "")"
                    @onclick="() => ToggleFavorite(_modalProject)">
                @(_favoriteIds.Contains(_modalProject.Id) ? "★ במועדפים" : "☆ הוסף למועדפים")
            </button>
            <button class="sc-modal-close-btn" @onclick="CloseModal">סגירה</button>
        </div>
    </div>
}

<!-- ══ Page ═════════════════════════════════════════════════════════════════ -->
<div class="sc-page">

    <!-- ══ Top bar ══════════════════════════════════════════════════════════ -->
    <div class="sc-topbar">
        <div class="sc-topbar-text">
            <h1 class="sc-page-title">קטלוג פרויקטים</h1>
            <p class="sc-page-sub">עיינו בפרויקטים הזמינים, סמנו מועדפים, ולאחר מכן הגישו טופס שיבוץ</p>
        </div>
        <a class="sc-assignment-btn" href="/@PageRoutes.StudentAssignment">
            <span>לבחירת שיבוצים</span>
            <span class="sc-arrow">←</span>
        </a>
    </div>

    <!-- ══ Search / filter bar ══════════════════════════════════════════════ -->
    <div class="sc-toolbar">
        <div class="sc-search-wrap">
            <span class="sc-search-icon">🔍</span>
            <input class="sc-search-input"
                   type="text"
                   placeholder="חיפוש לפי שם, תיאור, סוג, ארגון…"
                   @bind="_search"
                   @bind:event="oninput" />
        </div>
        <div class="sc-filter-wrap">
            <label class="sc-filter-label">סוג:</label>
            <select class="sc-filter-select" @bind="_typeFilter">
                <option value="">הכל</option>
                @foreach (var t in _projectTypes)
                {
                    <option value="@t">@t</option>
                }
            </select>
        </div>
        <button class="sc-fav-toggle @(_showFavoritesOnly ? "sc-fav-toggle--active" : "")"
                @onclick="ToggleFavoritesFilter"
                title="@(_showFavoritesOnly ? "הצג הכל" : "המועדפים שלי")">
            <span class="sc-star-icon" aria-hidden="true">★</span>
            @(_showFavoritesOnly ? "הכל" : "המועדפים שלי")
            @if (_favoriteCount > 0)
            {
                <span class="sc-fav-count">@_favoriteCount</span>
            }
        </button>
        <div class="sc-count-badge">@_filtered.Count פרויקטים</div>
    </div>

    <!-- ══ Content ══════════════════════════════════════════════════════════ -->
    @if (_loading)
    {
        <div class="sc-state-box">
            <div class="sc-spinner"></div>
            <span>טוענת פרויקטים…</span>
        </div>
    }
    else if (_loadError)
    {
        <div class="sc-state-box sc-state-box--error">
            <span>⚠</span>
            <span>שגיאה בטעינת הקטלוג. נסי לרענן את הדף.</span>
        </div>
    }
    else if (!_projects.Any())
    {
        <div class="sc-state-box">
            <span class="sc-empty-icon">📂</span>
            <span>לא נמצאו פרויקטים זמינים כרגע</span>
        </div>
    }
    else if (_filtered.Count == 0)
    {
        <div class="sc-state-box">
            <span class="sc-empty-icon">@(_showFavoritesOnly ? "★" : "🔍")</span>
            <span>
                @if (_showFavoritesOnly)
                { <span>טרם סימנת פרויקטים כמועדפים</span> }
                else
                { <span>לא נמצאו פרויקטים התואמים את החיפוש</span> }
            </span>
        </div>
    }
    else
    {
        <div class="sc-grid">
            @foreach (var p in _filtered)
            {
                bool isFav = _favoriteIds.Contains(p.Id);

                <div class="sc-card" @onclick="() => OpenModal(p)">

                    <!-- Card head: number · type · availability · star -->
                    <div class="sc-card-head">
                        <span class="sc-card-num">#@p.ProjectNumber</span>
                        <span class="sc-type-badge">@p.ProjectType</span>
                        @if (p.Availability == "Taken")
                        {
                            <span class="sc-avail-badge sc-avail-badge--taken">תפוס</span>
                        }
                        else
                        {
                            <span class="sc-avail-badge sc-avail-badge--free">פנוי</span>
                        }
                        <button class="sc-fav-btn @(isFav ? "sc-fav-btn--active" : "")"
                                @onclick:stopPropagation="true"
                                @onclick="() => ToggleFavorite(p)"
                                title="@(isFav ? "הסר ממועדפים" : "הוסף למועדפים")"
                                aria-label="@(isFav ? "הסר ממועדפים" : "הוסף למועדפים")">
                            @(isFav ? "★" : "☆")
                        </button>
                    </div>

                    <!-- Title -->
                    <h3 class="sc-card-title">@p.Title</h3>

                    <!-- Short description (distinct from full description shown in modal) -->
                    @if (!string.IsNullOrWhiteSpace(p.Description))
                    {
                        <p class="sc-card-desc">@Truncate(p.Description, 100)</p>
                    }

                    <!-- Quick org info if available -->
                    @if (!string.IsNullOrWhiteSpace(p.OrganizationName))
                    {
                        <div class="sc-card-org">
                            <span class="oi oi-building" aria-hidden="true"></span>
                            @p.OrganizationName
                        </div>
                    }

                    <div class="sc-card-footer">
                        <span class="sc-card-open-hint">לחץ לפרטים נוספים</span>
                    </div>

                </div>
            }
        </div>
    }

</div>

@code {

    private List<StudentCatalogProjectDto> _projects     = new();
    private readonly HashSet<int>          _favoriteIds  = new();
    private StudentCatalogProjectDto?      _modalProject = null;
    private bool   _loading           = true;
    private bool   _loadError         = false;
    private string _search            = "";
    private string _typeFilter        = "";
    private bool   _showFavoritesOnly = false;

    private List<string> _projectTypes => _projects
        .Select(p => p.ProjectType)
        .Distinct()
        .OrderBy(t => t)
        .ToList();

    private int _favoriteCount => _favoriteIds.Count;

    private List<StudentCatalogProjectDto> _filtered => _projects
        .Where(p =>
            (!_showFavoritesOnly || _favoriteIds.Contains(p.Id)) &&
            (string.IsNullOrWhiteSpace(_search) ||
             p.Title.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
             (p.Description ?? "").Contains(_search, StringComparison.OrdinalIgnoreCase) ||
             p.ProjectType.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
             (p.OrganizationName ?? "").Contains(_search, StringComparison.OrdinalIgnoreCase) ||
             (p.ProjectTopic ?? "").Contains(_search, StringComparison.OrdinalIgnoreCase)) &&
            (string.IsNullOrWhiteSpace(_typeFilter) || p.ProjectType == _typeFilter))
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var result = await Http.GetFromJsonAsync<List<StudentCatalogProjectDto>>("api/student/catalog");
            _projects = result ?? new();
            foreach (var p in _projects.Where(p => p.IsFavorite))
                _favoriteIds.Add(p.Id);
        }
        catch
        {
            _loadError = true;
        }
        finally
        {
            _loading = false;
        }
    }

    private void OpenModal(StudentCatalogProjectDto project) => _modalProject = project;
    private void CloseModal()                                  => _modalProject = null;

    private void ToggleFavoritesFilter() => _showFavoritesOnly = !_showFavoritesOnly;

    private async Task ToggleFavorite(StudentCatalogProjectDto project)
    {
        bool wasFavorite = _favoriteIds.Contains(project.Id);
        if (wasFavorite)
            _favoriteIds.Remove(project.Id);
        else
            _favoriteIds.Add(project.Id);

        try
        {
            if (wasFavorite)
                await Http.DeleteAsync($"api/student/favorites/{project.Id}");
            else
                await Http.PostAsync($"api/student/favorites/{project.Id}", null);
        }
        catch
        {
            if (wasFavorite) _favoriteIds.Add(project.Id);
            else             _favoriteIds.Remove(project.Id);
        }
    }

    private static string Truncate(string text, int max)
    {
        if (string.IsNullOrEmpty(text) || text.Length <= max) return text;
        return text[..max] + "…";
    }
}
