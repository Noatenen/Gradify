@page "/learning"
@layout AppLayout
@using Microsoft.AspNetCore.Authorization
@using AuthWithAdmin.Shared.AuthSharedModels
@using AuthWithAdmin.Client.Services
@inject ILearningMaterialsService LearningMaterialsService
@attribute [Authorize]

@if (_isLoading)
{
    <div class="lm-loading">
        <div class="lm-spinner"></div>
        <span>טוענת חומרי למידה…</span>
    </div>
}
else if (_loadError)
{
    <div class="lm-state-msg lm-state-error">
        <span class="oi oi-warning" aria-hidden="true"></span>
        <p>אירעה שגיאה בטעינת חומרי הלמידה. נסי לרענן את הדף.</p>
    </div>
}
else
{
    <div class="lm-page">

        <!-- ── Page header ── -->
        <div class="lm-header-card">
            <div class="lm-header-start">
                <div class="lm-page-icon">
                    <span class="oi oi-book" aria-hidden="true"></span>
                </div>
                <div>
                    <h1 class="lm-page-title">חומרי עזר</h1>
                    <p class="lm-page-subtitle">סרטונים, קבצים וקישורים הרלוונטיים לפרויקט שלך</p>
                </div>
            </div>
        </div>

        @if (_videos.Count == 0 && _files.Count == 0 && _links.Count == 0)
        {
            <!-- ── Global empty state ── -->
            <div class="lm-empty">
                <span class="oi oi-book" aria-hidden="true"></span>
                <p>אין עדיין חומרי עזר זמינים</p>
            </div>
        }
        else
        {
            <!-- ══════════════════════════════════════
                 VIDEOS SECTION
                 ══════════════════════════════════════ -->
            @if (_videos.Count > 0)
            {
                <div class="lm-section">
                    <div class="lm-section-header">
                        <span class="oi oi-media-play lm-section-icon" aria-hidden="true"></span>
                        <span class="lm-section-title">סרטונים</span>
                        <span class="lm-section-count">@_videos.Count</span>
                    </div>
                    <div class="lm-video-grid">
                        @foreach (var item in _videos)
                        {
                            string? embedUrl = GetEmbedUrl(item.Url);
                            <div class="lm-video-card">
                                <div class="lm-video-card-body">
                                    <div class="lm-video-title-row">
                                        <span class="oi oi-media-play lm-video-play-icon" aria-hidden="true"></span>
                                        <span class="lm-video-title">@item.Title</span>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(item.Description))
                                    {
                                        <p class="lm-video-desc">@item.Description</p>
                                    }
                                    @if (embedUrl is not null)
                                    {
                                        <div class="lm-video-embed-wrap">
                                            <iframe class="lm-video-embed"
                                                    src="@embedUrl"
                                                    title="@item.Title"
                                                    allowfullscreen
                                                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture">
                                            </iframe>
                                        </div>
                                    }
                                    else if (!string.IsNullOrWhiteSpace(item.Url))
                                    {
                                        <a class="lm-video-link"
                                           href="@item.Url"
                                           target="_blank"
                                           rel="noopener noreferrer">
                                            <span class="oi oi-external-link" aria-hidden="true"></span>
                                            צפייה בסרטון
                                        </a>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- ══════════════════════════════════════
                 FILES SECTION
                 ══════════════════════════════════════ -->
            @if (_files.Count > 0)
            {
                <div class="lm-section">
                    <div class="lm-section-header">
                        <span class="oi oi-file lm-section-icon" aria-hidden="true"></span>
                        <span class="lm-section-title">קבצים</span>
                        <span class="lm-section-count">@_files.Count</span>
                    </div>
                    <div class="lm-card">
                        <ul class="lm-file-list">
                            @foreach (var item in _files)
                            {
                                <li class="lm-file-item">
                                    <div class="lm-file-icon-wrap">
                                        <span class="oi oi-file" aria-hidden="true"></span>
                                    </div>
                                    <div class="lm-file-info">
                                        <span class="lm-file-name">@(item.FileName ?? item.Title)</span>
                                        @if (!string.IsNullOrWhiteSpace(item.Description))
                                        {
                                            <span class="lm-file-desc">@item.Description</span>
                                        }
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(item.Url))
                                    {
                                        <a class="lm-file-btn"
                                           href="@item.Url"
                                           target="_blank"
                                           rel="noopener noreferrer"
                                           download="@item.FileName">
                                            <span class="oi oi-cloud-download" aria-hidden="true"></span>
                                            הורדה / פתיחה
                                        </a>
                                    }
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            }

            <!-- ══════════════════════════════════════
                 LINKS SECTION
                 ══════════════════════════════════════ -->
            @if (_links.Count > 0)
            {
                <div class="lm-section">
                    <div class="lm-section-header">
                        <span class="oi oi-link-intact lm-section-icon" aria-hidden="true"></span>
                        <span class="lm-section-title">קישורים</span>
                        <span class="lm-section-count">@_links.Count</span>
                    </div>
                    <div class="lm-card">
                        <ul class="lm-link-list">
                            @foreach (var item in _links)
                            {
                                <li class="lm-link-item">
                                    <div class="lm-link-icon-wrap">
                                        <span class="oi oi-link-intact" aria-hidden="true"></span>
                                    </div>
                                    <div class="lm-link-info">
                                        <span class="lm-link-title">@item.Title</span>
                                        @if (!string.IsNullOrWhiteSpace(item.Description))
                                        {
                                            <span class="lm-link-desc">@item.Description</span>
                                        }
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(item.Url))
                                    {
                                        <a class="lm-link-btn"
                                           href="@item.Url"
                                           target="_blank"
                                           rel="noopener noreferrer">
                                            <span class="oi oi-external-link" aria-hidden="true"></span>
                                            פתיחת קישור
                                        </a>
                                    }
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            }
        }

    </div>
}

@code {

    private bool _isLoading = true;
    private bool _loadError = false;

    private List<LearningMaterialDto> _videos = new();
    private List<LearningMaterialDto> _files  = new();
    private List<LearningMaterialDto> _links  = new();

    protected override async Task OnInitializedAsync()
    {
        var all = await LearningMaterialsService.GetMyMaterialsAsync();

        _loadError = all is null;

        if (all is not null)
        {
            _videos = all.Where(m => m.MaterialType == LearningMaterialType.Video).ToList();
            _files  = all.Where(m => m.MaterialType == LearningMaterialType.File).ToList();
            _links  = all.Where(m => m.MaterialType == LearningMaterialType.Link).ToList();
        }

        _isLoading = false;
    }

    // ── YouTube embed URL helper ─────────────────────────────────────────────
    // Converts a watch URL or short URL to the embeddable iframe src.
    // Returns null for non-YouTube URLs (caller falls back to external link).
    private static string? GetEmbedUrl(string? url)
    {
        if (string.IsNullOrWhiteSpace(url)) return null;

        // youtu.be/VIDEO_ID
        if (url.Contains("youtu.be/"))
        {
            int slash = url.IndexOf("youtu.be/") + "youtu.be/".Length;
            string videoId = url[slash..].Split('?')[0].Trim('/');
            return string.IsNullOrEmpty(videoId)
                ? null
                : $"https://www.youtube.com/embed/{videoId}";
        }

        // youtube.com/watch?v=VIDEO_ID
        if (url.Contains("youtube.com/watch"))
        {
            int vIndex = url.IndexOf("v=");
            if (vIndex < 0) return null;
            string videoId = url[(vIndex + 2)..].Split('&')[0].Trim();
            return string.IsNullOrEmpty(videoId)
                ? null
                : $"https://www.youtube.com/embed/{videoId}";
        }

        // Already an embed URL
        if (url.Contains("youtube.com/embed/"))
            return url;

        return null; // not a YouTube URL
    }
}
