@page "/submissions"
@layout AppLayout
@using Microsoft.AspNetCore.Authorization
@using AuthWithAdmin.Shared.AuthSharedModels
@using AuthWithAdmin.Client.Services
@inject ITaskSubmissionsService SubmissionsService
@attribute [Authorize]

<!-- Submission modal (hosted on this page) -->
<SubmissionModal TaskId="@_openTaskId" OnClose="CloseModal" />

@if (_isLoading)
{
    <div class="sub-loading">
        <div class="sub-spinner"></div>
        <span>טוענת הגשות…</span>
    </div>
}
else if (_loadError)
{
    <div class="sub-state-msg sub-error">
        <span class="oi oi-warning" aria-hidden="true"></span>
        <p>אירעה שגיאה בטעינת ההגשות. נסי לרענן את הדף.</p>
    </div>
}
else if (!_tasks.Any())
{
    <div class="sub-state-msg">
        <span class="oi oi-info" aria-hidden="true"></span>
        <p>אין משימות הגשה בפרויקט שלך כרגע.</p>
    </div>
}
else
{
    <div class="sub-page">

        <!-- ── Header ── -->
        <div class="sub-header-card">
            <div class="sub-header-start">
                <div class="sub-page-icon">
                    <span class="oi oi-data-transfer-upload" aria-hidden="true"></span>
                </div>
                <div>
                    <h1 class="sub-page-title">הגשות</h1>
                    <p class="sub-page-subtitle">כל משימות ההגשה של הפרויקט שלך</p>
                </div>
            </div>
        </div>

        <!-- ── Summary pills ── -->
        <div class="sub-summary-row">
            <div class="sub-summary-pill">
                <span class="sub-summary-value">@_tasks.Count</span>
                <span class="sub-summary-label">סה"כ הגשות</span>
            </div>
            <div class="sub-summary-pill sub-summary-pill--done">
                <span class="sub-summary-value">@_tasks.Count(t => t.LatestSubmissionId.HasValue)</span>
                <span class="sub-summary-label">הוגשו</span>
            </div>
            <div class="sub-summary-pill sub-summary-pill--pending">
                <span class="sub-summary-value">@_tasks.Count(t => !t.LatestSubmissionId.HasValue)</span>
                <span class="sub-summary-label">ממתינות להגשה</span>
            </div>
        </div>

        <!-- ── Task cards ── -->
        <div class="sub-cards-grid">
            @foreach (var task in _tasks)
            {
                bool isReturned        = task.LatestMentorStatus == "Returned"
                                      || task.LatestSubmissionStatus == "NeedsRevision";
                bool isCourseSubmitted = task.LatestCourseSubmittedAt.HasValue;
                bool isSubmitted       = task.LatestSubmissionId.HasValue && !isReturned;
                bool isOverdue         = task.DueDate.HasValue
                                      && task.DueDate.Value.Date < DateTime.Today
                                      && !task.LatestSubmissionId.HasValue;
                bool canSubmitToCourse = task.LatestMentorStatus == "Approved"
                                      && !isCourseSubmitted
                                      && task.LatestSubmissionId.HasValue;
                var (badgeCss, badgeLabel) = SubmissionBadgeInfo(task);

                <div class="sub-card @(isReturned ? "sub-card-returned" : isOverdue ? "sub-card-overdue" : isSubmitted ? "sub-card-submitted" : "")">

                    <!-- Card header -->
                    <div class="sub-card-header">
                        <div class="sub-card-info">
                            <span class="sub-card-milestone">@task.MilestoneTitle</span>
                            <h3 class="sub-card-title">@task.TaskTitle</h3>
                        </div>
                        <span class="sub-status-badge sub-badge-@badgeCss">@badgeLabel</span>
                    </div>

                    @if (isReturned)
                    {
                        <div class="sub-card-returned-banner">
                            <span class="oi oi-arrow-circle-left" aria-hidden="true"></span>
                            ההגשה הוחזרה — יש לתקן ולהגיש מחדש
                        </div>
                    }

                    <!-- Due date -->
                    @if (task.DueDate.HasValue)
                    {
                        <div class="sub-card-due @(isOverdue ? "sub-due-overdue" : "")">
                            <span class="oi oi-calendar" aria-hidden="true"></span>
                            מועד הגשה: <strong>@task.DueDate.Value.ToString("dd/MM/yyyy")</strong>
                            @if (isOverdue) { <span class="sub-overdue-label">(באיחור)</span> }
                        </div>
                    }

                    <!-- Last submission info -->
                    @if (task.LatestSubmittedAt.HasValue)
                    {
                        <div class="sub-card-prev @(isReturned ? "sub-card-prev-returned" : "")">
                            <span class="oi @(isReturned ? "oi-arrow-circle-left" : "oi-check")" aria-hidden="true"></span>
                            הוגש לאחרונה: @task.LatestSubmittedAt.Value.ToString("dd/MM/yyyy HH:mm")
                            (@task.SubmissionCount @(task.SubmissionCount == 1 ? "הגשה" : "הגשות"))
                        </div>
                    }

                    <!-- Course submission action (appears after mentor approval) -->
                    @if (canSubmitToCourse)
                    {
                        <button class="sub-card-btn sub-card-btn-course"
                                @onclick="@(() => SubmitToCourseFromPageAsync(task))">
                            <span class="oi oi-globe" aria-hidden="true"></span>
                            הגשה לצוות הקורס
                        </button>
                    }
                    @if (isCourseSubmitted && !isReturned)
                    {
                        <div class="sub-card-course-done">
                            <span class="oi oi-circle-check" aria-hidden="true"></span>
                            הוגש לצוות הקורס · @task.LatestCourseSubmittedAt!.Value.ToString("dd/MM/yy HH:mm")
                        </div>
                    }

                    <!-- Action button -->
                    <div class="sub-card-actions">
                        <button class="sub-card-btn @(isReturned ? "sub-card-btn-returned" : isSubmitted ? "sub-card-btn-secondary" : "")"
                                @onclick="@(() => OpenSubmission(task.TaskId))">
                            <span class="oi @(isReturned ? "oi-loop-circular" : isSubmitted ? "oi-pencil" : "oi-data-transfer-upload")"
                                  aria-hidden="true"></span>
                            @(isReturned ? "הגשה לאחר תיקון" : isSubmitted ? "הגשה נוספת / צפייה" : "הגשה")
                        </button>
                    </div>

                </div>
            }
        </div>

    </div>
}

@code {
    [Parameter, SupplyParameterFromQuery] public int? TaskId { get; set; }
    [CascadingParameter] private User? _user { get; set; }

    private List<StudentSubmissionTaskDto> _tasks   = new();
    private bool _isLoading = true;
    private bool _loadError = false;
    private int  _openTaskId = 0;

    protected override async Task OnInitializedAsync()
    {
        var result = await SubmissionsService.GetMySubmissionTasksAsync();
        _loadError = result is null;
        _tasks     = result ?? new();
        _isLoading = false;

        // Auto-open modal when navigated here with ?taskId=N
        if (TaskId.HasValue && TaskId.Value > 0)
            _openTaskId = TaskId.Value;
    }

    private void OpenSubmission(int taskId) => _openTaskId = taskId;
    private void CloseModal()               => _openTaskId = 0;

    private async Task SubmitToCourseFromPageAsync(StudentSubmissionTaskDto task)
    {
        if (!task.LatestSubmissionId.HasValue) return;
        bool ok = await SubmissionsService.SubmitToCourseAsync(task.LatestSubmissionId.Value);
        if (ok) task.LatestCourseSubmittedAt = DateTime.Now;  // optimistic
    }

    // Returns (cssClass, label) based on status priority:
    // returned-by-mentor > needs-revision > reviewed > course-submitted > pending-mentor > submitted > none
    private static (string Css, string Label) SubmissionBadgeInfo(StudentSubmissionTaskDto task)
    {
        if (task.LatestMentorStatus == "Returned")          return ("returned-mentor", "הוחזר ע״י מנחה");
        if (task.LatestSubmissionStatus == "NeedsRevision") return ("needsrevision",   "דורש תיקון");
        if (task.LatestSubmissionStatus == "Reviewed")      return ("reviewed",        "נבדק");
        if (task.LatestCourseSubmittedAt.HasValue)          return ("submitted",       "הוגש לצוות הקורס");
        if (task.LatestMentorStatus == "Approved")          return ("approved",        "אושר ע״י מנחה");
        if (task.LatestMentorStatus == "Pending")           return ("submitted",       "ממתין לבדיקה");
        if (task.LatestSubmissionStatus == "Submitted")     return ("submitted",       "הוגש");
        return ("none", "טרם הוגש");
    }
}