@page "/create-team"
@layout BlankLayout
@attribute [AllowAnonymous]
@using Microsoft.AspNetCore.Components.Forms
@inject HttpClient Http
@inject NavigationManager Nav

<div class="ct-page">
    <div class="ct-card">

        <!-- ══════════════════════════════════════════
             HEADER
             ══════════════════════════════════════════ -->
        <div class="ct-header">
            <div class="ct-logo">G</div>
            <h1 class="ct-title">Gradify</h1>
            <p class="ct-subtitle">יצירת צוות לפרויקט גמר</p>
        </div>

        @if (_success)
        {
            <!-- ══════════════════════════════════════════
                 SUCCESS STATE
                 ══════════════════════════════════════════ -->
            <div class="ct-success-panel">
                <div class="ct-success-icon">✓</div>
                <h2 class="ct-success-title">הצוות נוצר בהצלחה!</h2>
                <p class="ct-success-body">
                    נשלח אימייל לכל אחד מחברי הצוות עם פרטי הכניסה למערכת.
                    <br />
                    עם קבלת הסיסמה הזמנית, כל סטודנט יוכל להיכנס ולהגיש את העדפות השיבוץ שלו.
                </p>
                @if (!string.IsNullOrEmpty(_warning))
                {
                    <p class="ct-success-warning">⚠ @_warning</p>
                }
                <button class="ct-submit-btn" @onclick="@(() => Nav.NavigateTo("/login"))">
                    מעבר לעמוד הכניסה
                </button>
            </div>
        }
        else
        {
            <!-- ══════════════════════════════════════════
                 FORM
                 ══════════════════════════════════════════ -->

            <!-- Students -->
            <div class="ct-students">
                @RenderStudentForm(1, _s1, OnImage1Changed)
                @RenderStudentForm(2, _s2, OnImage2Changed)
            </div>

            <!-- Error banner -->
            @if (!string.IsNullOrEmpty(_error))
            {
                <div class="ct-error-bar">
                    <span>⚠</span>
                    <span>@_error</span>
                </div>
            }

            <!-- Submit -->
            <div class="ct-footer">
                <button class="ct-submit-btn" @onclick="Submit" disabled="@_saving">
                    @if (_saving)
                    {
                        <span class="ct-spinner"></span>
                        <span>יוצר צוות...</span>
                    }
                    else
                    {
                        <span>יצירת הצוות ושליחת פרטי כניסה</span>
                    }
                </button>
                <p class="ct-footer-note">
                    לאחר הגשה, כל סטודנט יקבל אימייל עם סיסמה זמנית לכניסה למערכת.
                </p>
                <div class="ct-already-registered">
                    <span>כבר נרשמתן?</span>
                    <a class="ct-login-link" href="/login">להתחברות למערכת</a>
                </div>
            </div>
        }

    </div>
</div>

@* ──────────────────────────────────────────────────────────
   STUDENT FORM FRAGMENT
   ────────────────────────────────────────────────────────── *@
@code {

    private RenderFragment RenderStudentForm(int num, StudentState s, Func<InputFileChangeEventArgs, Task> onImage)
    {
        return __builder =>
        {
            <div class="ct-student-card">
                <div class="ct-student-header">
                    <div class="ct-student-num">@num</div>
                    <h3 class="ct-student-title">סטודנט @num</h3>
                </div>

                <!-- Profile image -->
                <div class="ct-avatar-row">
                    <div class="ct-avatar @(string.IsNullOrEmpty(s.ImagePreview) ? "ct-avatar--empty" : "")">
                        @if (!string.IsNullOrEmpty(s.ImagePreview))
                        {
                            <img src="@s.ImagePreview" alt="תמונת פרופיל" class="ct-avatar-img" />
                        }
                        else
                        {
                            <span class="ct-avatar-placeholder">📷</span>
                        }
                    </div>
                    <label class="ct-upload-btn">
                        @(string.IsNullOrEmpty(s.ImagePreview) ? "העלאת תמונה" : "החלפת תמונה")
                        <InputFile accept="image/*" OnChange="onImage" style="display:none" />
                    </label>
                </div>

                <div class="ct-field-grid">
                    <div class="ct-field">
                        <label class="ct-label">שם פרטי <span class="ct-required">*</span></label>
                        <input class="ct-input" type="text" @bind="s.FirstName" placeholder="שם פרטי" maxlength="50" />
                    </div>
                    <div class="ct-field">
                        <label class="ct-label">שם משפחה <span class="ct-required">*</span></label>
                        <input class="ct-input" type="text" @bind="s.LastName" placeholder="שם משפחה" maxlength="50" />
                    </div>
                    <div class="ct-field">
                        <label class="ct-label">מספר תעודת זהות <span class="ct-required">*</span></label>
                        <input class="ct-input" type="text" @bind="s.IdNumber" placeholder="9 ספרות" maxlength="20" />
                    </div>
                    <div class="ct-field">
                        <label class="ct-label">טלפון</label>
                        <input class="ct-input" type="tel" @bind="s.Phone" placeholder="05X-XXXXXXX" maxlength="20" />
                    </div>
                    <div class="ct-field ct-field--full">
                        <label class="ct-label">אימייל <span class="ct-required">*</span></label>
                        <input class="ct-input" type="email" @bind="s.Email" placeholder="example@mail.com" maxlength="150" />
                    </div>
                </div>
            </div>
        };
    }

    // ── State ────────────────────────────────────────────────────────────────

    private StudentState _s1 = new();
    private StudentState _s2 = new();
    private bool         _saving   = false;
    private bool         _success  = false;
    private string       _error    = "";
    private string       _warning  = "";

    private class StudentState
    {
        public string  FirstName    { get; set; } = "";
        public string  LastName     { get; set; } = "";
        public string  IdNumber     { get; set; } = "";
        public string  Email        { get; set; } = "";
        public string  Phone        { get; set; } = "";
        public string? ImageBase64  { get; set; }
        public string? ImageExt     { get; set; }
        public string? ImagePreview { get; set; }

        public StudentRegistrationForm ToDto() => new()
        {
            FirstName              = FirstName,
            LastName               = LastName,
            IdNumber               = IdNumber,
            Email                  = Email,
            Phone                  = Phone,
            ProfileImageBase64     = ImageBase64,
            ProfileImageExtension  = ImageExt,
        };
    }

    // ── Image handlers ───────────────────────────────────────────────────────

    private async Task OnImage1Changed(InputFileChangeEventArgs e)
        => await HandleImageAsync(e, _s1);

    private async Task OnImage2Changed(InputFileChangeEventArgs e)
        => await HandleImageAsync(e, _s2);

    private static async Task HandleImageAsync(InputFileChangeEventArgs e, StudentState s)
    {
        var file = e.File;
        if (file is null) return;

        const long maxSize = 5 * 1024 * 1024; // 5 MB
        if (file.Size > maxSize) return;       // silently ignore oversized files

        var ext = System.IO.Path.GetExtension(file.Name).TrimStart('.').ToLower();
        using var ms = new System.IO.MemoryStream();
        await file.OpenReadStream(maxSize).CopyToAsync(ms);

        s.ImageBase64  = Convert.ToBase64String(ms.ToArray());
        s.ImageExt     = ext;
        s.ImagePreview = $"data:{file.ContentType};base64,{s.ImageBase64}";
    }

    // ── Submit ───────────────────────────────────────────────────────────────

    private async Task Submit()
    {
        _error = "";

        // Client-side validation
        if (string.IsNullOrWhiteSpace(_s1.FirstName) || string.IsNullOrWhiteSpace(_s1.LastName))
            { _error = "יש למלא שם מלא לסטודנט 1"; return; }
        if (string.IsNullOrWhiteSpace(_s1.IdNumber))
            { _error = "יש להזין מספר תעודת זהות לסטודנט 1"; return; }
        if (string.IsNullOrWhiteSpace(_s1.Email) || !_s1.Email.Contains('@'))
            { _error = "יש להזין אימייל תקין לסטודנט 1"; return; }

        if (string.IsNullOrWhiteSpace(_s2.FirstName) || string.IsNullOrWhiteSpace(_s2.LastName))
            { _error = "יש למלא שם מלא לסטודנט 2"; return; }
        if (string.IsNullOrWhiteSpace(_s2.IdNumber))
            { _error = "יש להזין מספר תעודת זהות לסטודנט 2"; return; }
        if (string.IsNullOrWhiteSpace(_s2.Email) || !_s2.Email.Contains('@'))
            { _error = "יש להזין אימייל תקין לסטודנט 2"; return; }

        if (_s1.Email.Trim().ToLower() == _s2.Email.Trim().ToLower())
            { _error = "כתובות האימייל של שני הסטודנטים חייבות להיות שונות"; return; }

        if (_s1.IdNumber.Trim() == _s2.IdNumber.Trim())
            { _error = "מספרי תעודת הזהות של שני הסטודנטים חייבים להיות שונים"; return; }

        _saving = true;
        StateHasChanged();

        try
        {
            var req = new CreateTeamRequest
            {
                Student1 = _s1.ToDto(),
                Student2 = _s2.ToDto(),
            };

            var resp = await Http.PostAsJsonAsync("api/team-registration", req);

            if (resp.IsSuccessStatusCode)
            {
                var result = await resp.Content.ReadFromJsonAsync<TeamRegistrationResultDto>();
                _warning = result?.Warning ?? "";
                _success = true;
            }
            else
            {
                var msg = await resp.Content.ReadAsStringAsync();
                _error = msg.Trim('"');
            }
        }
        catch
        {
            _error = "שגיאה בחיבור לשרת. אנא נסה שוב.";
        }
        finally
        {
            _saving = false;
        }
    }
}
