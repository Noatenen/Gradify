@page "/assignments"
@layout AppLayout
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]

<div class="ap-page">
    <div class="ap-header">
        <h1 class="ap-title">שיבוצים</h1>
        <p class="ap-sub">ניהול שיבוצי סטודנטים לפרויקטים, טפסי העדפה ומדד ביקוש</p>
    </div>
    <div class="ap-placeholder">
        <span class="ap-placeholder-icon">🎯</span>
        <p>עמוד השיבוצים בפיתוח — יהיה זמין בקרוב</p>
    </div>
</div>
