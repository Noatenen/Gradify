@page "/mentor/projects"
@layout AppLayout
@attribute [Authorize(Roles = Roles.Mentor + "," + Roles.Admin + "," + Roles.Staff)]
@using AuthWithAdmin.Client.Services
@using AuthWithAdmin.Shared.AuthSharedModels
@inject IMentorProjectsService MentorService
@inject NavigationManager Nav

<div class="mp-page" dir="rtl">

    <!-- ══ Top bar ═══════════════════════════════════════════════════════════ -->
    <div class="mp-topbar">
        <div class="mp-topbar-start">
            <div>
                <div class="mp-breadcrumb">מנחה</div>
                <h1 class="mp-title">הפרויקטים שלי</h1>
            </div>
        </div>
        @if (!_isLoading && _projects.Count > 0)
        {
            <span class="mp-count-badge">@_projects.Count פרויקטים</span>
        }
    </div>

    <!-- ══ Content ═══════════════════════════════════════════════════════════ -->
    @if (_isLoading)
    {
        <div class="mp-loading">
            <div class="mp-spinner"></div>
            <span>טוען פרויקטים…</span>
        </div>
    }
    else if (_projects.Count == 0)
    {
        <div class="mp-empty">
            <span class="oi oi-folder" aria-hidden="true"></span>
            <p>לא משויכים אליך פרויקטים כרגע</p>
        </div>
    }
    else
    {
        <div class="mp-grid">
            @foreach (var p in _projects)
            {
                <button class='mp-card @(p.PendingMentorReview > 0 ? "mp-card-has-review" : "")'
                        @onclick='() => Nav.NavigateTo("/mentor/projects/" + p.Id)'>

                    <!-- Card header -->
                    <div class="mp-card-head">
                        <div class="mp-card-head-left">
                            <span class="mp-proj-number">#@p.ProjectNumber</span>
                            <span class="mp-health @HealthClass(p.HealthStatus)">
                                @HealthLabel(p.HealthStatus)
                            </span>
                        </div>
                        @if (p.PendingMentorReview > 0)
                        {
                            <span class="mp-review-badge">@p.PendingMentorReview ממתינות לאישור</span>
                        }
                    </div>

                    <!-- Title + team -->
                    <div class="mp-card-body">
                        <h2 class="mp-card-title">@p.Title</h2>
                        <div class="mp-team-row">
                            <span class="oi oi-people" aria-hidden="true"></span>
                            <span class="mp-team-name">@p.TeamName</span>
                            <span class="mp-team-members">(@p.StudentCount סטודנטים)</span>
                        </div>
                        @if (!string.IsNullOrEmpty(p.StudentNames))
                        {
                            <div class="mp-students">@p.StudentNames</div>
                        }
                    </div>

                    <!-- Milestone progress -->
                    @if (!string.IsNullOrEmpty(p.CurrentMilestoneTitle))
                    {
                        <div class="mp-milestone-row">
                            <div class="mp-milestone-info">
                                <span class="mp-milestone-label">אבן דרך נוכחית:</span>
                                <span class="mp-milestone-title">@p.CurrentMilestoneTitle</span>
                                @if (p.CurrentMilestoneDueDate.HasValue)
                                {
                                    <span class="mp-milestone-due">עד @p.CurrentMilestoneDueDate.Value.ToString("dd/MM/yy")</span>
                                }
                            </div>
                            <div class="mp-prog-bar-wrap">
                                <div class="mp-prog-bar">
                                    <div class="mp-prog-fill" style="width:@(p.MilestoneProgressPct)%"></div>
                                </div>
                                <span class="mp-prog-pct">@(p.MilestoneProgressPct)%</span>
                            </div>
                        </div>
                    }

                    <!-- Task counts -->
                    <div class="mp-task-chips">
                        @if (p.OverdueTasks > 0)
                        {
                            <span class="mp-chip mp-chip-overdue">@p.OverdueTasks באיחור</span>
                        }
                        <span class="mp-chip mp-chip-open">@p.OpenTasks פתוחות</span>
                        <span class="mp-chip mp-chip-progress">@p.InProgressTasks בביצוע</span>
                        <span class="mp-chip mp-chip-done">@p.CompletedTasks הושלמו</span>
                    </div>

                    <span class="oi oi-chevron-left mp-card-arrow" aria-hidden="true"></span>
                </button>
            }
        </div>
    }

</div>

@code {
    private List<MentorProjectSummaryDto> _projects  = new();
    private bool                          _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        _projects  = await MentorService.GetProjectsAsync();
        _isLoading = false;
    }

    private static string HealthClass(string? h) => h switch
    {
        "OnTrack"         => "mp-health-on",
        "NeedsAttention"  => "mp-health-warn",
        "AtRisk"          => "mp-health-risk",
        _                 => "mp-health-none",
    };

    private static string HealthLabel(string? h) => h switch
    {
        "OnTrack"        => "על המסלול",
        "NeedsAttention" => "דורש תשומת לב",
        "AtRisk"         => "בסיכון",
        _                => "",
    };
}
