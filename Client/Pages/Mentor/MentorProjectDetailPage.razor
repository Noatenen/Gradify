    private static string FirstLetter(string name) =>
        string.IsNullOrEmpty(name) ? "?" : name[0].ToString().ToUpper();

    private static string HealthClass(string? h) => h switch
    {
        "OnTrack"        => "mpd-health-on",
        "NeedsAttention" => "mpd-health-warn",
        "AtRisk"         => "mpd-health-risk",
        _                => "",
    };

    private static string HealthLabel(string? h) => h switch
    {
        "OnTrack"        => "על המסלול",
        "NeedsAttention" => "דורש תשומת לב",
        "AtRisk"         => "בסיכון",
        _                => "",
    };

    private static string StatusLabel(string? s) => s switch
    {
        "Active"    => "פעיל",
        "Completed" => "הושלם",
        "Archived"  => "בארכיון",
        _           => s ?? "",
    };

    private static string MilestoneStatusClass(string s) => s switch
    {
        "Completed" or "Done" or "Submitted" => "mpd-ms-done",
        "InProgress"                         => "mpd-ms-progress",
        _                                    => "mpd-ms-pending",
    };

    private static string MilestoneStatusLabel(string s) => s switch
    {
        "Completed" or "Done" or "Submitted" => "הושלם",
        "InProgress"                         => "בביצוע",
        "NotStarted"                         => "טרם החל",
        "Delayed"                            => "מאחר",
        _                                    => s,
    };

    private static string TaskDotClass(MentorTaskDto task)
    {
        // Mentor review state takes priority over the raw task status
        if (task.IsSubmission)
        {
            if (task.LatestMentorStatus == "Returned") return "mpd-dot-returned";
            if (task.LatestMentorStatus == "Approved") return "mpd-dot-done";
            if (task.LatestMentorStatus == "Pending")  return "mpd-dot-pending";
        }

        return task.Status switch
        {
            "Done" or "Completed" or "ApprovedForSubmission"          => "mpd-dot-done",
            "InProgress" or "SubmittedToMentor"
                or "ReturnedForRevision" or "RevisionSubmitted"       => "mpd-dot-progress",
            _                                                         => "mpd-dot-open",
        };
    }

    private static string TaskPillClass(MentorTaskDto task)
    {
        // When a resubmission is pending review, the raw task.Status may still be
        // ReturnedForRevision (set by the previous mentor-review). Override to
        // the "submitted" style so the mentor sees the correct current state.
        if (task.IsSubmission && task.LatestMentorStatus == "Pending"
            && task.Status == "ReturnedForRevision")
            return "mpd-pill-submitted";

        return task.Status switch
        {
            "Done" or "Completed" or "ApprovedForSubmission" => "mpd-pill-done",
            "InProgress"                                      => "mpd-pill-progress",
            "SubmittedToMentor" or "RevisionSubmitted"        => "mpd-pill-submitted",
            "ReturnedForRevision"                             => "mpd-pill-returned",
            _                                                 => "mpd-pill-open",
        };
    }

    private static string TaskStatusLabel(MentorTaskDto task)
    {
        if (task.IsSubmission && task.LatestMentorStatus == "Pending"
            && task.Status == "ReturnedForRevision")
            return "הוגש מחדש";

        return task.Status switch
        {
            "Open"                  => "פתוח",
            "InProgress"            => "בביצוע",
            "SubmittedToMentor"     => "הוגש למנחה",
            "ReturnedForRevision"   => "הוחזר לתיקון",
            "RevisionSubmitted"     => "תיקון הוגש",
            "ApprovedForSubmission" => "אושר להגשה",
            "Done" or "Completed"   => "הושלם",
            _                       => task.Status,
        };
    }

    private static string DrawerMentorStatusClass(string s) => s switch
    {
        "Approved" => "mpd-badge-approved",
        "Returned" => "mpd-badge-returned",
        _          => "mpd-badge-pending",
    };

    private static string DrawerMentorStatusLabel(string s) => s switch
    {
        "Approved" => "אושר",
        "Returned" => "הוחזר לתיקון",
        _          => "ממתין לאישורך",
    };

    private static string FileIcon(string contentType)
    {
        if (contentType.StartsWith("image/"))   return "oi-image";
        if (contentType == "application/pdf")   return "oi-document";
        if (contentType.Contains("word"))       return "oi-document";
        if (contentType.Contains("zip") || contentType.Contains("compressed")) return "oi-layers";
        return "oi-file";
    }

    private static string FormatSize(long bytes)
    {
        if (bytes < 1024)           return $"{bytes} B";
        if (bytes < 1024 * 1024)    return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024):F1} MB";
    }
