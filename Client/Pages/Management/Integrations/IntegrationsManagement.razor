@page "/management/integrations"
@layout AppLayout
@attribute [Authorize(Roles = Roles.Admin + "," + Roles.Staff)]
@using AuthWithAdmin.Client.Services
@using AuthWithAdmin.Shared.AuthSharedModels
@inject IIntegrationSettingsService IntegrationService
@inject IAirtableIntegrationService AirtableService
@inject NavigationManager Nav

<div class="im-page">

    <!-- ══ Top bar ══════════════════════════════════════════════════════════ -->
    <div class="im-topbar">
        <div class="im-topbar-start">
            <button class="im-back-btn" @onclick='() => Nav.NavigateTo("/management")' title="חזרה לניהול">
                <span class="oi oi-chevron-right" aria-hidden="true"></span>
            </button>
            <div>
                <div class="im-breadcrumb">ניהול</div>
                <h1 class="im-title">אינטגרציות</h1>
            </div>
        </div>
    </div>

    <!-- ══ Content ══════════════════════════════════════════════════════════ -->
    @if (_isLoading)
    {
        <div class="im-loading">
            <div class="im-spinner"></div>
            <span>טוענת הגדרות…</span>
        </div>
    }
    else
    {
        <div class="im-grid">

            <!-- ── Slack card ─────────────────────────────────────────────── -->
            <div class="im-card">
                <div class="im-card-header">
                    <div class="im-card-icon im-icon-slack">
                        <span class="oi oi-chat" aria-hidden="true"></span>
                    </div>
                    <div class="im-card-title-wrap">
                        <h2 class="im-card-title">Slack</h2>
                        <span class="im-card-sub">OAuth v2 — מאפשר לסטודנטים לחבר את חשבון ה-Slack שלהם</span>
                    </div>
                    <div class="im-status-badge @(_slack.IsEnabled ? "im-badge-on" : "im-badge-off")">
                        @(_slack.IsEnabled ? "פעיל" : "מושבת")
                    </div>
                </div>

                <div class="im-form">
                    <!-- Client ID -->
                    <div class="im-field">
                        <label class="im-label">Client ID <span class="im-required">*</span></label>
                        <input type="text"
                               class="im-input"
                               @bind="_slack.ClientId"
                               placeholder="xxxxxxxxxxxxxxxxxxxxxxxx"
                               maxlength="200"
                               disabled="@_isSaving" />
                        <span class="im-hint">מזהה האפליקציה מדף Basic Information ב-Slack API</span>
                    </div>

                    <!-- Client Secret -->
                    <div class="im-field">
                        <label class="im-label">
                            Client Secret
                            @if (_slackHasSecret && string.IsNullOrEmpty(_slackSecretInput))
                            {
                                <span class="im-secret-set">
                                    <span class="oi oi-lock-locked" aria-hidden="true"></span>
                                    מוגדר — השאר ריק לשמירת הסוד הנוכחי
                                </span>
                            }
                        </label>
                        <input type="password"
                               class="im-input"
                               @bind="_slackSecretInput"
                               placeholder="@(_slackHasSecret ? "••••••••••••••• (שמור קיים)" : "הכנס Client Secret")"
                               maxlength="200"
                               disabled="@_isSaving" />
                        <span class="im-hint">הסוד לא מוצג לאחר שמירה ולא נשלח ללקוח</span>
                    </div>

                    <!-- Redirect URI -->
                    <div class="im-field">
                        <label class="im-label">Redirect URI <span class="im-required">*</span></label>
                        <input type="text"
                               class="im-input im-input-ltr"
                               @bind="_slack.RedirectUri"
                               placeholder="https://yourdomain.com/api/slack/callback"
                               maxlength="500"
                               disabled="@_isSaving" />
                        <span class="im-hint">חייב להיות זהה ל-Redirect URL שהוגדר ב-Slack API</span>
                    </div>

                    <!-- Scopes (optional) -->
                    <div class="im-field">
                        <label class="im-label">Bot Scopes <span class="im-optional">(אופציונלי)</span></label>
                        <input type="text"
                               class="im-input im-input-ltr"
                               @bind="_slack.Scopes"
                               placeholder="chat:write"
                               maxlength="500"
                               disabled="@_isSaving" />
                        <span class="im-hint">הרשאות Slack מופרדות בפסיקים — ברירת מחדל: chat:write</span>
                    </div>

                    <!-- Enable / Disable -->
                    <div class="im-field im-field-toggle">
                        <span class="im-label">הפעלת אינטגרציה</span>
                        <button class="im-toggle @(_slack.IsEnabled ? "im-toggle-on" : "")"
                                @onclick="ToggleSlackEnabled"
                                disabled="@_isSaving">
                            <span class="im-toggle-thumb"></span>
                        </button>
                    </div>

                    <!-- Actions -->
                    <div class="im-actions">
                        @if (_saveError)
                        {
                            <span class="im-msg-error">
                                <span class="oi oi-warning" aria-hidden="true"></span>
                                שגיאה בשמירה. בדקי את הפרטים ונסי שנית.
                            </span>
                        }
                        @if (_saveSuccess)
                        {
                            <span class="im-msg-ok">
                                <span class="oi oi-circle-check" aria-hidden="true"></span>
                                ההגדרות נשמרו
                            </span>
                        }
                        <button class="im-btn-save" @onclick="SaveSlackAsync" disabled="@_isSaving">
                            @if (_isSaving)
                            {
                                <div class="im-spinner-sm"></div>
                                <span>שומר…</span>
                            }
                            else
                            {
                                <span class="oi oi-check" aria-hidden="true"></span>
                                <span>שמירת הגדרות</span>
                            }
                        </button>
                    </div>
                </div>
            </div>

            <!-- ── Airtable card ─────────────────────────────────────────── -->
            <div class="im-card">
                <div class="im-card-header">
                    <div class="im-card-icon im-icon-airtable">
                        <span class="oi oi-spreadsheet" aria-hidden="true"></span>
                    </div>
                    <div class="im-card-title-wrap">
                        <h2 class="im-card-title">Airtable</h2>
                        <span class="im-card-sub">ייבוא הצעות פרויקט, מנטורים ומיפויי שדות לפי מחזור אקדמי</span>
                    </div>
                    @if (_airtableLoading)
                    {
                        <span class="im-status-badge im-badge-off">טוען…</span>
                    }
                    else
                    {
                        <span class="im-status-badge @(_airtableActiveCount > 0 ? "im-badge-on" : "im-badge-off")">
                            @(_airtableActiveCount > 0 ? "פעיל" : "לא הוגדר")
                        </span>
                    }
                </div>

                <div class="im-form">
                    @if (!_airtableLoading)
                    {
                        <div class="im-airtable-summary">
                            <div class="im-airtable-summary-row">
                                <span class="im-airtable-label">תצורות מוגדרות</span>
                                <strong>@_airtableTotalCount</strong>
                            </div>
                            <div class="im-airtable-summary-row">
                                <span class="im-airtable-label">תצורה פעילה</span>
                                <strong>@(_airtableActiveCount > 0 ? "כן" : "אין")</strong>
                            </div>
                        </div>
                    }
                    <div class="im-actions">
                        <button class="im-btn-save" @onclick='() => Nav.NavigateTo("/management/integrations/airtable")'>
                            <span class="oi oi-pencil" aria-hidden="true"></span>
                            <span>ניהול הגדרות Airtable</span>
                        </button>
                    </div>
                </div>
            </div>

            <!-- ── Future integrations placeholder ───────────────────────── -->
            <div class="im-card im-card-future">
                <div class="im-card-header">
                    <div class="im-card-icon im-icon-google">
                        <span class="oi oi-calendar" aria-hidden="true"></span>
                    </div>
                    <div class="im-card-title-wrap">
                        <h2 class="im-card-title">Google Calendar</h2>
                        <span class="im-card-sub">סנכרון אבני דרך ומועדי הגשה לקלנדר האישי של הסטודנט</span>
                    </div>
                    <span class="im-coming-soon">בקרוב</span>
                </div>
            </div>

        </div>
    }

</div>

@code {
    private IntegrationSettingsDto _slack         = new() { Provider = "Slack" };
    private string                 _slackSecretInput = "";
    private bool                   _slackHasSecret   = false;

    private bool _isLoading   = true;
    private bool _isSaving    = false;
    private bool _saveError   = false;
    private bool _saveSuccess = false;

    private bool _airtableLoading     = true;
    private int  _airtableTotalCount  = 0;
    private int  _airtableActiveCount = 0;

    protected override async Task OnInitializedAsync()
    {
        var settings = await IntegrationService.GetSlackSettingsAsync();
        if (settings is not null)
        {
            _slack        = settings;
            _slackHasSecret = settings.HasSecret;
        }
        _isLoading = false;

        var configs = await AirtableService.GetAllAsync();
        _airtableTotalCount  = configs?.Count ?? 0;
        _airtableActiveCount = configs?.Count(c => c.IsActive) ?? 0;
        _airtableLoading     = false;
    }

    private void ToggleSlackEnabled() => _slack.IsEnabled = !_slack.IsEnabled;

    private async Task SaveSlackAsync()
    {
        _isSaving    = true;
        _saveError   = false;
        _saveSuccess = false;
        StateHasChanged();

        var req = new UpdateIntegrationSettingsRequest
        {
            ClientId     = _slack.ClientId?.Trim()    ?? "",
            ClientSecret = _slackSecretInput?.Trim()  ?? "",
            RedirectUri  = _slack.RedirectUri?.Trim() ?? "",
            Scopes       = _slack.Scopes?.Trim()      ?? "",
            IsEnabled    = _slack.IsEnabled,
        };

        bool ok = await IntegrationService.UpdateSlackSettingsAsync(req);
        _isSaving = false;

        if (ok)
        {
            _saveSuccess    = true;
            _slackHasSecret = _slackHasSecret || !string.IsNullOrEmpty(_slackSecretInput);
            _slackSecretInput = "";
            _ = AutoClearAsync(() => _saveSuccess = false, 3000);
        }
        else
        {
            _saveError = true;
        }

        StateHasChanged();
    }

    private async Task AutoClearAsync(Action clear, int delayMs)
    {
        await Task.Delay(delayMs);
        clear();
        StateHasChanged();
    }
}
