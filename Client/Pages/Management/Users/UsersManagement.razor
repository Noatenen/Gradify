@page "/management/users"
@layout AppLayout
@attribute [Authorize(Roles = Roles.Admin)]
@inject NavigationManager Nav
@inject IAuthenticationService _Auth


<div class="um-page" @onclick="CloseAllMenus">

    <!-- ═══════════════════════════════════════════
         TOP BAR
         ═══════════════════════════════════════════ -->
    <div class="um-topbar">
        <div class="um-topbar-start">
            <button class="um-back-btn" @onclick="@(() => Nav.NavigateTo("/management"))"
                    @onclick:stopPropagation="true" title="חזרה לניהול">
                <span class="oi oi-chevron-right" aria-hidden="true"></span>
            </button>
            <div>
                <div class="um-breadcrumb">ניהול</div>
                <h1 class="um-title">ניהול משתמשים</h1>
            </div>
        </div>

        <div class="um-topbar-end" @onclick:stopPropagation="true">
            <div class="um-import-wrap">
                <button class="um-import-btn" @onclick="ToggleImportMenu">
                    <span class="oi oi-plus um-import-icon" aria-hidden="true"></span>
                    ייבוא משתמשים
                </button>

                @if (_importMenuOpen)
                {
                    <div class="um-import-dropdown">
                        <div class="um-import-dropdown-section-label">העלאת קובץ</div>
                        <button class="um-import-option" @onclick="@(() => ImportAction("csv"))">
                            <span class="oi oi-data-transfer-download" aria-hidden="true"></span>
                            ייבוא מ-CSV
                        </button>
                        <button class="um-import-option" @onclick="@(() => ImportAction("xlsx"))">
                            <span class="oi oi-spreadsheet" aria-hidden="true"></span>
                            ייבוא מ-Excel / XLSX
                        </button>
                        <div class="um-import-sep"></div>
                        <div class="um-import-dropdown-section-label">חיבור מערכות חיצוניות</div>
                        <button class="um-import-option um-import-option--soon" disabled>
                            <span class="oi oi-cloud-download" aria-hidden="true"></span>
                            ייבוא מ-Moodle
                            <span class="um-soon-badge">בקרוב</span>
                        </button>
                        <button class="um-import-option um-import-option--soon" disabled>
                            <span class="oi oi-cloud-download" aria-hidden="true"></span>
                            ייבוא מ-Airtable
                            <span class="um-soon-badge">בקרוב</span>
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- ═══════════════════════════════════════════
         FILTERS BAR
         ═══════════════════════════════════════════ -->
    <div class="um-filters-bar">
        <div class="um-search-wrap">
            <span class="oi oi-magnifying-glass um-search-icon" aria-hidden="true"></span>
            <input class="um-search"
                   type="text"
                   placeholder="חיפוש לפי שם, מייל או טלפון..."
                   @bind="_searchQuery"
                   @bind:event="oninput" />
        </div>
        <div class="um-filters">
            <select class="um-filter-select" @bind="_filterRole">
                <option value="">כל התפקידים</option>
                <option value="Student">סטודנט</option>
                <option value="Mentor">מנחה</option>
                <option value="Lecturer">מרצה</option>
                <option value="Admin">מנהל</option>
            </select>
            <select class="um-filter-select" @bind="_filterCycle">
                <option value="">כל המחזורים</option>
                <option value="2024-2025">2024-2025</option>
                <option value="2025-2026">2025-2026</option>
            </select>
            <select class="um-filter-select" @bind="_filterStatus">
                <option value="">כל הסטטוסים</option>
                <option value="active">פעיל</option>
                <option value="inactive">לא פעיל</option>
            </select>
        </div>
    </div>

    <!-- ═══════════════════════════════════════════
         USERS TABLE
         ═══════════════════════════════════════════ -->
    <div class="um-table-panel">
        <div class="um-table-wrap">
            <table class="um-table">
                <thead>
                    <tr>
                        <th>שם מלא</th>
                        <th>מייל</th>
                        <th>תפקיד</th>
                        <th>מחזור</th>
                        <th>טלפון</th>
                        <th>סטטוס</th>
                        <th class="um-th-actions">פעולות</th>
                    </tr>
                </thead>
                <tbody>
                    @if (_loading)
                    {
                        <tr>
                            <td colspan="7" class="um-empty">טוען משתמשים...</td>
                        </tr>
                    }
                    else if (!FilteredUsers.Any())
                    {
                        <tr>
                            <td colspan="7" class="um-empty">
                                <span class="oi oi-magnifying-glass" aria-hidden="true"></span>
                                לא נמצאו משתמשים התואמים את הסינון
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var user in FilteredUsers)
                        {
                            var role = user.Roles.FirstOrDefault() ?? "";
                            var fullName = $"{user.FirstName} {user.LastName}".Trim();
                            <tr class="um-row">
                                <td class="um-cell-name">
                                    <div class="um-name-cell">
                                        <div class="um-mini-avatar">@GetInitials(fullName)</div>
                                        <span>@fullName</span>
                                    </div>
                                </td>
                                <td class="um-cell-secondary">@user.Email</td>
                                <td>
                                    <span class="um-role-badge um-role-@role.ToLower()">
                                        @RoleLabel(role)
                                    </span>
                                </td>
                                <td class="um-cell-secondary">@user.AcademicYear</td>
                                <td class="um-cell-secondary" dir="ltr">@user.Phone</td>
                                <td>
                                    <span class="um-status-badge @(user.IsActive ? "um-status--active" : "um-status--inactive")">
                                        @(user.IsActive ? "פעיל" : "לא פעיל")
                                    </span>
                                </td>
                                <td class="um-cell-actions" @onclick:stopPropagation="true">
                                    <div class="um-actions-wrap">
                                        <button class="um-dots-btn"
                                                @onclick="@(() => ToggleRowMenu(user.Id))"
                                                title="פעולות נוספות">
                                            <span class="oi oi-ellipses" aria-hidden="true"></span>
                                        </button>
                                        @if (_openRowMenuId == user.Id)
                                        {
                                            <div class="um-row-menu">
                                                <button class="um-row-action" @onclick="@(() => ChangeRole(user))">
                                                    <span class="oi oi-person" aria-hidden="true"></span>
                                                    שינוי תפקיד
                                                </button>
                                                <button class="um-row-action" @onclick="@(() => ToggleActive(user))">
                                                    <span class="oi @(user.IsActive ? "oi-ban" : "oi-circle-check")" aria-hidden="true"></span>
                                                    @(user.IsActive ? "השבתת משתמש" : "הפעלת משתמש")
                                                </button>
                                                <button class="um-row-action" @onclick="@(() => EditUser(user))">
                                                    <span class="oi oi-pencil" aria-hidden="true"></span>
                                                    עריכת פרטים
                                                </button>
                                            </div>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="um-table-footer">
            <span class="um-count">
                @{
                    var count = FilteredUsers.Count();
                }
                סה"כ @count משתמשים
                @if (!string.IsNullOrEmpty(_filterRole) || !string.IsNullOrEmpty(_filterStatus) ||
                     !string.IsNullOrEmpty(_searchQuery) || _filterCycle != "2025-2026")
                {
                    <span class="um-count-note">(מסוננים מתוך @_allUsers.Count)</span>
                }
            </span>
        </div>
    </div>

</div>

@code {

    // ─────────────────────────────────────────────────
    //  Data
    // ─────────────────────────────────────────────────
    private List<UserForAdmin> _allUsers = new();
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _allUsers = await _Auth.GetUsersByRoles("") ?? new List<UserForAdmin>();
        _loading = false;
    }

    // ─────────────────────────────────────────────────
    //  Filter / search state
    // ─────────────────────────────────────────────────
    private string _searchQuery  = "";
    private string _filterRole   = "";
    private string _filterCycle  = "2025-2026";   // default: current active cycle
    private string _filterStatus = "";

    private IEnumerable<UserForAdmin> FilteredUsers => _allUsers
        .Where(u => string.IsNullOrEmpty(_filterRole)
                    || u.Roles.Contains(_filterRole))
        .Where(u => string.IsNullOrEmpty(_filterCycle)
                    || u.AcademicYear == _filterCycle)
        .Where(u => string.IsNullOrEmpty(_filterStatus)
                    || (_filterStatus == "active"   &&  u.IsActive)
                    || (_filterStatus == "inactive" && !u.IsActive))
        .Where(u =>
        {
            if (string.IsNullOrEmpty(_searchQuery)) return true;
            var fullName = $"{u.FirstName} {u.LastName}";
            return fullName.Contains(_searchQuery,  StringComparison.OrdinalIgnoreCase)
                || u.Email.Contains(_searchQuery,   StringComparison.OrdinalIgnoreCase)
                || u.Phone.Contains(_searchQuery,   StringComparison.OrdinalIgnoreCase);
        });

    // ─────────────────────────────────────────────────
    //  Menu state
    // ─────────────────────────────────────────────────
    private bool _importMenuOpen = false;
    private int  _openRowMenuId  = -1;

    private void ToggleImportMenu()
    {
        _importMenuOpen = !_importMenuOpen;
        _openRowMenuId  = -1;
    }

    private void ToggleRowMenu(int userId)
    {
        _openRowMenuId  = _openRowMenuId == userId ? -1 : userId;
        _importMenuOpen = false;
    }

    private void CloseAllMenus()
    {
        _importMenuOpen = false;
        _openRowMenuId  = -1;
    }

    // ─────────────────────────────────────────────────
    //  Row actions
    // ─────────────────────────────────────────────────
    private void ImportAction(string source) => _importMenuOpen = false;   // TODO: file upload dialog

    private void ChangeRole(UserForAdmin user)
    {
        _openRowMenuId = -1;
        // TODO: open role-change modal
    }

    private void ToggleActive(UserForAdmin user)
    {
        // UI-only toggle — no persistence endpoint exists yet
        user.IsActive  = !user.IsActive;
        _openRowMenuId = -1;
    }

    private void EditUser(UserForAdmin user)
    {
        _openRowMenuId = -1;
        // TODO: open edit panel / navigate to edit page
    }

    // ─────────────────────────────────────────────────
    //  Display helpers
    // ─────────────────────────────────────────────────
    private static string RoleLabel(string role) => role switch
    {
        "Student"  => "סטודנט",
        "Mentor"   => "מנחה",
        "Lecturer" => "מרצה",
        "Admin"    => "מנהל",
        _          => role
    };

    private static string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[1][0]}"
            : parts[0][0].ToString();
    }
}
