@page "/management/users"
@layout AppLayout
@attribute [Authorize(Roles = Roles.Admin)]
@using AuthWithAdmin.Shared.AuthSharedModels
@inject NavigationManager Nav
@inject IAuthenticationService _Auth

<!-- ══════════════════════════════════════════
     CREATE USER MODAL
     ══════════════════════════════════════════ -->
@if (_createOpen)
{
    <div class="um-modal-overlay" @onclick="CancelCreate">
        <div class="um-modal-box" @onclick:stopPropagation="true">
            <div class="um-modal-header">
                <div>
                    <div class="um-modal-title">הוספת משתמש חדש</div>
                    <div class="um-modal-subtitle">הסיסמה תישלח למייל המשתמש</div>
                </div>
                <button class="um-modal-close" @onclick="CancelCreate" title="סגירה">
                    <span class="oi oi-x" aria-hidden="true"></span>
                </button>
            </div>

            <div class="um-modal-body">
                <div class="um-form-row">
                    <div class="um-form-field">
                        <label class="um-form-label">שם פרטי *</label>
                        <input class="um-form-input" @bind="_createFirstName" placeholder="ישראל" />
                    </div>
                    <div class="um-form-field">
                        <label class="um-form-label">שם משפחה *</label>
                        <input class="um-form-input" @bind="_createLastName" placeholder="ישראלי" />
                    </div>
                </div>
                <div class="um-form-field">
                    <label class="um-form-label">כתובת מייל *</label>
                    <input class="um-form-input" @bind="_createEmail" placeholder="user@example.com" dir="ltr" type="email" />
                </div>
                <div class="um-form-row">
                    <div class="um-form-field">
                        <label class="um-form-label">טלפון</label>
                        <input class="um-form-input" @bind="_createPhone" placeholder="050-0000000" dir="ltr" />
                    </div>
                    <div class="um-form-field">
                        <label class="um-form-label">שנת לימודים</label>
                        <select class="um-form-select" @bind="_createYear">
                            <option value="2024-2025">2024-2025</option>
                            <option value="2025-2026">2025-2026</option>
                        </select>
                    </div>
                </div>
                <div class="um-form-field">
                    <label class="um-form-label">תפקיד *</label>
                    <select class="um-form-select" @bind="_createRole">
                        <option value="Student">סטודנט</option>
                        <option value="Mentor">מנחה</option>
                        <option value="Staff">מרצה / צוות</option>
                        <option value="Admin">מנהל מערכת</option>
                    </select>
                </div>

                @if (!string.IsNullOrEmpty(_createError))
                {
                    <div class="um-form-error">
                        <span class="oi oi-warning" aria-hidden="true"></span>
                        @_createError
                    </div>
                }

                @if (_createSuccess)
                {
                    <div class="um-form-success">
                        <span class="oi oi-check" aria-hidden="true"></span>
                        המשתמש נוצר בהצלחה — נשלח מייל עם הגדרת סיסמה
                    </div>
                }
            </div>

            <div class="um-modal-footer">
                <button class="um-modal-save-btn" @onclick="SaveCreate" disabled="@_createSaving">
                    @if (_createSaving)
                    {
                        <span class="um-spinner-sm"></span>
                    }
                    else
                    {
                        <span class="oi oi-plus" aria-hidden="true"></span>
                    }
                    הוספה
                </button>
                <button class="um-modal-cancel-btn" @onclick="CancelCreate" disabled="@_createSaving">ביטול</button>
            </div>
        </div>
    </div>
}

<!-- ══════════════════════════════════════════
     EDIT USER MODAL
     ══════════════════════════════════════════ -->
@if (_editUser is not null)
{
    <div class="um-modal-overlay" @onclick="CancelEdit">
        <div class="um-modal-box" @onclick:stopPropagation="true">
            <div class="um-modal-header">
                <div>
                    <div class="um-modal-title">עריכת משתמש</div>
                    <div class="um-modal-subtitle">@_editUser.Email</div>
                </div>
                <button class="um-modal-close" @onclick="CancelEdit" title="סגירה">
                    <span class="oi oi-x" aria-hidden="true"></span>
                </button>
            </div>

            <div class="um-modal-body">
                <div class="um-form-row">
                    <div class="um-form-field">
                        <label class="um-form-label">שם פרטי</label>
                        <input class="um-form-input" @bind="_editFirstName" placeholder="שם פרטי" />
                    </div>
                    <div class="um-form-field">
                        <label class="um-form-label">שם משפחה</label>
                        <input class="um-form-input" @bind="_editLastName" placeholder="שם משפחה" />
                    </div>
                </div>
                <div class="um-form-row">
                    <div class="um-form-field">
                        <label class="um-form-label">טלפון</label>
                        <input class="um-form-input" @bind="_editPhone" placeholder="050-0000000" dir="ltr" />
                    </div>
                    <div class="um-form-field">
                        <label class="um-form-label">שנת לימודים</label>
                        <select class="um-form-select" @bind="_editYear">
                            <option value="2024-2025">2024-2025</option>
                            <option value="2025-2026">2025-2026</option>
                        </select>
                    </div>
                </div>
                <div class="um-form-field">
                    <label class="um-form-label">תפקיד</label>
                    <select class="um-form-select" @bind="_editRole">
                        <option value="Student">סטודנט</option>
                        <option value="Mentor">מנחה</option>
                        <option value="Staff">מרצה / צוות</option>
                        <option value="Admin">מנהל מערכת</option>
                    </select>
                </div>

                @if (!string.IsNullOrEmpty(_editError))
                {
                    <div class="um-form-error">
                        <span class="oi oi-warning" aria-hidden="true"></span>
                        @_editError
                    </div>
                }
            </div>

            <div class="um-modal-footer">
                <button class="um-modal-cancel-btn" @onclick="CancelEdit" disabled="@_editSaving">ביטול</button>
                <button class="um-modal-save-btn" @onclick="SaveEdit" disabled="@_editSaving">
                    @if (_editSaving)
                    {
                        <span class="um-spinner-sm"></span>
                    }
                    else
                    {
                        <span class="oi oi-check" aria-hidden="true"></span>
                    }
                    שמירה
                </button>
            </div>
        </div>
    </div>
}

<div class="um-page" @onclick="CloseAllMenus">

    <!-- ═══════════════════════════════════════════
         TOP BAR
         ═══════════════════════════════════════════ -->
    <div class="um-topbar">
        <div class="um-topbar-start">
            <button class="um-back-btn" @onclick="@(() => Nav.NavigateTo("/management"))"
                    @onclick:stopPropagation="true" title="חזרה לניהול">
                <span class="oi oi-chevron-right" aria-hidden="true"></span>
            </button>
            <div>
                <div class="um-breadcrumb">ניהול</div>
                <h1 class="um-title">ניהול משתמשים</h1>
            </div>
        </div>

        <div class="um-topbar-end" @onclick:stopPropagation="true">
            <button class="um-create-btn" @onclick="OpenCreate">
                <span class="oi oi-person um-create-icon" aria-hidden="true"></span>
                הוספת משתמש
            </button>
            <div class="um-import-wrap">
                <button class="um-import-btn" @onclick="ToggleImportMenu">
                    <span class="oi oi-plus um-import-icon" aria-hidden="true"></span>
                    ייבוא משתמשים
                </button>

                @if (_importMenuOpen)
                {
                    <div class="um-import-dropdown">
                        <div class="um-import-dropdown-section-label">העלאת קובץ</div>
                        <button class="um-import-option" @onclick="@(() => ImportAction("csv"))">
                            <span class="oi oi-data-transfer-download" aria-hidden="true"></span>
                            ייבוא מ-CSV
                        </button>
                        <button class="um-import-option" @onclick="@(() => ImportAction("xlsx"))">
                            <span class="oi oi-spreadsheet" aria-hidden="true"></span>
                            ייבוא מ-Excel / XLSX
                        </button>
                        <div class="um-import-sep"></div>
                        <div class="um-import-dropdown-section-label">חיבור מערכות חיצוניות</div>
                        <button class="um-import-option um-import-option--soon" disabled>
                            <span class="oi oi-cloud-download" aria-hidden="true"></span>
                            ייבוא מ-Moodle
                            <span class="um-soon-badge">בקרוב</span>
                        </button>
                        <button class="um-import-option um-import-option--soon" disabled>
                            <span class="oi oi-cloud-download" aria-hidden="true"></span>
                            ייבוא מ-Airtable
                            <span class="um-soon-badge">בקרוב</span>
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- ═══════════════════════════════════════════
         FILTERS BAR
         ═══════════════════════════════════════════ -->
    <div class="um-filters-bar">
        <div class="um-search-wrap">
            <span class="oi oi-magnifying-glass um-search-icon" aria-hidden="true"></span>
            <input class="um-search"
                   type="text"
                   placeholder="חיפוש לפי שם, מייל או טלפון..."
                   @bind="_searchQuery"
                   @bind:event="oninput" />
        </div>
        <div class="um-filters">
            <select class="um-filter-select" @bind="_filterRole">
                <option value="">כל התפקידים</option>
                <option value="Student">סטודנט</option>
                <option value="Mentor">מנחה</option>
                <option value="Lecturer">מרצה</option>
                <option value="Admin">מנהל</option>
            </select>
            <select class="um-filter-select" @bind="_filterCycle">
                <option value="">כל המחזורים</option>
                <option value="2024-2025">2024-2025</option>
                <option value="2025-2026">2025-2026</option>
            </select>
            <select class="um-filter-select" @bind="_filterStatus">
                <option value="">כל הסטטוסים</option>
                <option value="active">פעיל</option>
                <option value="inactive">לא פעיל</option>
            </select>
        </div>
    </div>

    <!-- ═══════════════════════════════════════════
         USERS TABLE
         ═══════════════════════════════════════════ -->
    <div class="um-table-panel">
        <div class="um-table-wrap">
            <table class="um-table">
                <thead>
                    <tr>
                        <th>שם מלא</th>
                        <th>מייל</th>
                        <th>תפקיד</th>
                        <th>מחזור</th>
                        <th>טלפון</th>
                        <th>סטטוס</th>
                        <th class="um-th-actions">פעולות</th>
                    </tr>
                </thead>
                <tbody>
                    @if (_loading)
                    {
                        <tr>
                            <td colspan="7" class="um-empty">טוען משתמשים...</td>
                        </tr>
                    }
                    else if (!FilteredUsers.Any())
                    {
                        <tr>
                            <td colspan="7" class="um-empty">
                                <span class="oi oi-magnifying-glass" aria-hidden="true"></span>
                                לא נמצאו משתמשים התואמים את הסינון
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var user in FilteredUsers)
                        {
                            var role = user.Roles.FirstOrDefault() ?? "";
                            var fullName = $"{user.FirstName} {user.LastName}".Trim();
                            <tr class="um-row">
                                <td class="um-cell-name">
                                    <div class="um-name-cell">
                                        <div class="um-mini-avatar">@GetInitials(fullName)</div>
                                        <span>@fullName</span>
                                    </div>
                                </td>
                                <td class="um-cell-secondary">@user.Email</td>
                                <td>
                                    <span class="um-role-badge um-role-@role.ToLower()">
                                        @RoleLabel(role)
                                    </span>
                                </td>
                                <td class="um-cell-secondary">@user.AcademicYear</td>
                                <td class="um-cell-secondary" dir="ltr">@user.Phone</td>
                                <td>
                                    <span class="um-status-badge @(user.IsActive ? "um-status--active" : "um-status--inactive")">
                                        @(user.IsActive ? "פעיל" : "לא פעיל")
                                    </span>
                                </td>
                                <td class="um-cell-actions" @onclick:stopPropagation="true">
                                    <div class="um-actions-wrap">
                                        <button class="um-dots-btn"
                                                @onclick="@(() => ToggleRowMenu(user.Id))"
                                                title="פעולות נוספות">
                                            <span class="oi oi-ellipses" aria-hidden="true"></span>
                                        </button>
                                        @if (_openRowMenuId == user.Id)
                                        {
                                            <div class="um-row-menu">
                                                <button class="um-row-action" @onclick="@(() => ToggleActive(user))">
                                                    <span class="oi @(user.IsActive ? "oi-ban" : "oi-circle-check")" aria-hidden="true"></span>
                                                    @(user.IsActive ? "השבתת משתמש" : "הפעלת משתמש")
                                                </button>
                                                <button class="um-row-action" @onclick="@(() => EditUser(user))">
                                                    <span class="oi oi-pencil" aria-hidden="true"></span>
                                                    עריכת פרטים
                                                </button>
                                            </div>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="um-table-footer">
            <span class="um-count">
                @{
                    var count = FilteredUsers.Count();
                }
                סה"כ @count משתמשים
                @if (!string.IsNullOrEmpty(_filterRole) || !string.IsNullOrEmpty(_filterStatus) ||
                     !string.IsNullOrEmpty(_searchQuery) || _filterCycle != "2025-2026")
                {
                    <span class="um-count-note">(מסוננים מתוך @_allUsers.Count)</span>
                }
            </span>
        </div>
    </div>

</div>

@code {

    // ─────────────────────────────────────────────────
    //  Data
    // ─────────────────────────────────────────────────
    private List<UserForAdmin> _allUsers = new();
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _allUsers = await _Auth.GetUsersByRoles("") ?? new List<UserForAdmin>();
        _loading = false;
    }

    // ─────────────────────────────────────────────────
    //  Filter / search state
    // ─────────────────────────────────────────────────
    private string _searchQuery  = "";
    private string _filterRole   = "";
    private string _filterCycle  = "2025-2026";   // default: current active cycle
    private string _filterStatus = "";

    private IEnumerable<UserForAdmin> FilteredUsers => _allUsers
        .Where(u => string.IsNullOrEmpty(_filterRole)
                    || u.Roles.Contains(_filterRole))
        .Where(u => string.IsNullOrEmpty(_filterCycle)
                    || u.AcademicYear == _filterCycle)
        .Where(u => string.IsNullOrEmpty(_filterStatus)
                    || (_filterStatus == "active"   &&  u.IsActive)
                    || (_filterStatus == "inactive" && !u.IsActive))
        .Where(u =>
        {
            if (string.IsNullOrEmpty(_searchQuery)) return true;
            var fullName = $"{u.FirstName} {u.LastName}";
            return fullName.Contains(_searchQuery,  StringComparison.OrdinalIgnoreCase)
                || u.Email.Contains(_searchQuery,   StringComparison.OrdinalIgnoreCase)
                || u.Phone.Contains(_searchQuery,   StringComparison.OrdinalIgnoreCase);
        });

    // ─────────────────────────────────────────────────
    //  Menu state
    // ─────────────────────────────────────────────────
    private bool _importMenuOpen = false;
    private int  _openRowMenuId  = -1;

    private void ToggleImportMenu()
    {
        _importMenuOpen = !_importMenuOpen;
        _openRowMenuId  = -1;
    }

    private void ToggleRowMenu(int userId)
    {
        _openRowMenuId  = _openRowMenuId == userId ? -1 : userId;
        _importMenuOpen = false;
    }

    private void CloseAllMenus()
    {
        _importMenuOpen = false;
        _openRowMenuId  = -1;
    }

    // ─────────────────────────────────────────────────
    //  Create user modal state
    // ─────────────────────────────────────────────────
    private bool   _createOpen    = false;
    private string _createFirstName = "";
    private string _createLastName  = "";
    private string _createEmail     = "";
    private string _createPhone     = "";
    private string _createYear      = "2025-2026";
    private string _createRole      = "Student";
    private string _createError     = "";
    private bool   _createSaving    = false;
    private bool   _createSuccess   = false;

    private void OpenCreate()
    {
        _createOpen      = true;
        _createFirstName = "";
        _createLastName  = "";
        _createEmail     = "";
        _createPhone     = "";
        _createYear      = "2025-2026";
        _createRole      = "Student";
        _createError     = "";
        _createSuccess   = false;
        _createSaving    = false;
        _importMenuOpen  = false;
    }

    private void CancelCreate()
    {
        if (_createSaving) return;
        _createOpen    = false;
        _createError   = "";
        _createSuccess = false;
    }

    private async Task SaveCreate()
    {
        _createError   = "";
        _createSuccess = false;

        if (string.IsNullOrWhiteSpace(_createFirstName))
        { _createError = "יש להזין שם פרטי"; return; }

        if (string.IsNullOrWhiteSpace(_createLastName))
        { _createError = "יש להזין שם משפחה"; return; }

        if (string.IsNullOrWhiteSpace(_createEmail))
        { _createError = "יש להזין כתובת מייל"; return; }

        if (!_createEmail.Contains('@') || !_createEmail.Contains('.'))
        { _createError = "כתובת מייל לא תקינה"; return; }

        _createSaving = true;

        var newUser = new UserAddedByAdmin
        {
            FirstName    = _createFirstName.Trim(),
            LastName     = _createLastName.Trim(),
            Email        = _createEmail.Trim().ToLower(),
            Phone        = _createPhone.Trim(),
            AcademicYear = _createYear,
            Role         = _createRole,
        };

        var result = await _Auth.AdminAddUser(newUser);
        _createSaving = false;

        if (result is null)
        {
            _createError = "שגיאה בלתי צפויה";
            return;
        }

        if (result.Result != AuthResults.Success)
        {
            _createError = result.Result switch
            {
                AuthResults.Exists          => "כתובת המייל כבר קיימת במערכת",
                AuthResults.EmailFailed     => "המשתמש נוצר אך שליחת המייל נכשלה",
                AuthResults.CreateUserFailed => "יצירת המשתמש נכשלה",
                _                           => result.Result
            };
            // EmailFailed is a partial success — user was created
            if (result.Result == AuthResults.EmailFailed && result.User is not null)
            {
                AddCreatedUserToList(result.User, newUser);
                _createSuccess = true;
            }
            return;
        }

        AddCreatedUserToList(result.User, newUser);
        _createSuccess = true;

        // Auto-close after a short visual confirmation
        await Task.Delay(1200);
        _createOpen    = false;
        _createSuccess = false;
    }

    private void AddCreatedUserToList(UserForAdmin serverUser, UserAddedByAdmin form)
    {
        // Use server-returned id; fill in form values the server doesn't echo back
        serverUser.Phone        = form.Phone;
        serverUser.AcademicYear = form.AcademicYear;
        if (!serverUser.Roles.Contains(form.Role))
            serverUser.Roles.Add(form.Role);
        serverUser.IsActive = true;
        _allUsers.Insert(0, serverUser);
    }

    // ─────────────────────────────────────────────────
    //  Edit modal state
    // ─────────────────────────────────────────────────
    private UserForAdmin? _editUser    = null;
    private string        _editFirstName = "";
    private string        _editLastName  = "";
    private string        _editPhone     = "";
    private string        _editYear      = "";
    private string        _editRole      = "";
    private string        _editError     = "";
    private bool          _editSaving    = false;

    // ─────────────────────────────────────────────────
    //  Row actions
    // ─────────────────────────────────────────────────
    private void ImportAction(string source) => _importMenuOpen = false;   // TODO: file upload dialog

    private void ToggleActive(UserForAdmin user)
    {
        // UI-only toggle — no persistence endpoint exists yet
        user.IsActive  = !user.IsActive;
        _openRowMenuId = -1;
    }

    private void EditUser(UserForAdmin user)
    {
        _openRowMenuId  = -1;
        _editUser       = user;
        _editFirstName  = user.FirstName ?? "";
        _editLastName   = user.LastName  ?? "";
        _editPhone      = user.Phone     ?? "";
        _editYear       = user.AcademicYear ?? "2025-2026";
        _editRole       = user.Roles.FirstOrDefault(r => r != "User") ?? "Student";
        _editError      = "";
        _editSaving     = false;
    }

    private void CancelEdit()
    {
        _editUser  = null;
        _editError = "";
    }

    private async Task SaveEdit()
    {
        if (string.IsNullOrWhiteSpace(_editFirstName) || string.IsNullOrWhiteSpace(_editLastName))
        {
            _editError = "שם פרטי ושם משפחה הם שדות חובה";
            return;
        }

        _editSaving = true;
        _editError  = "";

        var req = new AdminUpdateUserRequest
        {
            FirstName    = _editFirstName.Trim(),
            LastName     = _editLastName.Trim(),
            Phone        = _editPhone.Trim(),
            AcademicYear = _editYear,
            Role         = _editRole,
        };

        var error = await _Auth.UpdateUserAsync(_editUser!.Id, req);

        if (error is not null)
        {
            _editError  = error;
            _editSaving = false;
            return;
        }

        // Reflect changes locally so the table updates immediately
        _editUser.FirstName    = req.FirstName;
        _editUser.LastName     = req.LastName;
        _editUser.Phone        = req.Phone;
        _editUser.AcademicYear = req.AcademicYear;

        // Replace primary role in the local roles list (keep "User" if present)
        _editUser.Roles.RemoveAll(r => r != "User");
        if (!_editUser.Roles.Contains(req.Role))
            _editUser.Roles.Add(req.Role);

        _editSaving = false;
        _editUser   = null;
    }

    // ─────────────────────────────────────────────────
    //  Display helpers
    // ─────────────────────────────────────────────────
    private static string RoleLabel(string role) => role switch
    {
        "Student"  => "סטודנט",
        "Mentor"   => "מנחה",
        "Staff"    => "מרצה",
        "Lecturer" => "מרצה",
        "Admin"    => "מנהל",
        _          => role
    };

    private static string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[1][0]}"
            : parts[0][0].ToString();
    }
}
