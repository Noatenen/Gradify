@page "/management/projects"
@layout AppLayout
@attribute [Authorize(Roles = Roles.Admin + "," + Roles.Staff)]
@using AuthWithAdmin.Client.Services
@inject NavigationManager Nav
@inject IManagementService ManagementService

<div class="pm-page" @onclick="CloseAllMenus">

    <!-- ══════════════════════════════════════════
         TOP BAR
         ══════════════════════════════════════════ -->
    <div class="pm-topbar">
        <div class="pm-topbar-start">
            <button class="pm-back-btn" @onclick="@(() => Nav.NavigateTo("/management"))"
                    @onclick:stopPropagation="true" title="חזרה לניהול">
                <span class="oi oi-chevron-right" aria-hidden="true"></span>
            </button>
            <div>
                <div class="pm-breadcrumb">ניהול</div>
                <h1 class="pm-title">ניהול פרויקטים</h1>
            </div>
        </div>

        <div class="pm-topbar-end" @onclick:stopPropagation="true">
            <!-- Add project button -->
            <button class="pm-add-btn" @onclick="ToggleAddForm">
                <span class="oi oi-plus" aria-hidden="true"></span>
                פרויקט חדש
            </button>

            <!-- Import dropdown -->
            <div class="pm-import-wrap">
                <button class="pm-import-btn" @onclick="ToggleImportMenu">
                    <span class="oi oi-cloud-download" aria-hidden="true"></span>
                    ייבוא
                </button>

                @if (_importMenuOpen)
                {
                    <div class="pm-import-dropdown">
                        <div class="pm-import-section-label">העלאת קובץ</div>
                        <button class="pm-import-option" @onclick="@(() => ImportAction("csv"))">
                            <span class="oi oi-data-transfer-download" aria-hidden="true"></span>
                            ייבוא מ-CSV
                        </button>
                        <button class="pm-import-option" @onclick="@(() => ImportAction("xlsx"))">
                            <span class="oi oi-spreadsheet" aria-hidden="true"></span>
                            ייבוא מ-Excel / XLSX
                        </button>
                        <div class="pm-import-sep"></div>
                        <div class="pm-import-section-label">חיבור מערכות חיצוניות</div>
                        <button class="pm-import-option pm-import-option--soon" disabled>
                            <span class="oi oi-cloud-download" aria-hidden="true"></span>
                            ייבוא מ-Airtable
                            <span class="pm-soon-badge">בקרוב</span>
                        </button>
                        <button class="pm-import-option pm-import-option--soon" disabled>
                            <span class="oi oi-cloud-download" aria-hidden="true"></span>
                            ייבוא מ-Moodle
                            <span class="pm-soon-badge">בקרוב</span>
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- ══════════════════════════════════════════
         ADD PROJECT PANEL
         ══════════════════════════════════════════ -->
    @if (_showAddForm)
    {
        <div class="pm-add-panel" @onclick:stopPropagation="true">
            <div class="pm-add-panel-header">
                <span class="oi oi-plus" aria-hidden="true"></span>
                הוספת פרויקט חדש
            </div>

            <div class="pm-add-grid">
                <div class="pm-field">
                    <label class="pm-label">מספר פרויקט <span class="pm-required">*</span></label>
                    <input type="number" class="pm-input" @bind="_newProjectNumber" placeholder="לדוגמה: 101" min="1" />
                </div>

                <div class="pm-field">
                    <label class="pm-label">סוג פרויקט <span class="pm-required">*</span></label>
                    <select class="pm-input" @bind="_newProjectTypeId">
                        <option value="0">— בחר סוג —</option>
                        @foreach (var pt in _projectTypes)
                        {
                            <option value="@pt.Id">@pt.Name</option>
                        }
                    </select>
                </div>

                <div class="pm-field pm-field-full">
                    <label class="pm-label">שם פרויקט <span class="pm-required">*</span></label>
                    <input type="text" class="pm-input" @bind="_newTitle" placeholder="הזן שם פרויקט..." maxlength="200" />
                </div>

                <div class="pm-field pm-field-full">
                    <label class="pm-label">תיאור <span class="pm-optional">(אופציונלי)</span></label>
                    <input type="text" class="pm-input" @bind="_newDescription" placeholder="תיאור קצר..." maxlength="500" />
                </div>
            </div>

            @if (!string.IsNullOrEmpty(_addFormError))
            {
                <div class="pm-form-error">
                    <span class="oi oi-warning" aria-hidden="true"></span>
                    @_addFormError
                </div>
            }

            <div class="pm-add-panel-actions">
                <button class="pm-ghost-btn" @onclick="CancelAddForm" disabled="@_addSaving">ביטול</button>
                <button class="pm-add-btn pm-add-btn--save" @onclick="SubmitAddProject" disabled="@_addSaving">
                    @if (_addSaving) { <span class="pm-spinner-sm"></span> }
                    שמירה
                </button>
            </div>
        </div>
    }

    <!-- ══════════════════════════════════════════
         FILTERS BAR
         ══════════════════════════════════════════ -->
    <div class="pm-filters-bar">
        <div class="pm-search-wrap">
            <span class="oi oi-magnifying-glass pm-search-icon" aria-hidden="true"></span>
            <input class="pm-search"
                   type="text"
                   placeholder="חיפוש לפי שם, מספר פרויקט..."
                   @bind="_searchQuery"
                   @bind:event="oninput" />
        </div>
        <div class="pm-filters">
            <select class="pm-filter-select" @bind="_filterType">
                <option value="">כל הסוגים</option>
                @foreach (var pt in _projectTypes)
                {
                    <option value="@pt.Name">@pt.Name</option>
                }
            </select>
            <select class="pm-filter-select" @bind="_filterCycle">
                <option value="">כל המחזורים</option>
                @foreach (var yr in _distinctYears)
                {
                    <option value="@yr">@yr</option>
                }
            </select>
            <select class="pm-filter-select" @bind="_filterStatus">
                <option value="">כל הסטטוסים</option>
                <option value="Active">פעיל</option>
                <option value="Inactive">לא פעיל</option>
            </select>
        </div>
    </div>

    <!-- ══════════════════════════════════════════
         PROJECTS TABLE
         ══════════════════════════════════════════ -->
    <div class="pm-table-panel">
        <div class="pm-table-wrap">
            <table class="pm-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>שם פרויקט</th>
                        <th>סוג</th>
                        <th>צוות</th>
                        <th>מחזור</th>
                        <th>סטטוס</th>
                        <th class="pm-th-actions">פעולות</th>
                    </tr>
                </thead>
                <tbody>
                    @if (_loading)
                    {
                        <tr>
                            <td colspan="7" class="pm-empty">
                                <span class="pm-spinner-inline"></span>
                                טוען פרויקטים...
                            </td>
                        </tr>
                    }
                    else if (_loadError)
                    {
                        <tr>
                            <td colspan="7" class="pm-empty pm-empty--error">
                                <span class="oi oi-warning" aria-hidden="true"></span>
                                שגיאה בטעינת הפרויקטים. רענן את הדף.
                            </td>
                        </tr>
                    }
                    else if (!FilteredProjects.Any())
                    {
                        <tr>
                            <td colspan="7" class="pm-empty">
                                <span class="oi oi-magnifying-glass" aria-hidden="true"></span>
                                לא נמצאו פרויקטים התואמים את הסינון
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var proj in FilteredProjects)
                        {
                            <tr class="pm-row">
                                <td class="pm-cell-number">@proj.ProjectNumber</td>
                                <td class="pm-cell-name">
                                    <div class="pm-name-cell">
                                        <div class="pm-project-icon">
                                            <span class="oi oi-briefcase" aria-hidden="true"></span>
                                        </div>
                                        <div>
                                            <div class="pm-project-title">@proj.Title</div>
                                            @if (!string.IsNullOrWhiteSpace(proj.Description))
                                            {
                                                <div class="pm-project-desc">@proj.Description</div>
                                            }
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="pm-type-badge">@proj.ProjectType</span>
                                </td>
                                <td class="pm-cell-secondary">
                                    @if (proj.TeamSize > 0)
                                    {
                                        <span>@proj.TeamSize סטודנטים</span>
                                    }
                                    else
                                    {
                                        <span class="pm-no-team">ללא שיבוץ</span>
                                    }
                                </td>
                                <td class="pm-cell-secondary">
                                    @(string.IsNullOrEmpty(proj.AcademicYear) ? "—" : proj.AcademicYear)
                                </td>
                                <td>
                                    <span class="pm-status-badge @StatusClass(proj.Status)">
                                        @StatusLabel(proj.Status)
                                    </span>
                                </td>
                                <td class="pm-cell-actions" @onclick:stopPropagation="true">
                                    <div class="pm-actions-wrap">
                                        <button class="pm-dots-btn"
                                                @onclick="@(() => ToggleRowMenu(proj.Id))"
                                                title="פעולות נוספות">
                                            <span class="oi oi-ellipses" aria-hidden="true"></span>
                                        </button>
                                        @if (_openRowMenuId == proj.Id)
                                        {
                                            <div class="pm-row-menu">
                                                <button class="pm-row-action"
                                                        @onclick="@(() => ViewProject(proj))">
                                                    <span class="oi oi-eye" aria-hidden="true"></span>
                                                    צפייה בפרויקט
                                                </button>
                                                <button class="pm-row-action"
                                                        @onclick="@(() => EditProject(proj))">
                                                    <span class="oi oi-pencil" aria-hidden="true"></span>
                                                    עריכת פרטים
                                                </button>
                                                <div class="pm-row-menu-sep"></div>
                                                <button class="pm-row-action @(proj.Status == "Active" ? "pm-row-action--danger" : "")"
                                                        @onclick="@(() => ToggleStatus(proj))">
                                                    <span class="oi @(proj.Status == "Active" ? "oi-ban" : "oi-circle-check")" aria-hidden="true"></span>
                                                    @(proj.Status == "Active" ? "השבתת פרויקט" : "הפעלת פרויקט")
                                                </button>
                                            </div>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="pm-table-footer">
            <span class="pm-count">
                @{var count = FilteredProjects.Count();}
                סה"כ @count פרויקטים
                @if (!string.IsNullOrEmpty(_filterType) || !string.IsNullOrEmpty(_filterCycle) ||
                     !string.IsNullOrEmpty(_filterStatus) || !string.IsNullOrEmpty(_searchQuery))
                {
                    <span class="pm-count-note">(מסוננים מתוך @_allProjects.Count)</span>
                }
            </span>
        </div>
    </div>

</div>

@code {

    // ─────────────────────────────────────────────────
    //  Data
    // ─────────────────────────────────────────────────
    private List<ProjectManagementDto>  _allProjects  = new();
    private List<ProjectTypeOptionDto>  _projectTypes = new();
    private IEnumerable<string>         _distinctYears = Array.Empty<string>();
    private bool _loading   = true;
    private bool _loadError = false;

    protected override async Task OnInitializedAsync()
    {
        var projectsTask = ManagementService.GetProjectsAsync();
        var typesTask    = ManagementService.GetProjectTypesAsync();

        await Task.WhenAll(projectsTask, typesTask);

        var projects = await projectsTask;
        _loadError   = projects is null;
        _allProjects = projects ?? new List<ProjectManagementDto>();
        _projectTypes = await typesTask;

        _distinctYears = _allProjects
            .Select(p => p.AcademicYear)
            .Where(y => !string.IsNullOrEmpty(y))
            .Distinct()
            .OrderByDescending(y => y);

        _loading = false;
    }

    // ─────────────────────────────────────────────────
    //  Filter / search state
    // ─────────────────────────────────────────────────
    private string _searchQuery  = "";
    private string _filterType   = "";
    private string _filterCycle  = "";
    private string _filterStatus = "";

    private IEnumerable<ProjectManagementDto> FilteredProjects => _allProjects
        .Where(p => string.IsNullOrEmpty(_filterType)
                    || p.ProjectType == _filterType)
        .Where(p => string.IsNullOrEmpty(_filterCycle)
                    || p.AcademicYear == _filterCycle)
        .Where(p => string.IsNullOrEmpty(_filterStatus)
                    || p.Status == _filterStatus)
        .Where(p =>
        {
            if (string.IsNullOrEmpty(_searchQuery)) return true;
            return p.Title.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase)
                || p.ProjectNumber.ToString().Contains(_searchQuery);
        });

    // ─────────────────────────────────────────────────
    //  Menu state
    // ─────────────────────────────────────────────────
    private bool _importMenuOpen = false;
    private int  _openRowMenuId  = -1;

    private void ToggleImportMenu()
    {
        _importMenuOpen = !_importMenuOpen;
        _openRowMenuId  = -1;
    }

    private void ToggleRowMenu(int id)
    {
        _openRowMenuId  = _openRowMenuId == id ? -1 : id;
        _importMenuOpen = false;
    }

    private void CloseAllMenus()
    {
        _importMenuOpen = false;
        _openRowMenuId  = -1;
    }

    // ─────────────────────────────────────────────────
    //  Add project panel
    // ─────────────────────────────────────────────────
    private bool   _showAddForm       = false;
    private bool   _addSaving         = false;
    private string _addFormError      = "";
    private int    _newProjectNumber;
    private string _newTitle          = "";
    private string _newDescription    = "";
    private int    _newProjectTypeId;

    private void ToggleAddForm()
    {
        _showAddForm  = !_showAddForm;
        _addFormError = "";
        if (!_showAddForm) ResetAddForm();
    }

    private void CancelAddForm()
    {
        _showAddForm = false;
        ResetAddForm();
    }

    private void ResetAddForm()
    {
        _newProjectNumber = 0;
        _newTitle         = "";
        _newDescription   = "";
        _newProjectTypeId = 0;
        _addFormError     = "";
    }

    private async Task SubmitAddProject()
    {
        _addFormError = "";

        if (_newProjectNumber <= 0)            { _addFormError = "יש להזין מספר פרויקט תקין";  return; }
        if (string.IsNullOrWhiteSpace(_newTitle)) { _addFormError = "שם הפרויקט הוא שדה חובה"; return; }
        if (_newProjectTypeId <= 0)            { _addFormError = "יש לבחור סוג פרויקט";        return; }

        _addSaving = true;

        bool ok = await ManagementService.CreateProjectAsync(new CreateProjectRequest
        {
            ProjectNumber = _newProjectNumber,
            Title         = _newTitle.Trim(),
            Description   = string.IsNullOrWhiteSpace(_newDescription) ? null : _newDescription.Trim(),
            ProjectTypeId = _newProjectTypeId,
        });

        _addSaving = false;

        if (!ok)
        {
            _addFormError = "שגיאה ביצירת הפרויקט. ייתכן שמספר הפרויקט כבר קיים.";
            return;
        }

        _showAddForm = false;
        ResetAddForm();

        // Reload list
        _loading = true;
        var projects  = await ManagementService.GetProjectsAsync();
        _allProjects  = projects ?? _allProjects;
        _distinctYears = _allProjects
            .Select(p => p.AcademicYear)
            .Where(y => !string.IsNullOrEmpty(y))
            .Distinct()
            .OrderByDescending(y => y);
        _loading = false;
    }

    // ─────────────────────────────────────────────────
    //  Row actions
    // ─────────────────────────────────────────────────
    private void ImportAction(string source) => _importMenuOpen = false; // TODO: file-upload dialog

    private void ViewProject(ProjectManagementDto proj)
    {
        _openRowMenuId = -1;
        Nav.NavigateTo($"/management/projects/{proj.Id}");   // future detail page
    }

    private void EditProject(ProjectManagementDto proj)
    {
        _openRowMenuId = -1;
        // TODO: open edit modal — will be implemented in the next iteration
    }

    private async Task ToggleStatus(ProjectManagementDto proj)
    {
        _openRowMenuId = -1;
        string newStatus = proj.Status == "Active" ? "Inactive" : "Active";

        bool ok = await ManagementService.UpdateProjectStatusAsync(proj.Id, newStatus);
        if (ok) proj.Status = newStatus;
    }

    // ─────────────────────────────────────────────────
    //  Display helpers
    // ─────────────────────────────────────────────────
    private static string StatusClass(string status) => status switch
    {
        "Active"   => "pm-status--active",
        "Inactive" => "pm-status--inactive",
        _          => "pm-status--other",
    };

    private static string StatusLabel(string status) => status switch
    {
        "Active"   => "פעיל",
        "Inactive" => "לא פעיל",
        "Archived" => "בארכיון",
        _          => status,
    };
}