@page "/management/projects"
@layout AppLayout
@attribute [Authorize(Roles = Roles.Admin + "," + Roles.Staff)]
@using AuthWithAdmin.Client.Services
@inject NavigationManager Nav
@inject IManagementService ManagementService

<!-- ══════════════════════════════════════════
     EDIT PROJECT MODAL  (always edit mode)
     ══════════════════════════════════════════ -->
@if (_editProject is not null)
{
    <div class="pm-modal-overlay" @onclick="CloseEdit">
        <div class="pm-modal-box pm-modal-box--wide" @onclick:stopPropagation="true">

            <!-- Header -->
            <div class="pm-modal-header">
                <div class="pm-modal-header-info">
                    <div class="pm-modal-number-badge">#@_editProject.ProjectNumber</div>
                    <div class="pm-modal-header-label">עריכת פרויקט</div>
                </div>
                <div class="pm-modal-header-actions">
                    <button class="pm-modal-save-btn" @onclick="SaveEdit" disabled="@_editSaving">
                        @if (_editSaving)
                        {
                            <span class="pm-spinner-sm"></span>
                        }
                        else
                        {
                            <span class="oi oi-check" aria-hidden="true"></span>
                        }
                        שמירה
                    </button>
                    <button class="pm-modal-cancel-btn" @onclick="CloseEdit" disabled="@_editSaving">ביטול</button>
                    <button class="pm-modal-close-btn" @onclick="CloseEdit" title="סגירה" disabled="@_editSaving">
                        <span class="oi oi-x" aria-hidden="true"></span>
                    </button>
                </div>
            </div>

            <!-- Error banner -->
            @if (!string.IsNullOrEmpty(_editError))
            {
                <div class="pm-modal-error-bar">
                    <span class="oi oi-warning" aria-hidden="true"></span>
                    @_editError
                </div>
            }

            <!-- Body -->
            <div class="pm-modal-body">

                <!-- ── פרטי בסיס ──────────────────────────────────── -->
                <div class="pm-edit-section">
                    <div class="pm-edit-section-title">פרטי בסיס</div>
                    <div class="pm-edit-grid">

                        <div class="pm-edit-field">
                            <label class="pm-edit-label">מספר פרויקט <span class="pm-required">*</span></label>
                            <input type="number" class="pm-edit-input" @bind="_editNumber" min="1" />
                        </div>

                        <div class="pm-edit-field">
                            <label class="pm-edit-label">סוג פרויקט <span class="pm-required">*</span></label>
                            <select class="pm-edit-input" @bind="_editTypeId">
                                <option value="0">— בחר סוג —</option>
                                @foreach (var pt in _projectTypes)
                                {
                                    <option value="@pt.Id">@pt.Name</option>
                                }
                            </select>
                        </div>

                        <div class="pm-edit-field">
                            <label class="pm-edit-label">סטטוס</label>
                            <select class="pm-edit-input" @bind="_editStatus">
                                <option value="Active">פעיל</option>
                                <option value="Inactive">לא פעיל</option>
                                <option value="Archived">בארכיון</option>
                                <option value="Available">זמין לשיבוץ</option>
                                <option value="Unavailable">לא זמין</option>
                            </select>
                        </div>

                        <div class="pm-edit-field">
                            <label class="pm-edit-label">עדיפות</label>
                            <select class="pm-edit-input" @bind="_editPriority">
                                <option value="">— ללא —</option>
                                <option value="Low">נמוכה</option>
                                <option value="Normal">רגילה</option>
                                <option value="High">גבוהה</option>
                                <option value="Urgent">דחוף</option>
                            </select>
                        </div>

                    </div>
                </div>

                <!-- ── תוכן הפרויקט ───────────────────────────────── -->
                <div class="pm-edit-section">
                    <div class="pm-edit-section-title">תוכן הפרויקט</div>

                    <div class="pm-edit-field">
                        <label class="pm-edit-label">שם הפרויקט <span class="pm-required">*</span></label>
                        <input type="text" class="pm-edit-input" @bind="_editTitle" maxlength="200" placeholder="שם הפרויקט..." />
                    </div>

                    <div class="pm-edit-field">
                        <label class="pm-edit-label">תיאור</label>
                        <textarea class="pm-edit-textarea" @bind="_editDescription" rows="3" maxlength="500" placeholder="תיאור קצר של הפרויקט..."></textarea>
                    </div>

                    <div class="pm-edit-field">
                        <label class="pm-edit-label">מטרות הפרויקט</label>
                        <textarea class="pm-edit-textarea" @bind="_editGoals" rows="3" placeholder="פרט את המטרות והתפוקות הצפויות..."></textarea>
                    </div>

                    <div class="pm-edit-field">
                        <label class="pm-edit-label">קהל יעד</label>
                        <input type="text" class="pm-edit-input" @bind="_editTargetAudience" placeholder="למי מיועד הפרויקט?" />
                    </div>

                </div>

                <!-- ── ארגון / לקוח ───────────────────────────────── -->
                <div class="pm-edit-section">
                    <div class="pm-edit-section-title">ארגון / לקוח</div>

                    <div class="pm-edit-field">
                        <label class="pm-edit-label">שם הארגון</label>
                        <input type="text" class="pm-edit-input" @bind="_editOrgName" placeholder="שם הארגון / חברה..." />
                    </div>

                    <div class="pm-edit-grid">
                        <div class="pm-edit-field">
                            <label class="pm-edit-label">איש קשר</label>
                            <input type="text" class="pm-edit-input" @bind="_editContact" placeholder="שם איש הקשר..." />
                        </div>
                        <div class="pm-edit-field">
                            <label class="pm-edit-label">תפקיד איש הקשר</label>
                            <input type="text" class="pm-edit-input" @bind="_editContactRole" placeholder="לדוגמה: מנהל IT..." />
                        </div>
                    </div>

                </div>

                <!-- ── מידע פנימי ─────────────────────────────────── -->
                <div class="pm-edit-section">
                    <div class="pm-edit-section-title">מידע פנימי</div>

                    <div class="pm-edit-field">
                        <label class="pm-edit-label">הערות פנימיות</label>
                        <textarea class="pm-edit-textarea" @bind="_editNotes" rows="3" placeholder="הערות לשימוש פנימי בלבד..."></textarea>
                    </div>

                </div>

            </div>

            <!-- Footer (repeat save actions for long forms) -->
            <div class="pm-modal-footer">
                <button class="pm-modal-save-btn" @onclick="SaveEdit" disabled="@_editSaving">
                    @if (_editSaving) { <span class="pm-spinner-sm"></span> }
                    else { <span class="oi oi-check" aria-hidden="true"></span> }
                    שמירה
                </button>
                <button class="pm-modal-cancel-btn" @onclick="CloseEdit" disabled="@_editSaving">ביטול</button>
                @if (_editSuccess)
                {
                    <span class="pm-modal-success-msg">
                        <span class="oi oi-check" aria-hidden="true"></span>
                        הפרויקט עודכן בהצלחה
                    </span>
                }
            </div>

        </div>
    </div>
}

<!-- ══════════════════════════════════════════
     VIEW PROJECT MODAL  (read-only details)
     ══════════════════════════════════════════ -->
@if (_viewProject is not null)
{
    <div class="pm-modal-overlay" @onclick="CloseView">
        <div class="pm-modal-box pm-modal-box--wide" @onclick:stopPropagation="true">

            <!-- Header -->
            <div class="pm-modal-header">
                <div class="pm-modal-header-info">
                    <div class="pm-modal-number-badge">#@_viewProject.ProjectNumber</div>
                    <div>
                        <div class="pm-modal-view-title">@_viewProject.Title</div>
                        <div class="pm-modal-view-meta">
                            <span class="pm-type-badge">@_viewProject.ProjectType</span>
                            <span class="pm-status-badge @StatusClass(_viewProject.Status)">@StatusLabel(_viewProject.Status)</span>
                        </div>
                    </div>
                </div>
                <div class="pm-modal-header-actions">
                    <button class="pm-modal-edit-btn" @onclick="OpenEditFromView">
                        <span class="oi oi-pencil" aria-hidden="true"></span>
                        עריכת פרויקט
                    </button>
                    <button class="pm-modal-close-btn" @onclick="CloseView" title="סגירה">
                        <span class="oi oi-x" aria-hidden="true"></span>
                    </button>
                </div>
            </div>

            <!-- Body -->
            <div class="pm-modal-body">

                <div class="pm-edit-section">
                    <div class="pm-edit-section-title">פרטי בסיס</div>
                    <div class="pm-detail-grid">
                        <div class="pm-detail-field">
                            <div class="pm-detail-label">מספר פרויקט</div>
                            <div class="pm-detail-value">@_viewProject.ProjectNumber</div>
                        </div>
                        <div class="pm-detail-field">
                            <div class="pm-detail-label">סוג פרויקט</div>
                            <div class="pm-detail-value"><span class="pm-type-badge">@_viewProject.ProjectType</span></div>
                        </div>
                        <div class="pm-detail-field">
                            <div class="pm-detail-label">סטטוס</div>
                            <div class="pm-detail-value"><span class="pm-status-badge @StatusClass(_viewProject.Status)">@StatusLabel(_viewProject.Status)</span></div>
                        </div>
                        <div class="pm-detail-field">
                            <div class="pm-detail-label">עדיפות</div>
                            <div class="pm-detail-value">@PriorityLabel(_viewProject.Priority)</div>
                        </div>
                    </div>
                </div>

                <div class="pm-edit-section">
                    <div class="pm-edit-section-title">תוכן הפרויקט</div>
                    <div class="pm-detail-field">
                        <div class="pm-detail-label">שם הפרויקט</div>
                        <div class="pm-detail-value pm-detail-value--prominent">@_viewProject.Title</div>
                    </div>
                    <div class="pm-detail-field">
                        <div class="pm-detail-label">תיאור</div>
                        <div class="pm-detail-value pm-detail-value--multiline">@(string.IsNullOrWhiteSpace(_viewProject.Description) ? "—" : _viewProject.Description)</div>
                    </div>
                    <div class="pm-detail-field">
                        <div class="pm-detail-label">מטרות</div>
                        <div class="pm-detail-value pm-detail-value--multiline">@(string.IsNullOrWhiteSpace(_viewProject.Goals) ? "—" : _viewProject.Goals)</div>
                    </div>
                    <div class="pm-detail-field">
                        <div class="pm-detail-label">קהל יעד</div>
                        <div class="pm-detail-value">@(string.IsNullOrWhiteSpace(_viewProject.TargetAudience) ? "—" : _viewProject.TargetAudience)</div>
                    </div>
                </div>

                <div class="pm-edit-section">
                    <div class="pm-edit-section-title">ארגון / לקוח</div>
                    <div class="pm-detail-grid">
                        <div class="pm-detail-field">
                            <div class="pm-detail-label">שם הארגון</div>
                            <div class="pm-detail-value">@(string.IsNullOrWhiteSpace(_viewProject.OrganizationName) ? "—" : _viewProject.OrganizationName)</div>
                        </div>
                        <div class="pm-detail-field">
                            <div class="pm-detail-label">איש קשר</div>
                            <div class="pm-detail-value">@(string.IsNullOrWhiteSpace(_viewProject.ContactPerson) ? "—" : _viewProject.ContactPerson)</div>
                        </div>
                        <div class="pm-detail-field">
                            <div class="pm-detail-label">תפקיד איש הקשר</div>
                            <div class="pm-detail-value">@(string.IsNullOrWhiteSpace(_viewProject.ContactRole) ? "—" : _viewProject.ContactRole)</div>
                        </div>
                    </div>
                </div>

                <div class="pm-edit-section">
                    <div class="pm-edit-section-title">צוות</div>
                    <div class="pm-detail-grid">
                        <div class="pm-detail-field">
                            <div class="pm-detail-label">סטודנטים</div>
                            <div class="pm-detail-value">@((_viewProject.TeamSize > 0) ? $"{_viewProject.TeamSize} סטודנטים" : "ללא שיבוץ")</div>
                        </div>
                        <div class="pm-detail-field">
                            <div class="pm-detail-label">מחזור אקדמי</div>
                            <div class="pm-detail-value">@(string.IsNullOrWhiteSpace(_viewProject.AcademicYear) ? "—" : _viewProject.AcademicYear)</div>
                        </div>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(_viewProject.InternalNotes))
                {
                    <div class="pm-edit-section">
                        <div class="pm-edit-section-title">הערות פנימיות</div>
                        <div class="pm-detail-field">
                            <div class="pm-detail-value pm-detail-value--multiline">@_viewProject.InternalNotes</div>
                        </div>
                    </div>
                }

            </div>

        </div>
    </div>
}

<div class="pm-page" @onclick="CloseAllMenus">

    <!-- ══════════════════════════════════════════
         TOP BAR
         ══════════════════════════════════════════ -->
    <div class="pm-topbar">
        <div class="pm-topbar-start">
            <button class="pm-back-btn" @onclick="@(() => Nav.NavigateTo("/management"))"
                    @onclick:stopPropagation="true" title="חזרה לניהול">
                <span class="oi oi-chevron-right" aria-hidden="true"></span>
            </button>
            <div>
                <div class="pm-breadcrumb">ניהול</div>
                <h1 class="pm-title">ניהול פרויקטים</h1>
            </div>
        </div>

        <div class="pm-topbar-end" @onclick:stopPropagation="true">
            <button class="pm-add-btn" @onclick="ToggleAddForm">
                <span class="oi oi-plus" aria-hidden="true"></span>
                פרויקט חדש
            </button>

            <div class="pm-import-wrap">
                <button class="pm-import-btn" @onclick="ToggleImportMenu">
                    <span class="oi oi-cloud-download" aria-hidden="true"></span>
                    ייבוא
                </button>

                @if (_importMenuOpen)
                {
                    <div class="pm-import-dropdown">
                        <div class="pm-import-section-label">העלאת קובץ</div>
                        <button class="pm-import-option" @onclick="@(() => ImportAction("csv"))">
                            <span class="oi oi-data-transfer-download" aria-hidden="true"></span>
                            ייבוא מ-CSV
                        </button>
                        <button class="pm-import-option" @onclick="@(() => ImportAction("xlsx"))">
                            <span class="oi oi-spreadsheet" aria-hidden="true"></span>
                            ייבוא מ-Excel / XLSX
                        </button>
                        <div class="pm-import-sep"></div>
                        <div class="pm-import-section-label">חיבור מערכות חיצוניות</div>
                        <button class="pm-import-option pm-import-option--soon" disabled>
                            <span class="oi oi-cloud-download" aria-hidden="true"></span>
                            ייבוא מ-Moodle
                            <span class="pm-soon-badge">בקרוב</span>
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- ══════════════════════════════════════════
         ADD PROJECT PANEL
         ══════════════════════════════════════════ -->
    @if (_showAddForm)
    {
        <div class="pm-add-panel" @onclick:stopPropagation="true">
            <div class="pm-add-panel-header">
                <span class="oi oi-plus" aria-hidden="true"></span>
                הוספת פרויקט חדש
            </div>

            <div class="pm-add-grid">
                <div class="pm-field">
                    <label class="pm-label">מספר פרויקט <span class="pm-required">*</span></label>
                    <input type="number" class="pm-input" @bind="_newProjectNumber" placeholder="לדוגמה: 101" min="1" />
                </div>
                <div class="pm-field">
                    <label class="pm-label">סוג פרויקט <span class="pm-required">*</span></label>
                    <select class="pm-input" @bind="_newProjectTypeId">
                        <option value="0">— בחר סוג —</option>
                        @foreach (var pt in _projectTypes)
                        {
                            <option value="@pt.Id">@pt.Name</option>
                        }
                    </select>
                </div>
                <div class="pm-field pm-field-full">
                    <label class="pm-label">שם פרויקט <span class="pm-required">*</span></label>
                    <input type="text" class="pm-input" @bind="_newTitle" placeholder="הזן שם פרויקט..." maxlength="200" />
                </div>
                <div class="pm-field pm-field-full">
                    <label class="pm-label">תיאור <span class="pm-optional">(אופציונלי)</span></label>
                    <input type="text" class="pm-input" @bind="_newDescription" placeholder="תיאור קצר..." maxlength="500" />
                </div>
            </div>

            @if (!string.IsNullOrEmpty(_addFormError))
            {
                <div class="pm-form-error">
                    <span class="oi oi-warning" aria-hidden="true"></span>
                    @_addFormError
                </div>
            }

            <div class="pm-add-panel-actions">
                <button class="pm-ghost-btn" @onclick="CancelAddForm" disabled="@_addSaving">ביטול</button>
                <button class="pm-add-btn pm-add-btn--save" @onclick="SubmitAddProject" disabled="@_addSaving">
                    @if (_addSaving) { <span class="pm-spinner-sm"></span> }
                    שמירה
                </button>
            </div>
        </div>
    }

    <!-- ══════════════════════════════════════════
         FILTERS BAR
         ══════════════════════════════════════════ -->
    <div class="pm-filters-bar">
        <div class="pm-search-wrap">
            <span class="oi oi-magnifying-glass pm-search-icon" aria-hidden="true"></span>
            <input class="pm-search"
                   type="text"
                   placeholder="חיפוש לפי שם, מספר פרויקט..."
                   @bind="_searchQuery"
                   @bind:event="oninput" />
        </div>
        <div class="pm-filters">
            <select class="pm-filter-select" @bind="_filterType">
                <option value="">כל הסוגים</option>
                @foreach (var pt in _projectTypes)
                {
                    <option value="@pt.Name">@pt.Name</option>
                }
            </select>
            <select class="pm-filter-select" @bind="_filterCycle">
                <option value="">כל המחזורים</option>
                @foreach (var yr in _distinctYears)
                {
                    <option value="@yr">@yr</option>
                }
            </select>
            <select class="pm-filter-select" @bind="_filterStatus">
                <option value="">כל הסטטוסים</option>
                <option value="Active">פעיל</option>
                <option value="Inactive">לא פעיל</option>
            </select>
        </div>
    </div>

    <!-- ══════════════════════════════════════════
         PROJECTS TABLE
         ══════════════════════════════════════════ -->
    <div class="pm-table-panel">
        <div class="pm-table-wrap">
            <table class="pm-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>שם פרויקט</th>
                        <th>סוג</th>
                        <th>צוות</th>
                        <th>מחזור</th>
                        <th>סטטוס</th>
                        <th class="pm-th-actions">פעולות</th>
                    </tr>
                </thead>
                <tbody>
                    @if (_loading)
                    {
                        <tr>
                            <td colspan="7" class="pm-empty">
                                <span class="pm-spinner-inline"></span>
                                טוען פרויקטים...
                            </td>
                        </tr>
                    }
                    else if (_loadError)
                    {
                        <tr>
                            <td colspan="7" class="pm-empty pm-empty--error">
                                <span class="oi oi-warning" aria-hidden="true"></span>
                                שגיאה בטעינת הפרויקטים. רענן את הדף.
                            </td>
                        </tr>
                    }
                    else if (!FilteredProjects.Any())
                    {
                        <tr>
                            <td colspan="7" class="pm-empty">
                                <span class="oi oi-magnifying-glass" aria-hidden="true"></span>
                                לא נמצאו פרויקטים התואמים את הסינון
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var proj in FilteredProjects)
                        {
                            <tr class="pm-row">
                                <td class="pm-cell-number">@proj.ProjectNumber</td>
                                <td class="pm-cell-name">
                                    <div class="pm-name-cell">
                                        <div class="pm-project-icon">
                                            <span class="oi oi-briefcase" aria-hidden="true"></span>
                                        </div>
                                        <div>
                                            <div class="pm-project-title">@proj.Title</div>
                                            @if (!string.IsNullOrWhiteSpace(proj.Description))
                                            {
                                                <div class="pm-project-desc">@proj.Description</div>
                                            }
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="pm-type-badge">@proj.ProjectType</span>
                                </td>
                                <td class="pm-cell-secondary">
                                    @if (proj.TeamSize > 0)
                                    {
                                        <span>@proj.TeamSize סטודנטים</span>
                                    }
                                    else
                                    {
                                        <span class="pm-no-team">ללא שיבוץ</span>
                                    }
                                </td>
                                <td class="pm-cell-secondary">
                                    @(string.IsNullOrEmpty(proj.AcademicYear) ? "—" : proj.AcademicYear)
                                </td>
                                <td>
                                    <span class="pm-status-badge @StatusClass(proj.Status)">
                                        @StatusLabel(proj.Status)
                                    </span>
                                </td>
                                <td class="pm-cell-actions" @onclick:stopPropagation="true">
                                    <!-- Inline edit button (always visible) -->
                                    <button class="pm-edit-inline-btn"
                                            @onclick="@(() => OpenEdit(proj))"
                                            title="עריכת פרויקט">
                                        <span class="oi oi-pencil" aria-hidden="true"></span>
                                    </button>

                                    <!-- Dots menu -->
                                    <div class="pm-actions-wrap">
                                        <button class="pm-dots-btn"
                                                @onclick="@(() => ToggleRowMenu(proj.Id))"
                                                title="פעולות נוספות">
                                            <span class="oi oi-ellipses" aria-hidden="true"></span>
                                        </button>
                                        @if (_openRowMenuId == proj.Id)
                                        {
                                            <div class="pm-row-menu">
                                                <button class="pm-row-action"
                                                        @onclick="@(() => OpenView(proj))">
                                                    <span class="oi oi-eye" aria-hidden="true"></span>
                                                    צפייה בפרויקט
                                                </button>
                                                <button class="pm-row-action"
                                                        @onclick="@(() => OpenEdit(proj))">
                                                    <span class="oi oi-pencil" aria-hidden="true"></span>
                                                    עריכת פרויקט
                                                </button>
                                                <div class="pm-row-menu-sep"></div>
                                                <button class="pm-row-action @(proj.Status == "Active" ? "pm-row-action--danger" : "")"
                                                        @onclick="@(() => ToggleStatus(proj))">
                                                    <span class="oi @(proj.Status == "Active" ? "oi-ban" : "oi-circle-check")" aria-hidden="true"></span>
                                                    @(proj.Status == "Active" ? "השבתת פרויקט" : "הפעלת פרויקט")
                                                </button>
                                            </div>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="pm-table-footer">
            <span class="pm-count">
                @{var count = FilteredProjects.Count();}
                סה"כ @count פרויקטים
                @if (!string.IsNullOrEmpty(_filterType) || !string.IsNullOrEmpty(_filterCycle) ||
                     !string.IsNullOrEmpty(_filterStatus) || !string.IsNullOrEmpty(_searchQuery))
                {
                    <span class="pm-count-note">(מסוננים מתוך @_allProjects.Count)</span>
                }
            </span>
        </div>
    </div>

</div>

@code {

    // ─────────────────────────────────────────────────
    //  Data
    // ─────────────────────────────────────────────────
    private List<ProjectManagementDto>  _allProjects   = new();
    private List<ProjectTypeOptionDto>  _projectTypes  = new();
    private IEnumerable<string>         _distinctYears = Array.Empty<string>();
    private bool _loading   = true;
    private bool _loadError = false;

    protected override async Task OnInitializedAsync()
    {
        var projectsTask = ManagementService.GetProjectsAsync();
        var typesTask    = ManagementService.GetProjectTypesAsync();
        await Task.WhenAll(projectsTask, typesTask);

        var projects = await projectsTask;
        _loadError    = projects is null;
        _allProjects  = projects ?? new List<ProjectManagementDto>();
        _projectTypes = await typesTask;

        _distinctYears = _allProjects
            .Select(p => p.AcademicYear)
            .Where(y => !string.IsNullOrEmpty(y))
            .Distinct()
            .OrderByDescending(y => y);

        _loading = false;
    }

    // ─────────────────────────────────────────────────
    //  Filter / search
    // ─────────────────────────────────────────────────
    private string _searchQuery  = "";
    private string _filterType   = "";
    private string _filterCycle  = "";
    private string _filterStatus = "";

    private IEnumerable<ProjectManagementDto> FilteredProjects => _allProjects
        .Where(p => string.IsNullOrEmpty(_filterType)   || p.ProjectType == _filterType)
        .Where(p => string.IsNullOrEmpty(_filterCycle)  || p.AcademicYear == _filterCycle)
        .Where(p => string.IsNullOrEmpty(_filterStatus) || p.Status == _filterStatus)
        .Where(p =>
        {
            if (string.IsNullOrEmpty(_searchQuery)) return true;
            return p.Title.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase)
                || p.ProjectNumber.ToString().Contains(_searchQuery);
        });

    // ─────────────────────────────────────────────────
    //  Menu state
    // ─────────────────────────────────────────────────
    private bool _importMenuOpen = false;
    private int  _openRowMenuId  = -1;

    private void ToggleImportMenu() { _importMenuOpen = !_importMenuOpen; _openRowMenuId = -1; }
    private void ToggleRowMenu(int id) { _openRowMenuId = _openRowMenuId == id ? -1 : id; _importMenuOpen = false; }
    private void CloseAllMenus()   { _importMenuOpen = false; _openRowMenuId = -1; }

    // ─────────────────────────────────────────────────
    //  Add project panel
    // ─────────────────────────────────────────────────
    private bool   _showAddForm    = false;
    private bool   _addSaving      = false;
    private string _addFormError   = "";
    private int    _newProjectNumber;
    private string _newTitle       = "";
    private string _newDescription = "";
    private int    _newProjectTypeId;

    private void ToggleAddForm()  { _showAddForm = !_showAddForm; _addFormError = ""; if (!_showAddForm) ResetAddForm(); }
    private void CancelAddForm()  { _showAddForm = false; ResetAddForm(); }

    private void ResetAddForm()
    {
        _newProjectNumber = 0; _newTitle = ""; _newDescription = ""; _newProjectTypeId = 0; _addFormError = "";
    }

    private async Task SubmitAddProject()
    {
        _addFormError = "";
        if (_newProjectNumber <= 0)               { _addFormError = "יש להזין מספר פרויקט תקין";  return; }
        if (string.IsNullOrWhiteSpace(_newTitle)) { _addFormError = "שם הפרויקט הוא שדה חובה";   return; }
        if (_newProjectTypeId <= 0)               { _addFormError = "יש לבחור סוג פרויקט";        return; }

        _addSaving = true;
        bool ok = await ManagementService.CreateProjectAsync(new CreateProjectRequest
        {
            ProjectNumber = _newProjectNumber,
            Title         = _newTitle.Trim(),
            Description   = string.IsNullOrWhiteSpace(_newDescription) ? null : _newDescription.Trim(),
            ProjectTypeId = _newProjectTypeId,
        });
        _addSaving = false;

        if (!ok) { _addFormError = "שגיאה ביצירת הפרויקט. ייתכן שמספר הפרויקט כבר קיים."; return; }

        _showAddForm = false;
        ResetAddForm();
        await ReloadProjectsAsync();
    }

    private async Task ReloadProjectsAsync()
    {
        _loading = true;
        var projects = await ManagementService.GetProjectsAsync();
        _allProjects   = projects ?? _allProjects;
        _distinctYears = _allProjects
            .Select(p => p.AcademicYear)
            .Where(y => !string.IsNullOrEmpty(y))
            .Distinct()
            .OrderByDescending(y => y);
        _loading = false;
    }

    // ─────────────────────────────────────────────────
    //  View modal (read-only)
    // ─────────────────────────────────────────────────
    private ProjectManagementDto? _viewProject = null;

    private void OpenView(ProjectManagementDto proj)
    {
        _openRowMenuId = -1;
        _viewProject   = proj;
    }

    private void CloseView() => _viewProject = null;

    private void OpenEditFromView()
    {
        var proj = _viewProject;
        _viewProject = null;
        if (proj is not null) OpenEdit(proj);
    }

    // ─────────────────────────────────────────────────
    //  Edit modal (always edit mode)
    // ─────────────────────────────────────────────────
    private ProjectManagementDto? _editProject  = null;
    private bool   _editSaving  = false;
    private bool   _editSuccess = false;
    private string _editError   = "";

    // Form fields
    private int    _editNumber         = 0;
    private string _editTitle          = "";
    private string _editDescription    = "";
    private int    _editTypeId         = 0;
    private string _editStatus         = "";
    private string _editPriority       = "";
    private string _editOrgName        = "";
    private string _editContact        = "";
    private string _editContactRole    = "";
    private string _editGoals          = "";
    private string _editTargetAudience = "";
    private string _editNotes          = "";

    private void OpenEdit(ProjectManagementDto proj)
    {
        _openRowMenuId     = -1;
        _editProject       = proj;
        _editNumber        = proj.ProjectNumber;
        _editTitle         = proj.Title;
        _editDescription   = proj.Description      ?? "";
        _editTypeId        = proj.ProjectTypeId;
        _editStatus        = proj.Status;
        _editPriority      = proj.Priority         ?? "";
        _editOrgName       = proj.OrganizationName ?? "";
        _editContact       = proj.ContactPerson    ?? "";
        _editContactRole   = proj.ContactRole      ?? "";
        _editGoals         = proj.Goals            ?? "";
        _editTargetAudience = proj.TargetAudience  ?? "";
        _editNotes         = proj.InternalNotes    ?? "";
        _editError         = "";
        _editSuccess       = false;
    }

    private void CloseEdit()
    {
        if (_editSaving) return;
        _editProject = null;
        _editError   = "";
        _editSuccess = false;
    }

    private async Task SaveEdit()
    {
        if (_editProject is null) return;

        _editError   = "";
        _editSuccess = false;

        if (_editNumber <= 0)
            { _editError = "יש להזין מספר פרויקט תקין"; return; }
        if (string.IsNullOrWhiteSpace(_editTitle))
            { _editError = "שם הפרויקט הוא שדה חובה"; return; }
        if (_editTypeId <= 0)
            { _editError = "יש לבחור סוג פרויקט"; return; }

        _editSaving = true;

        var req = new UpdateProjectRequest
        {
            ProjectNumber    = _editNumber,
            Title            = _editTitle.Trim(),
            Description      = Nz(_editDescription),
            ProjectTypeId    = _editTypeId,
            Status           = _editStatus,
            OrganizationName = Nz(_editOrgName),
            ContactPerson    = Nz(_editContact),
            ContactRole      = Nz(_editContactRole),
            Goals            = Nz(_editGoals),
            TargetAudience   = Nz(_editTargetAudience),
            InternalNotes    = Nz(_editNotes),
            Priority         = Nz(_editPriority),
        };

        var (ok, error) = await ManagementService.UpdateProjectAsync(_editProject.Id, req);
        _editSaving = false;

        if (!ok)
        {
            _editError = string.IsNullOrWhiteSpace(error) ? "שגיאה בשמירת הפרויקט" : error;
            return;
        }

        // Sync changes back into the in-memory list item
        _editProject.ProjectNumber    = req.ProjectNumber;
        _editProject.Title            = req.Title;
        _editProject.Description      = req.Description;
        _editProject.Status           = req.Status;
        _editProject.OrganizationName = req.OrganizationName;
        _editProject.ContactPerson    = req.ContactPerson;
        _editProject.ContactRole      = req.ContactRole;
        _editProject.Goals            = req.Goals;
        _editProject.TargetAudience   = req.TargetAudience;
        _editProject.InternalNotes    = req.InternalNotes;
        _editProject.Priority         = req.Priority;

        var selectedType = _projectTypes.FirstOrDefault(t => t.Id == req.ProjectTypeId);
        if (selectedType is not null)
        {
            _editProject.ProjectType   = selectedType.Name;
            _editProject.ProjectTypeId = selectedType.Id;
        }

        _editSuccess = true;

        // Auto-close after brief success feedback
        await Task.Delay(900);
        _editProject = null;
        _editSuccess = false;
    }

    // ─────────────────────────────────────────────────
    //  Row actions
    // ─────────────────────────────────────────────────
    private void ImportAction(string source) => _importMenuOpen = false;

    private async Task ToggleStatus(ProjectManagementDto proj)
    {
        _openRowMenuId = -1;
        string newStatus = proj.Status == "Active" ? "Inactive" : "Active";
        bool ok = await ManagementService.UpdateProjectStatusAsync(proj.Id, newStatus);
        if (ok) proj.Status = newStatus;
    }

    // ─────────────────────────────────────────────────
    //  Helpers
    // ─────────────────────────────────────────────────
    private static string? Nz(string? s) =>
        string.IsNullOrWhiteSpace(s) ? null : s.Trim();

    private static string StatusClass(string status) => status switch
    {
        "Active"      => "pm-status--active",
        "Inactive"    => "pm-status--inactive",
        "Available"   => "pm-status--available",
        "Unavailable" => "pm-status--unavailable",
        _             => "pm-status--other",
    };

    private static string StatusLabel(string status) => status switch
    {
        "Active"      => "פעיל",
        "Inactive"    => "לא פעיל",
        "Archived"    => "בארכיון",
        "Available"   => "זמין לשיבוץ",
        "Unavailable" => "לא זמין",
        _             => status,
    };

    private static string PriorityLabel(string? p) => p switch
    {
        "Low"    => "נמוכה",
        "Normal" => "רגילה",
        "High"   => "גבוהה",
        "Urgent" => "דחוף",
        _        => string.IsNullOrWhiteSpace(p) ? "—" : p,
    };
}
