@inject NavigationManager Nav

<div class="cards-wrapper">
    <div class="cards-grid">
        @foreach (var card in _cards)
        {
            <button class="mgmt-card" @onclick="@(() => Nav.NavigateTo(card.Route))" title="@card.Title">
                <div class="mgmt-card-icon-wrap">
                    <span class="oi @card.Icon" aria-hidden="true"></span>
                </div>
                <div class="mgmt-card-content">
                    <div class="mgmt-card-title">@card.Title</div>
                    <div class="mgmt-card-desc">@card.Description</div>
                </div>
                <span class="oi oi-chevron-left mgmt-card-arrow" aria-hidden="true"></span>
            </button>
        }
    </div>
</div>

@code {
    private record ManagementCard(string Icon, string Title, string Description, string Route);

    private readonly List<ManagementCard> _cards = new()
    {
        new("oi-people",    "משתמשים",        "ניהול סטודנטים, מנחים ומרצים",                           "/management/users"),
        new("oi-briefcase", "פרויקטים",       "ניהול פרויקטים, הגדרות וסטטוסים",                       "/management/projects"),
        new("oi-calendar",  "מחזורים",        "הגדרת מחזורים אקדמיים, פתיחה וסגירת מחזורים",           "/management/cycles"),
        new("oi-target",    "שיבוצים",        "שיבוץ סטודנטים לפרויקטים, טפסי העדפה ומדד ביקוש",      "/management/assignments"),
        new("oi-document",  "חומרי עזר",      "מסמכים, סרטונים וקבצים מקוטלגים לפי אבני דרך",         "/management/resources"),
        new("oi-cog",       "הגדרות מערכת",   "הגדרות כלליות, התראות, לוגים והרשאות",                  "/management/settings"),
    };
}
