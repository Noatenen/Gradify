@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="cards-wrapper">

    <!-- ══ Registration link widget ══════════════════════════════════════════ -->
    <div class="reg-link-bar">
        <div class="reg-link-info">
            <span class="reg-link-label">לינק הרשמה לסטודנטים</span>
            <span class="reg-link-url">@_registrationUrl</span>
        </div>
        <div class="reg-link-actions">
            <button class="reg-link-btn" @onclick="CopyLink">
                @if (_copied)
                {
                    <span class="reg-link-check">✓</span>
                    <span>הקישור הועתק ללוח</span>
                }
                else
                {
                    <span>העתק קישור</span>
                }
            </button>
        </div>
    </div>

    <div class="cards-grid">
        @foreach (var card in _cards)
        {
            <button class="mgmt-card" @onclick="@(() => Nav.NavigateTo(card.Route))" title="@card.Title">
                <div class="mgmt-card-icon-wrap">
                    <span class="oi @card.Icon" aria-hidden="true"></span>
                </div>
                <div class="mgmt-card-content">
                    <div class="mgmt-card-title">@card.Title</div>
                    <div class="mgmt-card-desc">@card.Description</div>
                </div>
                <span class="oi oi-chevron-left mgmt-card-arrow" aria-hidden="true"></span>
            </button>
        }
    </div>
</div>

@code {
    private bool   _copied = false;
    private string _registrationUrl => Nav.BaseUri.TrimEnd('/') + "/create-team";

    private async Task CopyLink()
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", _registrationUrl);
        _copied = true;
        StateHasChanged();
        await Task.Delay(2500);
        _copied = false;
    }

    private record ManagementCard(string Icon, string Title, string Description, string Route);

    private readonly List<ManagementCard> _cards = new()
    {
        new("oi-people",    "משתמשים",        "ניהול סטודנטים, מנחים ומרצים",                           "/management/users"),
        new("oi-list",      "קטלוג פרויקטים", "הצעות פרויקט, זמינות ושיוך למחזור",                     "/management/catalog"),
        new("oi-briefcase", "פרויקטים פעילים","ניהול פרויקטים מוקצים, צוותות וסטטוסים",                "/management/projects"),
        new("oi-calendar",  "מחזורים",        "הגדרת מחזורים אקדמיים, פתיחה וסגירת מחזורים",           "/management/cycles"),
        new("oi-flag",      "אבני דרך",        "ניהול תבניות אבני דרך ושיוך לסוגי פרויקטים",            "/management/milestones"),
        new("oi-check",     "משימות",          "ניהול תבניות משימות וקישורן לאבני דרך",                  "/management/tasks"),
        new("oi-target",    "שיבוצים",        "שיבוץ סטודנטים לפרויקטים, טפסי העדפה ומדד ביקוש",      "/management/assignments"),
        new("oi-document",       "חומרי עזר",   "מסמכים, סרטונים וקבצים מקוטלגים לפי אבני דרך",         "/management/resources"),
        new("oi-envelope-closed","בקשות",       "ניהול בקשות סטודנטים: דחיות, אתגרים ופניות",            "/management/requests"),
        new("oi-link-intact",    "אינטגרציות",  "הגדרת Slack ואינטגרציות חיצוניות נוספות",               "/management/integrations"),
        new("oi-cog",            "הגדרות מערכת","הגדרות כלליות, התראות, לוגים והרשאות",                  "/management/settings"),
    };
}
