@using AuthWithAdmin.Shared.AuthSharedModels

<div class="tsc-grid">

    <div class="tsc-card tsc-active">
        <div class="tsc-card-top">
            <div class="tsc-icon-wrap tsc-icon-active">
                <span class="oi oi-clock" aria-hidden="true"></span>
            </div>
            <span class="tsc-count">@ActiveCount</span>
        </div>
        <div class="tsc-label">משימות פעילות</div>
        <div class="tsc-sublabel">ניתן לפעול עכשיו</div>
    </div>

    <div class="tsc-card tsc-pending">
        <div class="tsc-card-top">
            <div class="tsc-icon-wrap tsc-icon-pending">
                <span class="oi oi-media-pause" aria-hidden="true"></span>
            </div>
            <span class="tsc-count">@PendingCount</span>
        </div>
        <div class="tsc-label">משימות בהמתנה</div>
        <div class="tsc-sublabel">אבן הדרך טרם נפתחה</div>
    </div>

    <div class="tsc-card tsc-completed">
        <div class="tsc-card-top">
            <div class="tsc-icon-wrap tsc-icon-completed">
                <span class="oi oi-check" aria-hidden="true"></span>
            </div>
            <span class="tsc-count">@CompletedCount</span>
        </div>
        <div class="tsc-label">משימות שהושלמו</div>
        <div class="tsc-sublabel">הושלמו בהצלחה</div>
    </div>

</div>

@code {
    [Parameter, EditorRequired] public int ActiveCount    { get; set; }
    [Parameter, EditorRequired] public int PendingCount   { get; set; }
    [Parameter, EditorRequired] public int CompletedCount { get; set; }
}
