@using AuthWithAdmin.Shared.AuthSharedModels

<div class="tma-section">
    <div class="tma-section-header-row">
        <h2 class="tma-section-title">@SectionTitle</h2>
        @if (ShowAddButton)
        {
            <button class="tma-add-btn">
                <span class="oi oi-plus" aria-hidden="true"></span>
                משימה חדשה
            </button>
        }
    </div>

    @if (IsCompletedSection && ProjectTotalCount > 0)
    {
        <div class="tma-project-progress">
            <span class="tma-project-progress-label">
                התקדמות כוללת: @ProjectCompletedCount / @ProjectTotalCount משימות הושלמו
            </span>
            <div class="tma-project-progress-bar-track">
                <div class="tma-project-progress-bar-fill"
                     style="width: @(ProjectTotalCount > 0 ? (ProjectCompletedCount * 100 / ProjectTotalCount) : 0)%"></div>
            </div>
        </div>
    }

    @if (!Groups.Any())
    {
        <div class="tma-empty">
            <span class="oi oi-info" aria-hidden="true"></span>
            <span>@EmptyMessage</span>
        </div>
    }
    else
    {
        <div class="tma-groups">
            @foreach (var group in Groups)
            {
                bool isOpen = _openGroups.Contains(group.ProjectMilestoneId);
                // Milestone dot uses "attention" (orange) if any task is returned or overdue.
                // This prevents a green/completed dot from misleading when tasks need action.
                bool groupNeedsAttention = !IsCompletedSection
                    && group.Tasks.Any(TaskNeedsAttention);

                <div class="tma-group @(isOpen ? "tma-group-open" : "")">

                    <button class="tma-group-header"
                            @onclick="() => Toggle(group.ProjectMilestoneId)">
                        <div class="tma-group-start">
                            <span class="tma-ms-dot @(groupNeedsAttention ? "tma-ms-attention" : "tma-ms-@MsClass(group.MilestoneStatus)")"
                                  title="@(groupNeedsAttention ? "יש משימות שדורשות תשומת לב" : MsLabel(group.MilestoneStatus))"></span>
                            <span class="tma-ms-title">@group.MilestoneTitle</span>
                            @if (group.DueDate.HasValue)
                            {
                                <span class="tma-ms-due">
                                    <span class="oi oi-calendar" aria-hidden="true"></span>
                                    @group.DueDate.Value.ToString("dd/MM/yy")
                                </span>
                            }
                        </div>
                        <div class="tma-group-end">
                            @if (!IsCompletedSection)
                            {
                                <span class="tma-count-badge @(group.DoneCount == group.TotalCount && group.TotalCount > 0 ? "tma-count-all-done" : "")">
                                    @group.DoneCount/@group.TotalCount הושלמו
                                </span>
                            }
                            else
                            {
                                <span class="tma-count-badge tma-count-all-done">
                                    @group.DoneCount/@group.TotalCount הושלמו
                                </span>
                            }
                            <span class="oi @(isOpen ? "oi-chevron-top" : "oi-chevron-bottom") tma-chevron"
                                  aria-hidden="true"></span>
                        </div>
                    </button>

                    @if (isOpen)
                    {
                        <div class="tma-task-list">
                            @foreach (var task in group.Tasks)
                            {
                                bool isPending = !IsCompletedSection && task.MilestoneStatus == "NotStarted";
                                string resolvedStatus = ResolveDisplayStatus(task);
                                // A task is overdue when due date passed and it has not been
                                // touched at all (Open or InProgress).
                                // Returned tasks already communicate urgency through their own
                                // "returned" state — don't mask it with a generic "overdue" label.
                                bool isOverdue = !IsCompletedSection
                                             && task.DueDate.HasValue
                                             && task.DueDate.Value.Date < DateTime.Today
                                             && resolvedStatus is "Open" or "InProgress";

                                <div class="tma-task-row @(isPending ? "tma-task-pending" : "") @RowHighlightClass(resolvedStatus)"
                                     title="לחץ לפרטי המשימה"
                                     @onclick="() => OnOpenDetail.InvokeAsync(task.Id)">

                                    <div class="tma-task-icon tma-icon-@TaskIconClass(resolvedStatus, isPending, isOverdue)">
                                        <span class="oi @TaskIcon(resolvedStatus, isPending, isOverdue)"
                                              aria-hidden="true"></span>
                                    </div>

                                    <div class="tma-task-body">
                                        <span class="tma-task-title @(IsCompletedSection ? "tma-task-done-text" : "")">
                                            @task.Title
                                        </span>
                                        <div class="tma-task-meta">
                                            @if (!IsCompletedSection)
                                            {
                                                @if (task.DueDate.HasValue)
                                                {
                                                    <span class="tma-meta-item @(isOverdue ? "tma-meta-overdue" : "")">
                                                        <span class="oi oi-calendar" aria-hidden="true"></span>
                                                        @task.DueDate.Value.ToString("dd/MM/yy")
                                                        @if (isOverdue) { <span>(באיחור)</span> }
                                                    </span>
                                                }
                                                @if (task.LatestSubmittedAt.HasValue
                                                     && resolvedStatus is "PendingMentorReview" or "ReturnedByMentor"
                                                                       or "ReturnedForRevision" or "ApprovedByMentor")
                                                {
                                                    <span class="tma-meta-item tma-meta-submitted">
                                                        <span class="oi oi-data-transfer-upload" aria-hidden="true"></span>
                                                        הוגש @task.LatestSubmittedAt.Value.ToString("dd/MM/yy")
                                                    </span>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(task.AssignedToName))
                                                {
                                                    <span class="tma-meta-item">
                                                        <span class="oi oi-person" aria-hidden="true"></span>
                                                        @task.AssignedToName
                                                    </span>
                                                }
                                            }
                                            else
                                            {
                                                @if (task.CompletedAt.HasValue)
                                                {
                                                    <span class="tma-meta-item tma-meta-completed-at">
                                                        <span class="oi oi-check" aria-hidden="true"></span>
                                                        הושלמה ב: @task.CompletedAt.Value.ToString("dd/MM/yyyy")
                                                    </span>
                                                }
                                            }
                                        </div>
                                    </div>

                                    @if (!IsCompletedSection)
                                    {
                                        <!-- Status badge comes first so it's visually closest to the icon
                                             (rightmost in RTL), then the submit action. -->
                                        <div class="tma-task-badges">
                                            <span class="tma-status-badge tma-badge-@StatusClass(resolvedStatus, isPending, isOverdue)">
                                                @StatusLabel(resolvedStatus, isPending, isOverdue)
                                            </span>
                                            @if (task.IsSubmission && !isPending)
                                            {
                                                <button class="tma-submit-btn"
                                                        @onclick:stopPropagation="true"
                                                        @onclick="@(() => OnOpenSubmission.InvokeAsync(task.Id))"
                                                        title="פתח הגשה">
                                                    <span class="oi oi-data-transfer-upload" aria-hidden="true"></span>
                                                    הגש
                                                </button>
                                            }
                                            @if (task.IsMandatory)
                                            {
                                                <span class="tma-priority-badge">חובה</span>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="oi oi-circle-check tma-done-check" aria-hidden="true"></span>
                                    }

                                </div>
                            }
                        </div>
                    }

                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public string                    SectionTitle        { get; set; } = "";
    [Parameter, EditorRequired] public List<TaskMilestoneGroupDto> Groups            { get; set; } = default!;
    [Parameter]                 public bool                      IsCompletedSection  { get; set; }
    [Parameter]                 public string                    EmptyMessage        { get; set; } = "אין משימות להצגה";
    [Parameter]                 public bool                      ShowAddButton       { get; set; }
    [Parameter]                 public int                       ProjectCompletedCount { get; set; }
    [Parameter]                 public int                       ProjectTotalCount   { get; set; }
    [Parameter] public EventCallback<int> OnOpenSubmission { get; set; }
    [Parameter] public EventCallback<int> OnOpenDetail     { get; set; }

    private readonly HashSet<int> _openGroups = new();

    protected override void OnInitialized()
    {
        // Open the first InProgress or Delayed milestone by default in the active section
        if (!IsCompletedSection)
        {
            var first = Groups.FirstOrDefault(g =>
                g.MilestoneStatus == "InProgress" || g.MilestoneStatus == "Delayed");
            first ??= Groups.FirstOrDefault();
            if (first is not null) _openGroups.Add(first.ProjectMilestoneId);
        }
    }

    private void Toggle(int id)
    {
        if (!_openGroups.Remove(id)) _openGroups.Add(id);
    }

    private static string RowHighlightClass(string status) =>
        status is "ReturnedByMentor" or "ReturnedForRevision" ? "tma-row-attention" : "";

    // Returns true when a task requires student attention — used to set the milestone dot color.
    private static bool TaskNeedsAttention(TaskItemDto t)
    {
        string resolved = ResolveDisplayStatus(t);
        if (resolved is "ReturnedByMentor" or "ReturnedForRevision") return true;
        return t.DueDate.HasValue
            && t.DueDate.Value.Date < DateTime.Today
            && resolved is "Open" or "InProgress";
    }

    // ── Milestone status helpers ──────────────────────────────────────────────
    private static string MsClass(string s) => s switch
    {
        "Completed"  => "completed",
        "InProgress" => "inprogress",
        "Delayed"    => "delayed",
        _            => "notstarted",
    };

    private static string MsLabel(string s) => s switch
    {
        "Completed"  => "הושלם",
        "InProgress" => "פעיל",
        "Delayed"    => "באיחור",
        _            => "טרם נפתח",
    };

    // ── Effective status resolution ───────────────────────────────────────────
    // Priority order for submission tasks:
    //  1. Mentor returned   → "ReturnedByMentor"   (student must fix + resubmit)
    //  2. Reviewer returned → "ReturnedForRevision" (NeedsRevision from lecturer)
    //  3. Submission pending mentor review → "PendingMentorReview"
    //  4. Mentor approved, reviewer pending → "ApprovedByMentor"
    //  5. Fall back to task.Status (covers Done, InProgress, Open, etc.)
    private static string ResolveDisplayStatus(TaskItemDto task)
    {
        if (!task.IsSubmission || task.LatestSubmissionStatus is null)
            return task.Status;

        if (task.LatestMentorStatus == "Returned")
            return "ReturnedByMentor";

        if (task.LatestSubmissionStatus == "NeedsRevision")
            return "ReturnedForRevision";

        if (task.LatestMentorStatus == "Pending")
            return "PendingMentorReview";

        if (task.LatestMentorStatus == "Approved" && task.LatestSubmissionStatus == "Submitted")
            return "ApprovedByMentor";

        return task.Status;
    }

    // ── Task status helpers ───────────────────────────────────────────────────
    private static string StatusClass(string status, bool isPending, bool isOverdue)
    {
        if (isOverdue) return "overdue";
        if (isPending) return "pending";
        return status switch
        {
            "InProgress"            => "inprogress",
            "SubmittedToMentor"     => "submitted",
            "ReturnedForRevision"   => "returned",
            "RevisionSubmitted"     => "revision",
            "ApprovedForSubmission" => "approved",
            "Done"                  => "done",
            "PendingMentorReview"   => "submitted",
            "ReturnedByMentor"      => "returned",
            "ApprovedByMentor"      => "approved",
            _                       => "open",
        };
    }

    private static string StatusLabel(string status, bool isPending, bool isOverdue)
    {
        if (isOverdue) return "באיחור";
        if (isPending) return "ממתין לביצוע";
        return status switch
        {
            "InProgress"            => "בעבודה",
            "SubmittedToMentor"     => "הועבר לבדיקת מנחה",
            "ReturnedForRevision"   => "הוחזר לתיקון",
            "RevisionSubmitted"     => "הועבר לבדיקת מנחה",
            "ApprovedForSubmission" => "אושר להגשה",
            "Done"                  => "הושלם",
            "PendingMentorReview"   => "ממתין לאישור מנחה",
            "ReturnedByMentor"      => "הוחזר ע״י מנחה",
            "ApprovedByMentor"      => "ממתין לאישור מרצה",
            _                       => "ממתין לביצוע",
        };
    }

    private static string TaskIconClass(string status, bool isPending, bool isOverdue)
    {
        if (isOverdue) return "overdue";
        if (isPending) return "pending";
        return status switch
        {
            "InProgress"            => "inprogress",
            "SubmittedToMentor"     => "submitted",
            "ReturnedForRevision"   => "returned",
            "RevisionSubmitted"     => "revision",
            "ApprovedForSubmission" => "approved",
            "Done"                  => "completed",
            "PendingMentorReview"   => "submitted",
            "ReturnedByMentor"      => "returned",
            "ApprovedByMentor"      => "approved",
            _                       => "open",
        };
    }

    private static string TaskIcon(string status, bool isPending, bool isOverdue)
    {
        if (isOverdue) return "oi-warning";
        if (isPending) return "oi-clock";
        return status switch
        {
            "InProgress"            => "oi-reload",
            "SubmittedToMentor"     => "oi-data-transfer-upload",
            "ReturnedForRevision"   => "oi-arrow-circle-left",
            "RevisionSubmitted"     => "oi-loop-circular",
            "ApprovedForSubmission" => "oi-circle-check",
            "Done"                  => "oi-circle-check",
            "PendingMentorReview"   => "oi-data-transfer-upload",
            "ReturnedByMentor"      => "oi-arrow-circle-left",
            "ApprovedByMentor"      => "oi-circle-check",
            _                       => "oi-media-record",
        };
    }
}
