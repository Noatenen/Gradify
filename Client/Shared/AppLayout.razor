@inherits LayoutComponentBase

@*
    AppLayout — shared shell for the authenticated app area.
    Renders the sidebar navigation + the page content side by side.
    Auth pages (Login, Signup, etc.) continue to use MainLayout.
*@

<div class="app-shell">
    <AppSideNav />
    <div class="app-content">
        @Body
    </div>
</div>
