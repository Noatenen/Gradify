@using AuthWithAdmin.Client.Services
@using AuthWithAdmin.Client.Models
@using AuthWithAdmin.Shared.AuthSharedModels
@inject IAuthenticationService _Auth
@inject IProjectContextService _ProjectContext
@inject NavigationManager Nav

<aside class="sidenav-wrapper">
    <div class="sidenav-panel">

        <!-- ======= User Header ======= -->
        <div class="snav-header">
            <div class="snav-user-row">
                <div class="snav-avatar">@GetInitials()</div>
                <div class="snav-user-text">
                    <div class="snav-user-name">@($"{_user?.FirstName} {_user?.LastName}".Trim())</div>
                    <div class="snav-user-role">@RoleService.GetRoleLabel(_user)</div>
                    @if (_projectCtx is not null)
                    {
                        <div class="snav-project-info">
                            <div class="snav-project-number-row">
                                <div class="snav-project-number">
                                    <span class="oi oi-layers" aria-hidden="true"></span>
                                    צוות @_projectCtx.ProjectNumber
                                </div>
                                <TeamQuickInfoPopover TeamName="@(string.IsNullOrWhiteSpace(_projectCtx.TeamName) ? $"צוות {_projectCtx.ProjectNumber}" : _projectCtx.TeamName)"
                                                      ProjectTitle="@_projectCtx.ProjectTitle"
                                                      TrackName="@_projectCtx.TrackName"
                                                      StudentNames="_projectCtx.StudentNames"
                                                      StudentEmails="_projectCtx.StudentEmails"
                                                      MentorNames="_projectCtx.MentorNames"
                                                      MentorEmails="_projectCtx.MentorEmails"
                                                      ShowCopyAll="false">
                                    <button type="button"
                                            class="snav-team-info-btn"
                                            title="פרטי צוות"
                                            aria-label="פרטי צוות">
                                        <span class="oi oi-info" aria-hidden="true"></span>
                                        <span class="snav-team-info-btn-label">פרטי צוות</span>
                                    </button>
                                </TeamQuickInfoPopover>
                            </div>
                            <div class="snav-project-title">@_projectCtx.ProjectTitle</div>
                        </div>
                    }
                </div>
                <div class="snav-header-actions">
                    <NavLink class="snav-action-btn" href="settings" title="הגדרות" Match="NavLinkMatch.Prefix">
                        <span class="oi oi-cog" aria-hidden="true"></span>
                    </NavLink>
                    <NotificationBell />
                </div>
            </div>
        </div>

        <!-- ======= Main Navigation ======= -->
        <nav class="snav-section snav-section-main">
            @foreach (var item in _navMain)
            {
                <NavLink class="snav-item" href="@item.Href" Match="@item.Match">
                    <span class="oi @item.Icon snav-icon" aria-hidden="true"></span>
                    <span class="snav-label">@item.Label</span>
                </NavLink>
            }
        </nav>

        <div class="snav-divider"></div>

        <!-- ======= Bottom Navigation (admin / mentor only) ======= -->
        @if (_navBottom.Any())
        {
            <nav class="snav-section snav-section-bottom">
                @foreach (var item in _navBottom)
                {
                    <NavLink class="snav-item" href="@item.Href" Match="@item.Match">
                        <span class="oi @item.Icon snav-icon" aria-hidden="true"></span>
                        <span class="snav-label">@item.Label</span>
                    </NavLink>
                }
            </nav>
            <div class="snav-divider"></div>
        }

        <!-- ======= Project Status Widget (students with a project) ======= -->
        @if (_projectCtx is not null)
        {
            <div class="snav-widget">
                <div class="snav-widget-body">

                    @if (_widgetCard == 0)
                    {
                        <div class="snav-wcard">
                            <div class="snav-wcard-label">אבן דרך נוכחית</div>
                            @if (_projectCtx.CurrentMilestoneTitle is not null)
                            {
                                <div class="snav-wcard-value">@_projectCtx.CurrentMilestoneTitle</div>
                                <div class="snav-wcard-meta">
                                    <span class="snav-ms-badge snav-ms-@MsClass(_projectCtx.CurrentMilestoneStatus)">
                                        @MsLabel(_projectCtx.CurrentMilestoneStatus)
                                    </span>
                                    @if (_projectCtx.CurrentMilestoneDueDate.HasValue)
                                    {
                                        <span class="snav-wcard-due">
                                            <span class="oi oi-calendar" aria-hidden="true"></span>
                                            @_projectCtx.CurrentMilestoneDueDate.Value.ToString("dd/MM/yy")
                                        </span>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="snav-wcard-empty">כל אבני הדרך הושלמו</div>
                            }
                        </div>
                    }
                    else if (_widgetCard == 1)
                    {
                        <div class="snav-wcard">
                            <div class="snav-wcard-label">התקדמות כללית</div>
                            <div class="snav-progress-row">
                                <div class="snav-progress-track">
                                    <div class="snav-progress-fill"
                                         style="width: @MilestoneProgressPct()%"></div>
                                </div>
                                <span class="snav-progress-pct">@MilestoneProgressPct()%</span>
                            </div>
                            <div class="snav-progress-detail">
                                <span>
                                    <span class="oi oi-flag snav-detail-icon" aria-hidden="true"></span>
                                    @_projectCtx.MilestonesCompleted / @_projectCtx.MilestonesTotal אבני דרך
                                </span>
                                <span>
                                    <span class="oi oi-task snav-detail-icon" aria-hidden="true"></span>
                                    @_projectCtx.TasksDone / @_projectCtx.TasksTotal משימות
                                </span>
                            </div>
                        </div>
                    }
                    else if (_widgetCard == 2)
                    {
                        <div class="snav-wcard">
                            <div class="snav-wcard-label">משימה הבאה</div>
                            @if (_projectCtx.NextTaskTitle is not null)
                            {
                                <div class="snav-wcard-value">@_projectCtx.NextTaskTitle</div>
                                @if (_projectCtx.NextTaskDueDate.HasValue)
                                {
                                    <div class="snav-wcard-meta">
                                        <span class="snav-wcard-due">
                                            <span class="oi oi-calendar" aria-hidden="true"></span>
                                            @_projectCtx.NextTaskDueDate.Value.ToString("dd/MM/yy")
                                        </span>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="snav-wcard-empty">אין משימות פתוחות</div>
                            }
                        </div>
                    }

                </div>

                <div class="snav-widget-dots">
                    @{
                        int cardCount = WidgetCardCount;
                    }
                    @for (int i = 0; i < cardCount; i++)
                    {
                        int captured = i;
                        <button class="snav-dot @(_widgetCard == captured ? "snav-dot-active" : "")"
                                @onclick="() => _widgetCard = captured"
                                aria-label="@($"כרטיס {captured + 1}")">
                        </button>
                    }
                </div>
            </div>

            <div class="snav-divider"></div>
        }

        <!-- ======= Logout ======= -->
        <div class="snav-section snav-section-logout">
            <button class="snav-logout-btn" @onclick="HandleLogout">
                <span class="oi oi-account-logout snav-icon" aria-hidden="true"></span>
                <span class="snav-label">התנתקות</span>
            </button>
        </div>

    </div>
</aside>

@code {
    [CascadingParameter]
    private User? _user { get; set; }

    private IReadOnlyList<NavItem> _navMain    = Array.Empty<NavItem>();
    private IReadOnlyList<NavItem> _navBottom  = Array.Empty<NavItem>();
    private ProjectContextDto?     _projectCtx;
    private int                    _widgetCard;

    protected override async Task OnInitializedAsync()
    {
        _projectCtx = await _ProjectContext.GetAsync();
    }

    protected override void OnParametersSet()
    {
        (_navMain, _navBottom) = NavDefinitions.GetNavItems(_user);
    }

    private int WidgetCardCount => _projectCtx?.NextTaskTitle is not null ? 3 : 2;

    private int MilestoneProgressPct()
    {
        if (_projectCtx is null || _projectCtx.MilestonesTotal == 0) return 0;
        return _projectCtx.MilestonesCompleted * 100 / _projectCtx.MilestonesTotal;
    }

    private static string MsClass(string? s) => s switch
    {
        "Completed"  => "completed",
        "InProgress" => "inprogress",
        "Delayed"    => "delayed",
        _            => "notstarted",
    };

    private static string MsLabel(string? s) => s switch
    {
        "Completed"  => "הושלם",
        "InProgress" => "פעיל",
        "Delayed"    => "באיחור",
        _            => "טרם נפתח",
    };

    private string GetInitials()
    {
        var first = _user?.FirstName?.Trim() ?? "";
        var last  = _user?.LastName?.Trim()  ?? "";
        if (first.Length == 0 && last.Length == 0) return "?";
        return (first.Length > 0 ? first[0].ToString() : "")
             + (last.Length  > 0 ? last[0].ToString()  : "");
    }

    private async Task HandleLogout()
    {
        await _Auth.Logout();
        Nav.NavigateTo(PageRoutes.Login, forceLoad: true);
    }
}
