@using AuthWithAdmin.Client.Services
@using AuthWithAdmin.Client.Models
@using AuthWithAdmin.Shared.AuthSharedModels
@inject IAuthenticationService _Auth
@inject NavigationManager Nav

<aside class="sidenav-wrapper">
    <div class="sidenav-panel">

        <!-- ======= User Header ======= -->
        <div class="snav-header">
            <div class="snav-user-row">
                <div class="snav-avatar">@GetInitials()</div>
                <div class="snav-user-text">
                    <div class="snav-user-name">@($"{_user?.FirstName} {_user?.LastName}".Trim())</div>
                    <div class="snav-user-role">@RoleService.GetRoleLabel(_user)</div>
                </div>
                <div class="snav-bell" title="התראות">
                    <span class="oi oi-bell" aria-hidden="true"></span>
                    <span class="bell-dot"></span>
                </div>
            </div>
        </div>

        <!-- ======= Main Navigation ======= -->
        <nav class="snav-section snav-section-main">
            @foreach (var item in _navMain)
            {
                <NavLink class="snav-item" href="@item.Href" Match="@item.Match">
                    <span class="oi @item.Icon snav-icon" aria-hidden="true"></span>
                    <span class="snav-label">@item.Label</span>
                </NavLink>
            }
        </nav>

        <div class="snav-divider"></div>

        <!-- ======= Bottom Navigation ======= -->
        <nav class="snav-section snav-section-bottom">
            @foreach (var item in _navBottom)
            {
                <NavLink class="snav-item" href="@item.Href" Match="@item.Match">
                    <span class="oi @item.Icon snav-icon" aria-hidden="true"></span>
                    <span class="snav-label">@item.Label</span>
                </NavLink>
            }
        </nav>

        <div class="snav-divider"></div>

        <!-- ======= Logout ======= -->
        <div class="snav-section snav-section-logout">
            <button class="snav-logout-btn" @onclick="HandleLogout">
                <span class="oi oi-account-logout snav-icon" aria-hidden="true"></span>
                <span class="snav-label">התנתקות</span>
            </button>
        </div>

    </div>
</aside>

@code {
    [CascadingParameter]
    private User? _user { get; set; }

    private IReadOnlyList<NavItem> _navMain   = Array.Empty<NavItem>();
    private IReadOnlyList<NavItem> _navBottom = Array.Empty<NavItem>();

    protected override void OnParametersSet()
    {
        (_navMain, _navBottom) = NavDefinitions.GetNavItems(_user);
    }

    private string GetInitials()
    {
        var first = _user?.FirstName?.Trim() ?? "";
        var last  = _user?.LastName?.Trim()  ?? "";
        if (first.Length == 0 && last.Length == 0) return "?";
        return (first.Length > 0 ? first[0].ToString() : "")
             + (last.Length  > 0 ? last[0].ToString()  : "");
    }

    private async Task HandleLogout()
    {
        await _Auth.Logout();
        Nav.NavigateTo(PageRoutes.Login, forceLoad: true);
    }
}
