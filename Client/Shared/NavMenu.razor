@inject IAuthenticationService _Auth

<AuthorizeView>
    <Authorized>
        <div class="navbar navbar-dark">

            <div class="container-fluid justify-content-start">
                @if (user != null)
                {
                    <div class="px-3">
                        <span class="oi oi-person ps-2"></span>@user.FirstName @user.LastName
                    </div>
                    @if (user.Roles.Contains(Roles.Admin))
                    {
                        <NavLink class="nav-link" href="@PageRoutes.Admin">
                            <span aria-hidden="true"></span> ניהול משתמשים
                        </NavLink>

                    }

                }
               
                <div class="nav-item">
                    <NavLink class="nav-link" href="@PageRoutes.LandingPage" Match="NavLinkMatch.All">
                        <span aria-hidden="true"></span> דף הבית
                    </NavLink>
                </div>
                <div class="nav-item">
                    <NavLink class="nav-link" href="@PageRoutes.UserPage">
                        <span aria-hidden="true"></span> הפרויקטים שלי
                    </NavLink>
                </div>
                <div class="nav-item">
                    <button class="btn" @onclick="() => { _Auth.Logout(); }">התנתקות</button>
                </div>
            </div>
        </div>
    </Authorized>

    <NotAuthorized>
        <div class="navbar navbar-dark">
            <div class="container-fluid justify-content-start">
                <div class="nav-item">
                    <NavLink class="nav-link" href="@PageRoutes.LandingPage" Match="NavLinkMatch.All">
                        <span aria-hidden="true"></span> דף הבית
                    </NavLink>
                </div>
                <div class="nav-item">
                    <NavLink class="nav-link" href="@PageRoutes.UserPage">
                        <span aria-hidden="true"></span> הפרויקטים שלי
                    </NavLink>
                </div>
                <div class="nav-item">
                    <NavLink class="nav-link" href="@PageRoutes.Login">
                        <span aria-hidden="true"></span> התחברות
                    </NavLink>
                </div>
                <div class="nav-item">
                    <NavLink class="nav-link" href="@PageRoutes.Signup">
                        <span aria-hidden="true"></span> הרשמה
                    </NavLink>
                </div>
            </div>
        </div>
    </NotAuthorized>
</AuthorizeView>


@code {
    [CascadingParameter] private User user { get; set; }

}